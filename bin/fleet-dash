#!/usr/bin/env bash
# fleet-dash <session> — interactive agent dashboard for the command center.
# One row per agent (state · repo/branch · time-in-state · mode · last activity),
# sorted by urgency. Self-refreshes ~2s. Keyboard control: select / jump / cycle
# permission mode / send / new.
#
# Runs as the right-hand pane of the "main" window, inside the project session,
# so the fleet sub-commands it shells out to resolve session/root from $TMUX.

set -u
SESS="${1:-}"
[ -n "$SESS" ] || { echo "usage: fleet-dash <session>"; exit 1; }

SELF="$(readlink -f "${BASH_SOURCE[0]}")"   # this script, for in-place self-reload
FLEET_BIN="$(dirname "$SELF")/fleet"
CLIP_PCT="${FLEET_TILE_CLIP:-32}"        # right-column % kept for nvim panes
REFRESH="${FLEET_DASH_REFRESH:-1}"        # idle refresh interval, seconds
MODES=(default accept-edits plan auto)   # Shift+Tab cycle order (verified); bypass is not reachable via Shift+Tab
SELF_PANE="${TMUX_PANE:-}"                 # this dashboard's own tmux pane id
declare -A GIT_RAW GIT_TS                  # per-pane git status cache (4s TTL)
declare -A COST_RAW COST_TS                 # per-pane token/cost cache (10s TTL)
declare -A HNS_RAW                          # per-pane harness name cache
STALL_SEC="${FLEET_STALL:-600}"             # working longer than this = stalled

# config-sync / repo glance row: one pill per repo of the dashboard's CURRENT
# project (resolved from the session's @fleet_root), showing git state. For
# pc-tune the row is "live"-aware: each config repo carries a symlink-integrity
# check against its deployed path (the symlink→main deploy pattern is
# pc-tune-specific). Other projects are plain repos with no live-deploy map, so
# they show plain git-status pills (no `!` check) under a "repos" label.
# (docs/config-sync-architecture.md §3.1). Read-only; recomputed at most every 30s.
PC_TUNE_ROOT="${PC_TUNE_ROOT:-$HOME/proj/pc-tune}"   # built-in live-map anchor
CFG_PILL_MAX=8                              # cap pills/row (bound pathological roots)
CFG_RAW=""; CFG_NP=0; CFG_TS=""             # cached pill string / count / timestamp
CFG_LABEL="live"                            # row label ("live" for pc-tune, else "repos")

sel=0                                     # selected row index
status=""                                 # transient status line

# --- terminal setup ----------------------------------------------------------
cleanup() { printf '\033[?1004l' 2>/dev/null; tput rmcup 2>/dev/null; tput cnorm 2>/dev/null; }
trap cleanup EXIT INT TERM
tput smcup 2>/dev/null                    # alternate screen
tput civis 2>/dev/null                    # hide cursor
# Focus reporting: ask the terminal to send \033[I / \033[O on focus change, and
# have tmux forward them. They wake the read loop so the focus marker updates
# instantly instead of on the next ~2s refresh.
tmux set -g focus-events on 2>/dev/null
printf '\033[?1004h'

# --- helpers -----------------------------------------------------------------
glyph_color() { # state -> SGR color
  case "$1" in
    blocked) printf '\033[31m' ;;        # red
    working) printf '\033[34m' ;;        # blue
    idle)    printf '\033[32m' ;;        # green
    *)       printf '\033[90m' ;;        # grey
  esac
}

fit_left() { # fit to exactly w *display chars* (char-aware, avoids printf's byte
  local s="$1" w="$2" pad   # precision); left-ellipsis keeps the branch tail visible
  (( w <= 0 )) && return
  (( ${#s} > w )) && s="…${s: -$((w - 1))}"
  pad=$(( w - ${#s} )); (( pad < 0 )) && pad=0
  printf '%s%*s' "$s" "$pad" ''
}

mode_label() { # pane_id -> the agent's REAL permission mode, read from claude's
  local m   # footer "<glyph> <mode> on (shift+tab to cycle)". The glyph varies
            # per mode (⏵⏵ auto/accept, ⏸ plan, …), so match on the suffix and
            # take the mode words before it — never key off the glyph.
  m=$(tmux capture-pane -p -t "$1" 2>/dev/null \
      | grep -oE '[A-Za-z][A-Za-z ]*on \(shift\+tab to cycle\)' | tail -1 \
      | sed -E 's/ *on \(shift.*//; s/ +$//')
  # default (normal) mode prints no such line. Normalise to short labels.
  case "$m" in
    *bypass*|*Bypass*) printf 'bypass' ;;
    *plan*|*Plan*)     printf 'plan' ;;
    *accept*|*edit*)   printf 'accept-edits' ;;
    *auto*)            printf 'auto' ;;
    "")                printf 'default' ;;
    *)                 printf '%s' "$m" ;;
  esac
}

mode_color() { # mode text -> SGR (non-default modes stand out)
  case "$1" in
    *bypass*)       printf '\033[31m' ;;   # red — dangerous
    *plan*)         printf '\033[33m' ;;   # yellow
    *edit*|*auto*)  printf '\033[36m' ;;   # cyan
    *)              printf '\033[2m'  ;;   # dim — default
  esac
}

git_status() { # worktree dir -> "DIRTY AHEAD BEHIND"; empty if not a git tree
  git -C "$1" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return
  local d a b ab
  d=$(git -C "$1" status --porcelain 2>/dev/null | grep -c .)
  ab=$(git -C "$1" rev-list --left-right --count '@{upstream}...HEAD' 2>/dev/null)
  b=${ab%%[	 ]*}; a=${ab##*[	 ]}        # rev-list prints "behind<TAB>ahead"
  printf '%s %s %s' "${d:-0}" "${a:-0}" "${b:-0}"
}

git_cached() { # pane -> "DIRTY AHEAD BEHIND", recomputed at most every 4s
  local pane="$1" dir
  if [ -z "${GIT_TS[$pane]:-}" ] || (( SECONDS - GIT_TS[$pane] > 4 )); then
    dir=$(tmux display -p -t "$pane" '#{pane_current_path}' 2>/dev/null)
    GIT_RAW[$pane]=$(git_status "$dir"); GIT_TS[$pane]=$SECONDS
  fi
  printf '%s' "${GIT_RAW[$pane]}"
}

cost_cached() { # pane -> "$X.YZ Nk" token/cost, recomputed at most every 10s
  local pane="$1"
  if [ -z "${COST_TS[$pane]:-}" ] || (( SECONDS - COST_TS[$pane] > 10 )); then
    COST_RAW[$pane]=$("$FLEET_BIN" cost-pane "$pane" 2>/dev/null)
    COST_TS[$pane]=$SECONDS
  fi
  printf '%s' "${COST_RAW[$pane]:--}"
}

harness_of() { # pane -> harness name (@fleet_harness), default claude; cached
  local pane="$1"
  if [ -z "${HNS_RAW[$pane]:-}" ]; then
    HNS_RAW[$pane]=$(tmux display -p -t "$pane" '#{@fleet_harness}' 2>/dev/null)
    [ -n "${HNS_RAW[$pane]}" ] || HNS_RAW[$pane]=claude
  fi
  printf '%s' "${HNS_RAW[$pane]}"
}

harness_has_modes() { # harness -> 0 if it supports a permission-mode cycle
  case "$1" in claude) return 0 ;; *) return 1 ;; esac
}

gitfmt() { # "D A B" -> compact ASCII (≤8 cols): *dirty +ahead -behind, or ok/-
  [ -n "$1" ] || { printf -- '-'; return; }
  local d a b s=""; read -r d a b <<<"$1"
  (( ${d:-0} > 0 )) && s+="*$d "
  (( ${a:-0} > 0 )) && s+="+$a "
  (( ${b:-0} > 0 )) && s+="-$b "
  [ -z "$s" ] && s="ok"
  printf '%.8s' "$s"
}

gitcolor() { # "D A B" -> SGR (behind=red, dirty=yellow, ahead=cyan, clean=green)
  [ -n "$1" ] || { printf '\033[90m'; return; }
  local d a b; read -r d a b <<<"$1"
  if   (( ${b:-0} > 0 )); then printf '\033[31m'
  elif (( ${d:-0} > 0 )); then printf '\033[33m'
  elif (( ${a:-0} > 0 )); then printf '\033[36m'
  else printf '\033[32m'; fi
}

# --- pills (rounded nerd-font capsules, like the omarchy status bar) -----------
PILL_L=$''   # left semicircle (Nerd Font / powerline-extra)
PILL_R=$''   # right semicircle
PILL_W=7      # fixed inner text width — every pill is the same size
PILL_GAP=3    # spaces between row items (state · label · git · mode)
ROW_GAP=1     # blank rows between agents

pill_center() { # text -> centred/truncated to exactly PILL_W chars
  local t="$1" len=${#1} pad l
  (( len >= PILL_W )) && { printf '%.*s' "$PILL_W" "$t"; return; }
  pad=$(( PILL_W - len )); l=$(( pad / 2 ))
  printf '%*s%s%*s' "$l" '' "$t" "$(( pad - l ))" ''
}

pill() { # text color256 -> fixed-width rounded pill (display width = PILL_W + 4)
  local t c="$2" tf=0
  [ "$c" = 8 ] && tf=15                       # white text on the grey pill
  t=$(pill_center "$1")
  printf '\033[38;5;%s;49m%s\033[48;5;%s;38;5;%sm %s \033[49;38;5;%sm%s\033[0m' \
    "$c" "$PILL_L" "$c" "$tf" "$t" "$c" "$PILL_R"
}
mode_short() { case "$1" in accept-edits) echo accept ;; *) echo "$1" ;; esac; }
state_pcol() { case "$1" in blocked) echo 1;; working) echo 4;; idle) echo 2;; *) echo 8;; esac; }
mode_pcol()  { case "$1" in *bypass*) echo 1;; *plan*) echo 3;; *accept*|*edit*|*auto*) echo 6;; *) echo 8;; esac; }
git_pcol()   { # "D A B" -> pill colour
  [ -n "$1" ] || { echo 8; return; }
  local d a b; read -r d a b <<<"$1"
  if   (( ${b:-0} > 0 )); then echo 1
  elif (( ${d:-0} > 0 )); then echo 3
  elif (( ${a:-0} > 0 )); then echo 6
  else echo 2; fi
}

# --- config-sync / repo glance row -------------------------------------------
# One pill per repo of the dashboard's current project, sorted as the live map
# (pc-tune) declares or alphabetically (generic). Each pill: short name + git
# state marker (clean / *dirty / +ahead / vbehind), coloured like the git pill.
# For pc-tune repos a live-deploy symlink check adds a red `!` when the deployed
# path no longer resolves inside the repo's primary worktree. Generic projects
# have no live map, so they show plain git pills (no `!`) under a "repos" label.
# Sets CFG_RAW (pill string), CFG_NP (pill count), CFG_LABEL (row label).

dash_root() { # the dashboard's project root: @fleet_root → FLEET_ROOT → pwd
  local r; r=$(tmux show -t "$SESS" -v @fleet_root 2>/dev/null)
  [ -n "$r" ] && { printf '%s' "$r"; return 0; }
  [ -n "${FLEET_ROOT:-}" ] && { printf '%s' "$FLEET_ROOT"; return 0; }
  pwd
}

primary_worktree() { # container → primary worktree path; empty if no checkout
  # main/ worktree (pc-tune shape) > plain repo > origin/HEAD default-branch
  # worktree > first worktree. Only the generic branches touch git (pc-tune
  # always hits the cheap main/ case, so its row stays git-call-free here).
  local cont="$1" w anchor def path br
  if [ -d "$cont/main" ] && [ -e "$cont/main/.git" ]; then printf '%s' "$cont/main"; return 0; fi
  # plain working repo: a non-bare checkout directly at the container (a bare
  # worktree-container has a .git too, but no work tree — fall through to glob).
  if [ -e "$cont/.git" ] && [ "$(git -C "$cont" rev-parse --is-inside-work-tree 2>/dev/null)" = true ]; then
    printf '%s' "$cont"; return 0          # a bare container prints "false" here → skip
  fi
  anchor=""
  for w in "$cont"/*/; do w="${w%/}"; [ -e "$w/.git" ] || continue; anchor="$w"; break; done
  [ -n "$anchor" ] || return 1
  def=$(git -C "$anchor" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||')
  if [ -n "$def" ]; then
    while IFS=$'\t' read -r path br; do
      [ "$br" = "$def" ] && { printf '%s' "$path"; return 0; }
    done < <(git -C "$anchor" worktree list --porcelain 2>/dev/null \
               | awk '/^worktree /{p=$2} /^branch /{sub("refs/heads/","",$2); print p"\t"$2}')
  fi
  printf '%s' "$anchor"
}

cfg_short() { # repo name → pill label: tmuxinator→tmxn, long hyphenated→last segment
  local n="$1"
  case "$n" in tmuxinator) printf 'tmxn'; return ;; esac
  (( ${#n} > PILL_W )) && case "$n" in *-*) n="${n##*-}" ;; esac
  printf '%s' "$n"
}

config_live() {
  CFG_RAW=""; CFG_NP=0; CFG_LABEL="repos"
  local root; root=$(dash_root); [ -n "$root" ] || return 0
  # Live map: built-in pc-tune set, applied only when the resolved root IS the
  # pc-tune root. Keyed by canonical path so $PWD/symlink variants still match;
  # both sides must be non-empty to avoid an empty==empty false positive.
  local -a specs=(); local -A livemap=()
  local s n p rc pc
  rc=$(readlink -f "$root" 2>/dev/null)
  pc=$(readlink -f "$PC_TUNE_ROOT" 2>/dev/null)
  if [ -n "$rc" ] && [ -n "$pc" ] && [ "$rc" = "$pc" ]; then
    specs=(
      "nvim|$HOME/.config/nvim"
      "tmux|$HOME/.tmux.conf"
      "tmuxinator|$HOME/.config/tmuxinator"
      "fleet|$HOME/.local/bin/fleet"
    )
    CFG_LABEL="live"
    for s in "${specs[@]}"; do IFS='|' read -r n p <<<"$s"; livemap[$n]="$p"; done
  fi
  # Repo list: live-map order when present (pc-tune → byte-for-byte today),
  # else all repos discovered under the root (alphabetical, generic projects).
  local -a names=()
  if (( ${#specs[@]} )); then
    for s in "${specs[@]}"; do IFS='|' read -r n p <<<"$s"; names+=("$n"); done
  else
    while IFS= read -r n; do [ -n "$n" ] && names+=("$n"); done \
      < <("$FLEET_BIN" repos 2>/dev/null)
  fi
  (( ${#names[@]} )) || return 0           # scratch / repo-less project → skip row
  local name cont prim g d a b col mark link canon got symok short gap count=0
  gap=$(printf '%*s' "$PILL_GAP" '')
  for name in "${names[@]}"; do
    (( count >= CFG_PILL_MAX )) && break    # bound pathological roots (noted)
    cont="$root/$name"
    prim=$(primary_worktree "$cont"); [ -n "$prim" ] || continue
    g=$(git_status "$prim"); read -r d a b <<<"${g:-0 0 0}"
    link="${livemap[$name]:-}"
    if [ -n "$link" ]; then
      # symlink integrity: deployed path resolves at/under the primary worktree
      canon=$(readlink -f "$prim" 2>/dev/null)
      got=$(readlink -f "$link" 2>/dev/null)
      if [ -z "$got" ] || [ -z "$canon" ]; then symok=0
      elif [ "$got" = "$canon" ] || case "$got" in "$canon"/*) true;; *) false;; esac; then symok=1
      else symok=0; fi
    else symok=1; fi                        # no live mapping → no `!` check
    if (( symok == 0 )); then col=1; mark="!"
    else
      col=$(git_pcol "$g")
      if   (( ${b:-0} > 0 )); then mark="v"
      elif (( ${d:-0} > 0 )); then mark="*"
      elif (( ${a:-0} > 0 )); then mark="+"
      else mark=""; fi
    fi
    short=$(cfg_short "$name")
    # state glyph is secondary: on names that fill PILL_W it truncates away, but
    # the pill colour (git_pcol: red behind / yellow dirty / cyan ahead) still
    # encodes state, so nothing is lost beyond the redundant glyph.
    [ -n "$CFG_RAW" ] && CFG_RAW+="$gap"
    CFG_RAW+=$(pill "$short${mark:+ $mark}" "$col")
    (( CFG_NP++ )); (( count++ ))
  done
}

config_live_cached() { # recompute CFG_RAW/CFG_NP at most every 30s
  if [ -z "$CFG_TS" ] || (( SECONDS - CFG_TS > 30 )); then config_live; CFG_TS=$SECONDS; fi
}

# --- data --------------------------------------------------------------------
# ROWS[] entries: state \t label \t window_id \t window_name \t since \t pane_id \t age
load_rows() {
  ROWS=()
  local line state label sess win wname since pane age order
  while IFS=$'\t' read -r state label sess win wname since pane age ready; do
    [ -n "$pane" ] || continue
    [ "$sess" = "$SESS" ] || continue     # this project only
    [ "$wname" = "main" ] && continue     # skip the orchestrator itself
    ROWS+=("$state"$'\t'"$label"$'\t'"$win"$'\t'"$wname"$'\t'"$since"$'\t'"$pane"$'\t'"${age:-0}"$'\t'"$ready")
  done < <("$FLEET_BIN" agents 2>/dev/null | sort -t$'\t' -k1,1 \
            | awk -F'\t' '
                $1=="blocked"{o=0} $1=="idle"{o=1} $1=="working"{o=2} $1!~/blocked|idle|working/{o=3}
                {print o"\t"$0}' | sort -n | cut -f2-)
  N=${#ROWS[@]}
  (( N == 0 )) && sel=0
  (( sel >= N )) && sel=$((N - 1))
  (( sel < 0 )) && sel=0
}

field() { printf '%s' "${ROWS[$1]}" | cut -f"$2"; }  # field <rowidx> <col>

# --- render ------------------------------------------------------------------
# Rounded box drawn inside the pane (tmux pane borders can't be rounded). Redraw
# in place (cursor-home, clear-to-EOL per line) so the pane never flashes.
# Border row helpers embed a title/hint label into a ─ rule between corners.
hrule() { # hrule <left-corner> <right-corner> <inner-width> [label]
  local l="$1" r="$2" w="$3" label="${4:-}" fill
  if [ -n "$label" ]; then
    # between the corners must be exactly w cols: "─" + lab + fill(n) = w.
    # Truncate an over-long label so the line can't wrap (which would scroll).
    local lab=" $label " avail=$(( w - 1 ))
    (( avail < 0 )) && avail=0
    (( ${#lab} > avail )) && lab="${lab:0:avail}"
    local n=$(( avail - ${#lab} )); (( n < 0 )) && n=0
    fill=$(printf '%.0s─' $(seq 1 "$n"))
    printf '%s─%s%s%s' "$l" "$lab" "$fill" "$r"
  else
    fill=$(printf '%.0s─' $(seq 1 "$w"))
    printf '%s%s%s' "$l" "$fill" "$r"
  fi
}

PAD_X=2          # blank columns inset on each side, inside the rails
PAD_Y=1          # blank rows of inset below the top border / above the bottom

render() {
  local cols rows; cols=$(tput cols); rows=$(tput lines)
  # leave the pane's last column empty: writing a full-width last line scrolls
  # on auto-wrap terminals. cols-3 keeps the right rail one column in.
  local inner=$(( cols - 3 ))                 # columns between the │ │ rails
  local slots=$(( rows - 2 ))                 # content rows between the borders
  local cw=$(( inner - 2 * PAD_X ))           # usable width after horizontal pad
  (( cw < 0 )) && cw=0
  local ins; ins=$(printf '%*s' "$PAD_X" '')  # left/right inset spaces
  local ins1; ins1=$(printf '%*s' $(( PAD_X - 1 )) '')   # inset minus the marker col
  local blank; blank=$(printf '%*s' "$inner" '')
  # Selection marker colour reflects keyboard focus: green when this dashboard
  # pane is the active pane of the current window (keys land here), dim grey
  # otherwise (focus is on the orchestrator/claude pane or another window).
  local pa; pa=$(tmux display -p -t "$SELF_PANE" '#{pane_active}#{window_active}' 2>/dev/null)
  local markc='\033[38;5;240m'                # unfocused: dim grey
  [ "$pa" = "11" ] && markc='\033[1;32m'      # focused: green
  tput cup 0 0 2>/dev/null

  # top border with title. Keep label text to width-1 glyphs only (box-drawing
  # chars and · are reliable; wide/ambiguous glyphs like ⏎ or nerd icons break
  # the char-count = display-width assumption hrule relies on).
  printf '\033[2m%s\033[0m\033[K\n' \
    "$(hrule '╭' '╮' "$inner" "FLEET · $SESS · $N agent$([ "$N" = 1 ] || echo s)")"

  local drawn=0 i
  for (( i=0; i<PAD_Y && drawn<slots; i++ )); do   # top padding rows
    printf '\033[2m│%s│\033[0m\033[K\n' "$blank"; (( drawn++ ))
  done

  # project repo glance row: one pill per repo, then a blank spacer. Skipped on
  # repo-less projects (CFG_NP==0) or when too narrow to fit. The label width is
  # derived from CFG_LABEL so "live " (pc-tune) and "repos " stay in budget.
  config_live_cached
  if (( CFG_NP > 0 && drawn < slots )); then
    local cpw=$(( PILL_W + 4 )) cused cpad clab
    clab="${CFG_LABEL:-live} "
    cused=$(( CFG_NP * cpw + (CFG_NP - 1) * PILL_GAP + ${#clab} ))
    cpad=$(( cw - cused ))
    if (( cpad >= 0 )); then
      printf '\033[2m│\033[0m%s\033[2m%s\033[0m%s%*s%s\033[2m│\033[0m\033[K\n' \
        "$ins" "$clab" "$CFG_RAW" "$cpad" '' "$ins"
      (( drawn++ ))
      (( drawn < slots )) && { printf '\033[2m│%s│\033[0m\033[K\n' "$blank"; (( drawn++ )); }
    fi
  fi

  if (( N == 0 )); then
    (( drawn < slots )) && { printf '\033[2m│\033[0m%s%-*s%s\033[2m│\033[0m\033[K\n' \
      "$ins" "$cw" "no agents yet — press n to spawn one" "$ins"; (( drawn++ )); }
  else
    # Row: <state pill>  repo/branch  <git pill>  <mode pill>. The label is the
    # flexible filler; pills (rounded capsules) have width len(text)+4. Content
    # width is kept exactly = cw so the right rail stays aligned.
    # every pill is the same display width (PW); the label is the flexible filler.
    # PILL_GAP-wide gaps separate the items.
    local PW=$(( PILL_W + 4 )) G=$PILL_GAP CF=12    # CF = cost field width
    local gap; gap=$(printf '%*s' "$G" '')
    local state label pane mode g gt content lblsgr LW git_show mode_show cost_show
    local age sdisp scol cost
    for (( i=0; i<N && drawn<slots; i++ )); do
      state=$(field "$i" 1); label=$(field "$i" 2); pane=$(field "$i" 6); age=$(field "$i" 7)
      g=$(git_cached "$pane"); gt=$(gitfmt "$g")
      # mode pill only for harnesses with a runtime permission-mode cycle (claude)
      local hmode np
      if harness_has_modes "$(harness_of "$pane")"; then mode=$(mode_label "$pane"); hmode=1; np=3
      else mode=""; hmode=0; np=2; fi
      git_show=1; mode_show=$hmode; cost_show=1
      LW=$(( cw - np*PW - CF - (np+1)*G ))         # np pills + cost + gaps
      (( LW < 1 )) && { cost_show=0; LW=$(( cw - np*PW - np*G )); }
      (( LW < 1 )) && (( hmode )) && { mode_show=0; np=2; LW=$(( cw - np*PW - np*G )); }
      (( LW < 1 )) && { git_show=0; LW=$(( cw - PW - G )); }
      (( LW < 0 )) && LW=0
      # stall: an agent stuck "working" too long shows a red 'stalled' pill
      sdisp="$state"; scol=$(state_pcol "$state")
      if [ "$state" = working ] && (( ${age:-0} > STALL_SEC )); then sdisp="stalled"; scol=1; fi
      # flagged ready for deletion (fleet ready) → magenta 'done' pill, overrides all
      [ -n "$(field "$i" 8)" ] && { sdisp="done"; scol=5; }
      (( i == sel )) && lblsgr='\033[1m' || lblsgr='\033[2m'
      content=$(pill "$sdisp" "$scol")
      content+=$(printf "%s${lblsgr}%b\033[22m" "$gap" "$(fit_left "$label" "$LW")")
      (( git_show )) && content+="$gap$(pill "$gt" "$(git_pcol "$g")")"
      (( mode_show )) && content+="$gap$(pill "$(mode_short "$mode")" "$(mode_pcol "$mode")")"
      if (( cost_show )); then
        cost=$(cost_cached "$pane")
        content+=$(printf "%s\033[2m%-*.*s\033[0m" "$gap" "$CF" "$CF" "$cost")
      fi
      if (( i == sel )); then   # focus-coloured marker bar marks the selection
        printf '\033[2m│\033[0m%b▌\033[0m%s%b%s\033[2m│\033[0m\033[K\n' \
          "$markc" "$ins1" "$content" "$ins"
      else
        printf '\033[2m│\033[0m%s%b%s\033[2m│\033[0m\033[K\n' "$ins" "$content" "$ins"
      fi
      (( drawn++ ))
      local gi                                  # vertical gap between agents
      for (( gi=0; gi<ROW_GAP && i<N-1 && drawn<slots; gi++ )); do
        printf '\033[2m│%s│\033[0m\033[K\n' "$blank"; (( drawn++ ))
      done
    done
  fi

  # empty side rails fill the box down to the bottom border (also = bottom pad)
  while (( drawn < slots )); do
    printf '\033[2m│%s│\033[0m\033[K\n' "$blank"
    (( drawn++ ))
  done

  # bottom border with key hints (or a transient status)
  local hint
  if [ -n "$status" ]; then hint="$status"
  else hint="j/k · Ent jump · v diff · m mode · s send · n new · d close · r/R refresh/reload"; fi
  tput cup $(( rows - 1 )) 0 2>/dev/null
  printf '\033[2m%s\033[0m\033[K' "$(hrule '╰' '╯' "$inner" "$hint")"
}

# read one line from the user at the bottom, cursor shown
ask() { # ask "prompt> " -> echoes reply
  local reply; local rows; rows=$(tput lines)
  tput cnorm 2>/dev/null
  tput cup $((rows - 1)) 0 2>/dev/null; tput el 2>/dev/null
  IFS= read -rep "$1" reply
  tput civis 2>/dev/null
  printf '%s' "$reply"
}

# --- modal popups -------------------------------------------------------------
# These draw a centred rounded box directly to /dev/tty and read keys from
# /dev/tty, so they can run inside $(...) and return only their result on stdout.
tsize() { stty size </dev/tty 2>/dev/null || echo "24 80"; }   # -> "rows cols"
at()  { printf '\033[%d;%dH' $(( $1 + 1 )) $(( $2 + 1 )) >/dev/tty; }   # cup row col (0-based)
mtop() { at "$1" "$2"; printf '\033[2m%s\033[0m' "$(hrule '╭' '╮' $(( $3 - 2 )) "$4")" >/dev/tty; }
mbot() { at "$1" "$2"; printf '\033[2m%s\033[0m' "$(hrule '╰' '╯' $(( $3 - 2 )) "")" >/dev/tty; }
mrow() { # row col width text [selected]
  local r="$1" x="$2" w="$3" t="$4" s="${5:-}"
  at "$r" "$x"
  if [ -n "$s" ]; then
    printf '\033[2m│\033[0m\033[7m %-*.*s \033[0m\033[2m│\033[0m' $(( w-4 )) $(( w-4 )) "$t" >/dev/tty
  else
    printf '\033[2m│\033[0m %-*.*s \033[2m│\033[0m' $(( w-4 )) $(( w-4 )) "$t" >/dev/tty
  fi
}

# --- permission-mode selection ------------------------------------------------
# Claude only exposes mode *cycling* (Shift+Tab), not "set mode X". The MODES list
# above is the Shift+Tab cycle order (verified empirically: default → accept-edits
# → plan → auto, looping; bypass is NOT in the Shift+Tab cycle in current claude).
# We present it as a pick-list, then drive the agent toward the chosen mode with
# apply_mode — which reads the live footer after each press, so it stays correct
# even if a claude version reorders the cycle (MODES only affects display order).

mode_desc() { # short hint per known mode
  case "$1" in
    default)      echo "prompt for each tool" ;;
    auto)         echo "auto mode" ;;
    accept-edits) echo "auto-accept edits" ;;
    plan)         echo "read-only planning" ;;
    bypass)       echo "skip all permission prompts" ;;
    *)            echo "" ;;
  esac
}

# pane -> true if claude is idle at its input prompt (the only state where
# Shift+Tab actually cycles the permission mode — not busy, not in a dialog).
agent_at_prompt() {
  tmux capture-pane -p -t "$1" 2>/dev/null | grep -qE '\? for shortcuts|shift\+tab to cycle'
}

msg_box() { # title line -> small centred notice box (drawn to /dev/tty)
  local title="$1" line="$2" R C bw=46
  read -r R C < <(tsize)
  local bx=$(( (C - bw) / 2 )) by=$(( (R - 3) / 2 ))
  (( bx < 0 )) && bx=0; (( by < 1 )) && by=1
  mtop "$by" "$bx" "$bw" "$title"; mrow $(( by+1 )) "$bx" "$bw" "  $line"; mbot $(( by+2 )) "$bx" "$bw"
}

settle_read() { # pane prev -> the mode once it has changed from prev AND is
  local pane="$1" prev="$2" cur last="__init__" i   # stable (seen twice). The
  for (( i=0; i<25; i++ )); do          # footer settles in ~100ms, so this polls
    sleep 0.1; cur=$(mode_label "$pane")   # fast and returns in ~0.2-0.3s; the
    [ "$cur" != "$prev" ] && [ "$cur" = "$last" ] && { printf '%s' "$cur"; return; }
    last="$cur"                         # stability check ignores transient frames.
  done
  printf '%s' "$cur"                    # gave up (~2.5s) — return latest
}


# apply_mode pane label target -> Shift+Tab toward target. Robust: stops if the
# cycle loops back to start (target not reachable) or the agent isn't responding,
# and restores the agent to its original mode on failure (bounded keystrokes).
apply_mode() {
  local pane="$1" label="$2" target="$3" start cur n=0
  start=$(mode_label "$pane"); cur="$start"
  [ "$cur" = "$target" ] && return 0
  while (( n < 8 )); do
    "$FLEET_BIN" mode "$label" >/dev/null 2>&1
    cur=$(settle_read "$pane" "$cur"); (( n++ ))
    [ "$cur" = "$target" ] && return 0
    [ "$cur" = "$start" ] && break          # full loop, or no change (stuck) → give up
  done
  while [ "$(mode_label "$pane")" != "$start" ] && (( n < 16 )); do
    "$FLEET_BIN" mode "$label" >/dev/null 2>&1; cur=$(settle_read "$pane" "$cur"); (( n++ ))
  done
  return 1
}

# pick_mode <pane> <label> -> centred mode picker; sets global `status`.
pick_mode() {
  local pane="$1" label="$2" k r R C bw=46
  local cur n=${#MODES[@]} mi=0 i
  cur=$(mode_label "$pane")
  for (( i=0; i<n; i++ )); do [ "${MODES[i]}" = "$cur" ] && mi=$i; done
  read -r R C < <(tsize)
  local bx=$(( (C - bw) / 2 )) by=$(( (R - (n + 2)) / 2 ))
  (( bx < 0 )) && bx=0; (( by < 1 )) && by=1
  while :; do
    mtop "$by" "$bx" "$bw" "Select permission mode"
    for (( i=0; i<n; i++ )); do
      local txt; txt=$(printf '%-13s %s' "${MODES[i]}" "$(mode_desc "${MODES[i]}")")
      if (( i == mi )); then mrow $(( by+1+i )) "$bx" "$bw" "$txt" 1
      else mrow $(( by+1+i )) "$bx" "$bw" "$txt"; fi
    done
    mbot $(( by+1+n )) "$bx" "$bw"
    IFS= read -rsN1 -t 120 k </dev/tty || return
    case "$k" in
      $'\e') IFS= read -rsN2 -t 0.01 r </dev/tty
        case "$r" in '[A') (( mi>0 ))&&((mi--));; '[B') (( mi<n-1 ))&&((mi++));; '') return;; esac ;;
      k) (( mi>0 ))&&((mi--)) ;;
      j) (( mi<n-1 ))&&((mi++)) ;;
      $'\n'|$'\r')
        local target="${MODES[mi]}"
        if [ "$target" = "$cur" ]; then status="mode: $target ($label)"; return; fi
        # Claude only cycles permission mode at its idle prompt — never poke a
        # busy agent or a permission dialog with Shift+Tab.
        if ! agent_at_prompt "$pane"; then
          status="$label is busy — set mode when it's idle at its prompt"; return
        fi
        msg_box "Permission mode" "setting $target ..."
        if apply_mode "$pane" "$label" "$target"; then status="mode -> $target ($label)"
        else status="couldn't reach $target — $label may lack that mode"; fi
        return ;;
      q) return ;;
    esac
  done
}

# list_pick <title> <cur-index> <item>... -> echoes the chosen index (or cur on
# cancel). Centred scrollable popup — used for the Repo/Base dropdowns.
list_pick() {
  local title="$1" cur="$2"; shift 2
  local items=("$@") n=${#items[@]}
  (( n == 0 )) && { echo "$cur"; return; }
  local mi="$cur"; (( mi<0 || mi>=n )) && mi=0
  local k r R C bw=50
  read -r R C < <(tsize)
  local maxv=$(( R - 6 )); (( maxv > n )) && maxv=$n; (( maxv < 3 )) && maxv=3
  local bx=$(( (C - bw) / 2 )) by=$(( (R - (maxv + 2)) / 2 )) vs=0
  (( bx < 0 )) && bx=0; (( by < 1 )) && by=1
  printf '\033[2J\033[H' >/dev/tty          # clean backdrop (not stdout — that's the result)
  while :; do
    (( mi < vs )) && vs=$mi
    (( mi >= vs + maxv )) && vs=$(( mi - maxv + 1 ))
    mtop "$by" "$bx" "$bw" "$title"
    local i row=0
    for (( i=vs; i<vs+maxv && i<n; i++ )); do
      if (( i == mi )); then mrow $(( by+1+row )) "$bx" "$bw" "${items[i]}" 1
      else mrow $(( by+1+row )) "$bx" "$bw" "${items[i]}"; fi
      ((row++))
    done
    while (( row < maxv )); do mrow $(( by+1+row )) "$bx" "$bw" ""; ((row++)); done
    mbot $(( by+1+maxv )) "$bx" "$bw"
    IFS= read -rsN1 -t 120 k </dev/tty || { echo "$cur"; return; }
    case "$k" in
      $'\e') IFS= read -rsN2 -t 0.01 r </dev/tty
        case "$r" in '[A') (( mi>0 ))&&((mi--));; '[B') (( mi<n-1 ))&&((mi++));; '') echo "$cur"; return;; esac ;;
      k) (( mi>0 ))&&((mi--)) ;;
      j) (( mi<n-1 ))&&((mi++)) ;;
      $'\n'|$'\r') echo "$mi"; return ;;
      q) echo "$cur"; return ;;
    esac
  done
}

# new_agent_form -> centred in-box form. Repo is a dropdown; Branch picks an
# EXISTING worktree to launch on, or "+ new branch" to create one (then a text
# field + Base appear). j/k or ↑/↓ move between fields. Sets global `status`.
NEWSENT="+ new branch"
new_agent_form() {
  local R C bw=58 prompt="" bare="no" scratch="no" ai=0 note="" k r x s newbranch="" editing=0
  local nitems=8    # 0 Repo,1 Branch,2 Base,3 Prompt,4 Scratch,5 Bare,6 Harness,7 Create
  # `editing` (0/1): text fields (Prompt; new-branch name) only capture keystrokes
  # while editing=1. Enter on a text field enters edit mode; Enter/Esc commits and
  # returns to nav mode. In nav mode j/k/arrows navigate every field uniformly.
  # Scratch is a plain toggle (not a text field) — it never uses editing mode.
  read -r R C < <(tsize)
  local REPOS=() ri=0
  while IFS= read -r x; do [ -n "$x" ] && REPOS+=("$x"); done < <("$FLEET_BIN" repos 2>/dev/null)
  local repo=""
  # No repos under the project root? A repo-less scratch agent is still possible.
  if (( ${#REPOS[@]} )); then repo="${REPOS[0]}"; else scratch="yes"; note="no repos found — scratch only"; ai=4; fi
  local HARN=() hi=0
  while IFS= read -r x; do [ -n "$x" ] && HARN+=("$x"); done < <("$FLEET_BIN" harnesses 2>/dev/null)
  (( ${#HARN[@]} == 0 )) && HARN=(claude)
  # default to claude if present
  local _i; for _i in "${!HARN[@]}"; do [ "${HARN[_i]}" = claude ] && hi=$_i; done
  local WT=() wi=0 BRANCHES=() bi=0
  _load_repo() {  # existing worktrees (+ a "new branch" entry) and base branches
    WT=(); while IFS= read -r x; do [ -n "$x" ] && WT+=("$x"); done < <("$FLEET_BIN" worktrees "$repo" 2>/dev/null)
    WT+=("$NEWSENT"); wi=0
    BRANCHES=(); bi=0
    while IFS= read -r x; do [ -n "$x" ] && BRANCHES+=("$x"); done < <("$FLEET_BIN" branches "$repo" 2>/dev/null)
  }
  _load_repo
  local bx=$(( (C - bw) / 2 )) by=$(( (R - 16) / 2 ))
  (( bx < 0 )) && bx=0; (( by < 1 )) && by=1

  _isnew() { [ "${WT[wi]}" = "$NEWSENT" ]; }
  _base() { (( ${#BRANCHES[@]} )) && printf '%s' "${BRANCHES[bi]}" || printf '(default)'; }
  _active() { # idx -> 0 if the field is navigable in the current mode
    [ "$scratch" = yes ] && case "$1" in 0|1|2|5) return 1 ;; esac   # repo/branch/base/bare off
    return 0
  }
  _step() { # move ai by <dir>, skipping inactive fields, clamped to the range
    local d="$1" j=$ai
    while :; do j=$(( j + d )); (( j<0 || j>=nitems )) && return; _active "$j" && { ai=$j; return; }; done
  }
  _toggle_scratch() { # repo-less needs at least the option; lock on when no repos
    (( ${#REPOS[@]} == 0 )) && { scratch=yes; note="no repos found — scratch only"; return; }
    [ "$scratch" = no ] && scratch=yes || scratch=no
  }
  _field() { # off idx label value type [placeholder]
    local off="$1" idx="$2" lbl="$3" v="$4" ty="$5" ph="${6:-}" disp txt
    if (( ai == idx )); then
      case "$ty" in
        text)   if (( editing )); then disp="${v}_"   # edit mode: trailing cursor
                else disp="${v:-$ph}"; fi ;;          # nav mode: plain value/placeholder
        select) disp="< ${v:-$ph} >" ;;
        *)      disp="$v" ;;
      esac
    else disp="${v:-$ph}"; fi
    txt=$(printf '%-8s %s' "$lbl" "$disp")
    if (( ai == idx )); then mrow $(( by+off )) "$bx" "$bw" "$txt" 1
    else mrow $(( by+off )) "$bx" "$bw" "$txt"; fi
  }
  _draw() {
    mtop "$by" "$bx" "$bw" "New fleet agent"
    mrow $(( by+1 )) "$bx" "$bw" ""
    if [ "$scratch" = yes ]; then
      _field 2 0 "Repo"   "(scratch — repo-less)" info
      _field 3 1 "Branch" "(scratch — repo-less)" info
      _field 4 2 "Base"   "(scratch — repo-less)" info
    elif _isnew; then
      _field 2 0 "Repo" "$repo" select
      _field 3 1 "Branch" "$newbranch" text "<new branch>"
      _field 4 2 "Base" "$(_base)" select
    else
      _field 2 0 "Repo" "$repo" select
      _field 3 1 "Branch" "${WT[wi]}" select
      _field 4 2 "Base" "(existing worktree)" info
    fi
    _field 5 3 "Prompt" "$prompt" text "(optional)"
    _field 6 4 "Scratch" "$scratch" toggle
    if [ "$scratch" = yes ]; then _field 7 5 "Bare" "(forced)" info
    else                          _field 7 5 "Bare" "$bare" toggle; fi
    _field 8 6 "Harness" "${HARN[hi]}" select
    mrow $(( by+9 )) "$bx" "$bw" ""
    if (( ai == 7 )); then mrow $(( by+10 )) "$bx" "$bw" "[ Create agent ]" 1
    else mrow $(( by+10 )) "$bx" "$bw" "  Create agent"; fi
    mrow $(( by+11 )) "$bx" "$bw" ""
    mrow $(( by+12 )) "$bx" "$bw" "${note:-j/k or up/down move . <> cycle . Enter=edit/list . Esc}"
    mbot $(( by+13 )) "$bx" "$bw"
  }
  _cyc() { # field <dir:1|-1> — cycle the active select
    local d="$1"
    case "$ai" in
      0) (( ${#REPOS[@]} )) && { ri=$(( (ri + d + ${#REPOS[@]}) % ${#REPOS[@]} )); repo="${REPOS[ri]}"; _load_repo; } ;;
      1) wi=$(( (wi + d + ${#WT[@]}) % ${#WT[@]} )) ;;
      2) _isnew && (( ${#BRANCHES[@]} )) && bi=$(( (bi + d + ${#BRANCHES[@]}) % ${#BRANCHES[@]} )) ;;
      4) _toggle_scratch ;;
      5) [ "$bare" = no ] && bare=yes || bare=no ;;
      6) hi=$(( (hi + d + ${#HARN[@]}) % ${#HARN[@]} )) ;;
    esac
  }
  _spawn() {
    local args
    if [ "$scratch" = yes ]; then   # repo-less: no repo/branch/worktree
      msg_box "New fleet agent" "launching scratch agent (${HARN[hi]}) ..."
      args=(--scratch)
      [ -n "$prompt" ] && args+=(-p "$prompt")
      args+=(--harness "${HARN[hi]}")
      if "$FLEET_BIN" new "${args[@]}" >/dev/null 2>&1; then status="launched: scratch (${HARN[hi]})"
      else status="spawn failed: scratch"; fi
      return 0
    fi
    local branch; if _isnew; then branch="$newbranch"; else branch="${WT[wi]}"; fi
    [ -n "$branch" ] || { note="pick a worktree or enter a new branch name"; return; }
    msg_box "New fleet agent" "launching $repo / $branch ..."
    args=("$repo" "$branch")
    [ -n "$prompt" ] && args+=(-p "$prompt")
    [ "$bare" = yes ] && args+=(--bare)
    if _isnew && (( ${#BRANCHES[@]} )); then args+=(--base "${BRANCHES[bi]}"); fi
    args+=(--harness "${HARN[hi]}")
    if "$FLEET_BIN" new "${args[@]}" >/dev/null 2>&1; then status="launched: $repo $branch"
    else status="spawn failed: $repo $branch"; fi
    return 0
  }

  while :; do
    _draw
    IFS= read -rsN1 -t 300 k </dev/tty || return
    case "$k" in
      $'\e')
        IFS= read -rsN2 -t 0.01 r </dev/tty || r=''
        # In edit mode: bare Esc commits the text (does NOT cancel the form);
        # arrow keys are swallowed so they don't navigate mid-edit.
        if (( editing )); then [ -z "$r" ] && { editing=0; note=""; }; continue; fi
        case "$r" in
          '[A') _step -1 ;;
          '[B') _step 1 ;;
          '[C') _cyc 1 ;;
          '[D') _cyc -1 ;;
          '') return ;;
        esac ;;
      $'\t') if (( ! editing )); then local _n=0; while (( _n++ < nitems )); do ai=$(( (ai+1) % nitems )); _active "$ai" && break; done; fi ;;
      $'\n'|$'\r')
        if (( editing )); then editing=0; note=""; continue; fi  # Enter commits text
        case "$ai" in
          0) s=$(list_pick "Select repo" "$ri" "${REPOS[@]}"); clear
             [ -n "$s" ] && { ri="$s"; repo="${REPOS[ri]}"; _load_repo; } ;;
          1) if _isnew; then editing=1; note="type branch name . Enter/Esc commits"
             else s=$(list_pick "Launch on worktree" "$wi" "${WT[@]}"); clear
               [ -n "$s" ] && wi="$s"; fi ;;
          2) if _isnew && (( ${#BRANCHES[@]} )); then s=$(list_pick "Branch off of" "$bi" "${BRANCHES[@]}"); clear
               [ -n "$s" ] && bi="$s"; fi ;;
          3) editing=1; note="type prompt . Enter/Esc commits" ;;  # enter prompt edit mode
          6) s=$(list_pick "Harness" "$hi" "${HARN[@]}"); clear
             [ -n "$s" ] && hi="$s" ;;
          7) _spawn; [ "$status" ] && return ;;
          *) _step 1 ;;
        esac ;;
      $'\177'|$'\b')
        if (( editing )); then
          if (( ai == 1 )); then newbranch="${newbranch%?}"; else prompt="${prompt%?}"; fi
        fi ;;
      ' ')
        if (( editing )); then
          if (( ai == 1 )); then newbranch+=" "; else prompt+=" "; fi
        elif (( ai == 4 )); then _toggle_scratch
        elif (( ai == 5 )); then [ "$bare" = no ] && bare=yes || bare=no
        fi ;;
      *)
        case "$k" in
          [[:print:]])
            if (( editing )); then
              if (( ai == 1 )); then newbranch+="$k"; else prompt+="$k"; fi
            elif [ "$k" = k ]; then _step -1
            elif [ "$k" = j ]; then _step 1
            fi ;;
        esac ;;
    esac
  done
}

# --- teardown -----------------------------------------------------------------
agent_wt() { # dir -> 1 if it's a linked git worktree (safe to `worktree remove`)
  local gd; gd=$(git -C "$1" rev-parse --git-dir 2>/dev/null) || { echo 0; return; }
  case "$gd" in *"/worktrees/"*) echo 1 ;; *) echo 0 ;; esac
}

# confirm_teardown <label> <win> <pane> <dir> -> centred confirm popup; closes
# the agent window and optionally removes its worktree. Sets global `status`.
confirm_teardown() {
  local label="$1" win="$2" pane="$3" dir="$4"
  local iswt=0; [ -n "$dir" ] && iswt=$(agent_wt "$dir")
  local opts=() acts=()
  opts+=("Close window (keep files)");                acts+=("close")
  if (( iswt == 1 )); then
    opts+=("Close + remove worktree");                acts+=("remove")
    opts+=("Close + FORCE remove (discard changes)"); acts+=("force")
  fi
  opts+=("Cancel");                                   acts+=("cancel")
  local n=${#opts[@]} mi=0 k r R C bw=54
  read -r R C < <(tsize)
  local bx=$(( (C - bw) / 2 )) by=$(( (R - (n + 4)) / 2 ))
  (( bx < 0 )) && bx=0; (( by < 1 )) && by=1
  while :; do
    mtop "$by" "$bx" "$bw" "Close agent"
    mrow $(( by+1 )) "$bx" "$bw" "  $label"
    mrow $(( by+2 )) "$bx" "$bw" ""
    local i
    for (( i=0; i<n; i++ )); do
      if (( i == mi )); then mrow $(( by+3+i )) "$bx" "$bw" "${opts[i]}" 1
      else mrow $(( by+3+i )) "$bx" "$bw" "${opts[i]}"; fi
    done
    mbot $(( by+3+n )) "$bx" "$bw"
    IFS= read -rsN1 -t 120 k </dev/tty || return
    case "$k" in
      $'\e') IFS= read -rsN2 -t 0.01 r </dev/tty
        case "$r" in '[A') (( mi>0 ))&&((mi--));; '[B') (( mi<n-1 ))&&((mi++));; '') return;; esac ;;
      k) (( mi>0 ))&&((mi--)) ;;
      j) (( mi<n-1 ))&&((mi++)) ;;
      $'\n'|$'\r')
        [ -n "$win" ] || return
        case "${acts[mi]}" in
          cancel) return ;;
          close) tmux kill-window -t "$win" 2>/dev/null
                 "$FLEET_BIN" forget "$dir" 2>/dev/null
                 status="closed $label"; return ;;
          remove|force)
            local force="" main
            [ "${acts[mi]}" = force ] && force="--force"
            # main working tree (or bare container) to run `worktree remove` from
            main=$(git -C "$dir" worktree list --porcelain 2>/dev/null | awk '/^worktree /{print $2; exit}')
            tmux kill-window -t "$win" 2>/dev/null
            "$FLEET_BIN" forget "$dir" 2>/dev/null
            if git -C "${main:-$dir}" worktree remove $force "$dir" 2>/dev/null; then
              status="removed worktree: $label"
            else
              status="closed; worktree kept (uncommitted? use FORCE): $label"
            fi
            return ;;
        esac ;;
      q) return ;;
    esac
  done
}

# view_diff <dir> <label> -> show the agent's `git diff HEAD` in a popup pager
# (delta if available, else less). Blocks until the user quits the pager.
view_diff() {
  local dir="$1" label="$2" pager="less -R" q
  command -v delta >/dev/null 2>&1 && pager="delta"
  q=$(printf '%q' "$dir")
  local cmd="d=\$(git -C $q -c color.ui=always diff HEAD 2>/dev/null); if [ -n \"\$d\" ]; then printf '%s\\n' \"\$d\" | $pager; else printf 'working tree clean vs HEAD\\n'; sleep 1.2; fi"
  tmux display-popup -E -b rounded -w 90% -h 90% -T " diff · $label " "$cmd" 2>/dev/null
}

# --- main loop ---------------------------------------------------------------
clear
while :; do
  load_rows
  render

  key=''
  IFS= read -rsN1 -t "$REFRESH" key || { status=""; continue; }   # timeout -> refresh
  case "$key" in
    $'\e')  # arrow keys: ESC [ A/B
      IFS= read -rsN2 -t 0.01 rest || rest=''
      case "$rest" in
        '[A') (( sel > 0 )) && ((sel--)) ;;
        '[B') (( sel < N-1 )) && ((sel++)) ;;
      esac ;;
    k) (( sel > 0 )) && ((sel--)) ;;
    j) (( sel < N-1 )) && ((sel++)) ;;
    g) sel=0 ;;
    G) (( N > 0 )) && sel=$((N - 1)) ;;
    r) status="" ;;
    R) cleanup; exec "$SELF" "$SESS" ;;   # reload the dashboard with fresh code
    $'\n'|$'\r')   # jump to selected agent's window
      (( N == 0 )) && continue
      tmux select-window -t "$(field "$sel" 3)" 2>/dev/null ;;
    m)             # permission-mode pick-list for the selected agent (sets status)
      (( N == 0 )) && continue
      label=$(field "$sel" 2); pane=$(field "$sel" 6)
      case "$(field "$sel" 1)" in
        starting|stale) status="$label still starting — no hook yet" ;;
        *) if harness_has_modes "$(harness_of "$pane")"; then pick_mode "$pane" "$label"; clear
           else status="$(harness_of "$pane") has no permission modes"; fi ;;
      esac ;;
    s)             # send a message to selected agent
      (( N == 0 )) && continue
      label=$(field "$sel" 2)
      msg=$(ask "send to $label> "); clear   # repaint: read -e may have scrolled
      [ -n "$msg" ] && { "$FLEET_BIN" send "$label" "$msg" >/dev/null 2>&1 \
        && status="sent → $label" || status="send failed → $label"; } ;;
    n)             # spawn a new agent via the in-box form (sets status)
      new_agent_form; clear ;;
    d)             # close/teardown the selected agent (confirm popup)
      (( N == 0 )) && continue
      label=$(field "$sel" 2); win=$(field "$sel" 3); pane=$(field "$sel" 6)
      dir=$(tmux display -p -t "$pane" '#{pane_current_path}' 2>/dev/null)
      confirm_teardown "$label" "$win" "$pane" "$dir"; clear ;;
    v)             # view the selected agent's git diff in a popup pager
      (( N == 0 )) && continue
      label=$(field "$sel" 2); pane=$(field "$sel" 6)
      dir=$(tmux display -p -t "$pane" '#{pane_current_path}' 2>/dev/null)
      view_diff "$dir" "$label"; clear ;;
    *) : ;;        # ignore everything else (no q — this is the persistent pane)
  esac
done
