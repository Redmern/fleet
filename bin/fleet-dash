#!/usr/bin/env bash
# fleet-dash <session> — interactive agent dashboard for the command center.
# One row per agent (state · repo/branch · time-in-state · mode · last activity),
# sorted by urgency. Self-refreshes ~2s. Keyboard control: select / jump / cycle
# permission mode / send / new.
#
# Runs as the right-hand pane of the "main" window, inside the project session,
# so the fleet sub-commands it shells out to resolve session/root from $TMUX.

set -u
SESS="${1:-}"
[ -n "$SESS" ] || { echo "usage: fleet-dash <session>"; exit 1; }

SELF="$(readlink -f "${BASH_SOURCE[0]}")"   # this script, for in-place self-reload
FLEET_BIN="$(dirname "$SELF")/fleet"
CLIP_PCT="${FLEET_TILE_CLIP:-32}"        # right-column % kept for nvim panes
REFRESH="${FLEET_DASH_REFRESH:-1}"        # idle refresh interval, seconds
MODES=(default accept-edits plan auto)   # Shift+Tab cycle order (verified); bypass is not reachable via Shift+Tab
SELF_PANE="${TMUX_PANE:-}"                 # this dashboard's own tmux pane id
declare -A GIT_RAW GIT_TS                  # per-pane git status cache (4s TTL)
declare -A COST_RAW COST_TS                 # per-pane token/cost cache (10s TTL)
declare -A HNS_RAW                          # per-pane harness name cache
STALL_SEC="${FLEET_STALL:-600}"             # working longer than this = stalled

# config-sync / repo glance row: one pill per repo of the dashboard's CURRENT
# project (resolved from the session's @fleet_root), showing git state. For
# pc-tune the row is "live"-aware: each config repo carries a symlink-integrity
# check against its deployed path (the symlink→main deploy pattern is
# pc-tune-specific). Other projects are plain repos with no live-deploy map, so
# they show plain git-status pills (no `!` check) under a "repos" label.
# (docs/config-sync-architecture.md §3.1). Read-only; recomputed at most every 30s.
PC_TUNE_ROOT="${PC_TUNE_ROOT:-$HOME/proj/pc-tune}"   # built-in live-map anchor
CFG_PILL_MAX=8                              # cap pills/row (bound pathological roots)
CFG_RAW=""; CFG_NP=0; CFG_TS=""             # cached pill string / count / timestamp
CFG_LABEL="live"                            # row label ("live" for pc-tune, else "repos")

sel=0                                     # selected row index (agents view)
status=""                                 # transient status line
MODE=agents                               # view: 'agents' (default) or 'inbox' (the per-agent 'e' msg view)
isel=0                                    # selected row index (inbox view)
IN=0                                      # inbox row count (filtered to the scoped agent)
IROWS=()                                  # inbox rows: one .msg path each, newest-first
IUNREAD=0                                 # unread count for the msg-view title (== IN, archive-as-truth)
IFILTER=""                               # 'e' view scope: only msgs whose agent-key == IFILTER
IORPHAN=0                                # 'e' view: 1 = orphan bucket (msgs from no live window)
ISYSTEM=0                                # 'e' view: 1 = system bucket (orchestrator/gate notes)
IALL=0                                   # triage scope: 1 = cross-agent (every *.msg, no filter), multi-select
ISORT=asc                                # triage sort: asc (oldest↑, default) | desc (newest↓); 'o' toggles
ITOK=""                                  # .dirty token seen at the last triage load (stale-list "changed—r" hint)
declare -A MARKED                        # triage marked-set, keyed by *.msg PATH (stable across re-sorts)

# Per-agent unread INDEX (rebuilt lazily — see load_inbox_index / THE GATE).
declare -A UNREAD                          # UNREAD[agent-key] = live (unread) msg count
declare -A MAXSEV                          # MAXSEV[agent-key] = highest severity among its unread
declare -A LIVEWIN                         # LIVEWIN[window-name] = 1 for each live agent row
declare -A LIVEPANE                        # LIVEPANE[pane-id-no-%] = 1 for each live pane
IBX_TS=0                                   # SECONDS of the last index build (0 = never)
IBX_DIRTY=""                               # .dirty mtime seen at the last build
IBX_TOTAL=0                                # total unread across all live agents (title summary)
IBX_WARN=0                                 # of those, count at sev warn|blocked (the ⚠ summary)
ORPHAN_N=0                                 # unread msgs from a REAPED/GONE worker (no live window)
ORPHAN_MAXSEV=""                           # highest severity among orphan msgs
ORPHAN_ROW=0                               # 1 = render the synthetic '⌫ orphans' row (ORPHAN_N>0)
SYSTEM_N=0                                 # unread orchestrator/system msgs (main/-) — NOT reaped workers
SYSTEM_MAXSEV=""                           # highest severity among system msgs
SYSTEM_ROW=0                               # 1 = render the synthetic '⚙ system' row (SYSTEM_N>0)

# --- terminal setup ----------------------------------------------------------
# The loop runs load_rows+render between key reads; in cooked mode the tty echoes
# keys pressed in that window (the stray j/k) and line-buffers them. `read -s`
# only suppresses echo *during* the read syscall. So hold -echo -icanon for the
# whole lifetime: nav keys are consumed raw, never echoed. read -rsN1/-N2 read
# raw byte counts regardless of canon mode, so they keep working. The one
# unrecoverable path is SIGKILL with a surviving pane (untrappable) — rare and
# the pane's pty is usually destroyed with the process anyway.
STTY_SAVED=""
raw_mode()    { stty -echo -icanon min 1 time 0 2>/dev/null; }
cooked_mode() { [ -n "$STTY_SAVED" ] && stty "$STTY_SAVED" 2>/dev/null; }
cleanup() { cooked_mode; printf '\033[?1004l' 2>/dev/null; tput rmcup 2>/dev/null; tput cnorm 2>/dev/null; }
# Test/lib seam: `DASH_LIB=1 source fleet-dash <sess>` loads every function (so shell
# tests can drive load_inbox_index/classification) WITHOUT grabbing the tty, the
# alternate screen, or entering the event loop. The gate keeps all that off tests.
if [ -z "${DASH_LIB:-}" ]; then
  [ -t 0 ] && STTY_SAVED=$(stty -g 2>/dev/null)
  trap cleanup EXIT INT TERM
  tput smcup 2>/dev/null                    # alternate screen
  tput civis 2>/dev/null                    # hide cursor
  raw_mode                                  # no echo, char-at-a-time (see above)
fi
# Focus reporting: ask the terminal to send \033[I / \033[O on focus change, and
# have tmux forward them. They wake the read loop so the focus marker updates
# instantly instead of on the next ~2s refresh.
[ -z "${DASH_LIB:-}" ] && { tmux set -g focus-events on 2>/dev/null; printf '\033[?1004h'; }

# --- helpers -----------------------------------------------------------------
glyph_color() { # state -> SGR color
  case "$1" in
    blocked) printf '\033[31m' ;;        # red
    working) printf '\033[34m' ;;        # blue
    idle)    printf '\033[32m' ;;        # green
    *)       printf '\033[90m' ;;        # grey
  esac
}

fit_left() { # fit to exactly w *display chars* (char-aware, avoids printf's byte
  local s="$1" w="$2" pad   # precision); left-ellipsis keeps the branch tail visible
  (( w <= 0 )) && return
  (( ${#s} > w )) && s="…${s: -$((w - 1))}"
  pad=$(( w - ${#s} )); (( pad < 0 )) && pad=0
  printf '%s%*s' "$s" "$pad" ''
}

mode_label() { # pane_id -> the agent's REAL permission mode, read from claude's
  local m   # footer "<glyph> <mode> on (shift+tab to cycle)". The glyph varies
            # per mode (⏵⏵ auto/accept, ⏸ plan, …), so match on the suffix and
            # take the mode words before it — never key off the glyph.
  m=$(tmux capture-pane -p -t "$1" 2>/dev/null \
      | grep -oE '[A-Za-z][A-Za-z ]*on \(shift\+tab to cycle\)' | tail -1 \
      | sed -E 's/ *on \(shift.*//; s/ +$//')
  # default (normal) mode prints no such line. Normalise to short labels.
  case "$m" in
    *bypass*|*Bypass*) printf 'bypass' ;;
    *plan*|*Plan*)     printf 'plan' ;;
    *accept*|*edit*)   printf 'accept-edits' ;;
    *auto*)            printf 'auto' ;;
    "")                printf 'default' ;;
    *)                 printf '%s' "$m" ;;
  esac
}

mode_color() { # mode text -> SGR (non-default modes stand out)
  case "$1" in
    *bypass*)       printf '\033[31m' ;;   # red — dangerous
    *plan*)         printf '\033[33m' ;;   # yellow
    *edit*|*auto*)  printf '\033[36m' ;;   # cyan
    *)              printf '\033[2m'  ;;   # dim — default
  esac
}

git_status() { # worktree dir -> "DIRTY AHEAD BEHIND"; empty if not a git tree
  git -C "$1" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return
  local d a b ab
  d=$(git -C "$1" status --porcelain 2>/dev/null | grep -c .)
  ab=$(git -C "$1" rev-list --left-right --count '@{upstream}...HEAD' 2>/dev/null)
  b=${ab%%[	 ]*}; a=${ab##*[	 ]}        # rev-list prints "behind<TAB>ahead"
  printf '%s %s %s' "${d:-0}" "${a:-0}" "${b:-0}"
}

git_cached() { # pane -> "DIRTY AHEAD BEHIND", recomputed at most every 4s
  local pane="$1" dir
  if [ -z "${GIT_TS[$pane]:-}" ] || (( SECONDS - GIT_TS[$pane] > 4 )); then
    dir=$(tmux display -p -t "$pane" '#{pane_current_path}' 2>/dev/null)
    GIT_RAW[$pane]=$(git_status "$dir"); GIT_TS[$pane]=$SECONDS
  fi
  printf '%s' "${GIT_RAW[$pane]}"
}

cost_cached() { # pane -> "$X.YZ Nk" token/cost, recomputed at most every 10s
  local pane="$1"
  if [ -z "${COST_TS[$pane]:-}" ] || (( SECONDS - COST_TS[$pane] > 10 )); then
    COST_RAW[$pane]=$("$FLEET_BIN" cost-pane "$pane" 2>/dev/null)
    COST_TS[$pane]=$SECONDS
  fi
  printf '%s' "${COST_RAW[$pane]:--}"
}

harness_of() { # pane -> harness name (@fleet_harness), default claude; cached
  local pane="$1"
  if [ -z "${HNS_RAW[$pane]:-}" ]; then
    HNS_RAW[$pane]=$(tmux display -p -t "$pane" '#{@fleet_harness}' 2>/dev/null)
    [ -n "${HNS_RAW[$pane]}" ] || HNS_RAW[$pane]=claude
  fi
  printf '%s' "${HNS_RAW[$pane]}"
}

harness_has_modes() { # harness -> 0 if it supports a permission-mode cycle
  case "$1" in claude) return 0 ;; *) return 1 ;; esac
}

# --- orchestrator cards: ownership + classification --------------------------
# Workers spawned by a sub-orchestrator carry a non-forgeable @fleet_owner window
# option (=so-<id>), stamped at spawn by cmd_new. The dashboard groups each card's
# rows under their sub-orch header. owner_of is cached PROCESS-LIFETIME (owner is
# immutable per window) — NOT cleared per load_rows.
ROWS=()                                     # live agent rows (8-field, see load_rows)
declare -a ROW_GID ROW_ROLE ROW_ANNOT       # per-row card group / role(0 hdr,1 wkr) / annotation, display order
declare -A OWN_RAW                          # window_id -> @fleet_owner (lifetime cache)
declare -A CARD_NWORK CARD_WARN CARD_STATE  # per-card live-worker count / warn count / ledger state
HAS_CARDS=0                                 # 1 when >=1 live sub-orch header exists (else byte-identical flat list)

owner_of() { # window_id -> owning sub-orch window name (so-<id>), or "" (prints to stdout)
  # OWN_RAW is the process-lifetime cache; the EFFECTIVE memoisation happens in
  # group_rows (which calls this via $() so a write here would be lost in the
  # subshell). Direct callers still get a correct value; group_rows guarantees the
  # tmux query runs at most once per window_id for the whole process.
  local wid="$1"
  if [ -z "${OWN_RAW[$wid]+x}" ]; then
    OWN_RAW[$wid]=$(tmux show -wqv -t "$wid" @fleet_owner 2>/dev/null)
  fi
  printf '%s' "${OWN_RAW[$wid]}"
}
is_suborch_name() { [[ "$1" =~ ^so-[A-Za-z0-9]+$ ]]; }   # the so-<id> window-name shape
suborch_ledger()  { local id="${1#so-}"; [ -d "$(dash_root)/.fleet/dispatch/$id" ]; }  # genuine sub-orch (vs a worker named so-*)
urgrank()         { case "$1" in blocked) echo 0 ;; idle) echo 1 ;; working) echo 2 ;; *) echo 3 ;; esac; }  # lower floats up
card_meta_state() { # <so-id> -> ledger 'state' value (running/planning/…), or ""
  local id="${1#so-}" f; f="$(dash_root)/.fleet/dispatch/$id/meta.tsv"
  [ -f "$f" ] && awk -F'\t' '$1=="state"{v=$2} END{print v}' "$f" 2>/dev/null
}
unowned_rule() { # <inner-width> -> a '╶ unowned ╴' plain rule of exactly <inner> display chars
  local w="$1" lab=" unowned " n fill
  n=$(( w - ${#lab} - 2 )); (( n < 0 )) && n=0
  fill=""; (( n > 0 )) && fill=$(printf '%.0s─' $(seq 1 "$n"))
  printf '╶%s╴%s' "$lab" "$fill"
}

gitfmt() { # "D A B" -> nerd-font glyphs (≤PILL_W cols): ●dirty ↑ahead ↓behind, ✓ clean, - none
  [ -n "$1" ] || { printf -- '-'; return; }
  local d a b; read -r d a b <<<"$1"
  # priority order: behind ↓ (red) > dirty ● (yellow) > ahead ↑ (cyan); ahead drops first if clipped
  local segs=()
  (( ${b:-0} > 0 )) && segs+=("↓$b")
  (( ${d:-0} > 0 )) && segs+=("●$d")
  (( ${a:-0} > 0 )) && segs+=("↑$a")
  (( ${#segs[@]} == 0 )) && { printf '✓'; return; }
  local s
  while :; do
    s=$(IFS=' '; printf '%s' "${segs[*]}")
    (( ${#s} <= PILL_W || ${#segs[@]} <= 1 )) && break
    unset 'segs[${#segs[@]}-1]'; segs=("${segs[@]}")
  done
  printf '%s' "$s"   # loop already bounds to PILL_W *chars*; %.Ns would byte-clip glyphs
}

gitcolor() { # "D A B" -> SGR (behind=red, dirty=yellow, ahead=cyan, clean=green)
  [ -n "$1" ] || { printf '\033[90m'; return; }
  local d a b; read -r d a b <<<"$1"
  if   (( ${b:-0} > 0 )); then printf '\033[31m'
  elif (( ${d:-0} > 0 )); then printf '\033[33m'
  elif (( ${a:-0} > 0 )); then printf '\033[36m'
  else printf '\033[32m'; fi
}

# --- pills (rounded nerd-font capsules, like the omarchy status bar) -----------
PILL_L=$''   # left semicircle (Nerd Font / powerline-extra)
PILL_R=$''   # right semicircle
PILL_W=7      # fixed inner text width — every pill is the same size
PILL_GAP=3    # spaces between row items (state · label · git · mode)
ROW_GAP=1     # blank rows between agents

pill_center() { # text -> centred/truncated to exactly PILL_W chars
  local t="$1" len=${#1} pad l
  (( len >= PILL_W )) && { printf '%s' "${t:0:PILL_W}"; return; }  # char-based (glyph-safe), not %.Ns bytes
  pad=$(( PILL_W - len )); l=$(( pad / 2 ))
  printf '%*s%s%*s' "$l" '' "$t" "$(( pad - l ))" ''
}

pill() { # text color256 -> fixed-width rounded pill (display width = PILL_W + 4)
  local t c="$2" tf=0
  [ "$c" = 8 ] && tf=15                       # white text on the grey pill
  t=$(pill_center "$1")
  printf '\033[38;5;%s;49m%s\033[48;5;%s;38;5;%sm %s \033[49;38;5;%sm%s\033[0m' \
    "$c" "$PILL_L" "$c" "$tf" "$t" "$c" "$PILL_R"
}
mode_short() { case "$1" in accept-edits) echo accept ;; *) echo "$1" ;; esac; }
state_pcol() { case "$1" in blocked) echo 1;; working) echo 4;; idle) echo 2;; *) echo 8;; esac; }
mode_pcol()  { case "$1" in *bypass*) echo 1;; *plan*) echo 3;; *accept*|*edit*|*auto*) echo 6;; *) echo 8;; esac; }
git_pcol()   { # "D A B" -> pill colour
  [ -n "$1" ] || { echo 8; return; }
  local d a b; read -r d a b <<<"$1"
  if   (( ${b:-0} > 0 )); then echo 1
  elif (( ${d:-0} > 0 )); then echo 3
  elif (( ${a:-0} > 0 )); then echo 6
  else echo 2; fi
}

# --- config-sync / repo glance row -------------------------------------------
# One pill per repo of the dashboard's current project, sorted as the live map
# (pc-tune) declares or alphabetically (generic). Each pill: short name + git
# state marker (clean / *dirty / +ahead / vbehind), coloured like the git pill.
# For pc-tune repos a live-deploy symlink check adds a red `!` when the deployed
# path no longer resolves inside the repo's primary worktree. Generic projects
# have no live map, so they show plain git pills (no `!`) under a "repos" label.
# Sets CFG_RAW (pill string), CFG_NP (pill count), CFG_LABEL (row label).

dash_root() { # the dashboard's project root: @fleet_root → FLEET_ROOT → pwd
  local r; r=$(tmux show -t "$SESS" -v @fleet_root 2>/dev/null)
  [ -n "$r" ] && { printf '%s' "$r"; return 0; }
  [ -n "${FLEET_ROOT:-}" ] && { printf '%s' "$FLEET_ROOT"; return 0; }
  pwd
}

primary_worktree() { # container → primary worktree path; empty if no checkout
  # main/ worktree (pc-tune shape) > plain repo > origin/HEAD default-branch
  # worktree > first worktree. Only the generic branches touch git (pc-tune
  # always hits the cheap main/ case, so its row stays git-call-free here).
  local cont="$1" w anchor def path br
  if [ -d "$cont/main" ] && [ -e "$cont/main/.git" ]; then printf '%s' "$cont/main"; return 0; fi
  # plain working repo: a non-bare checkout directly at the container (a bare
  # worktree-container has a .git too, but no work tree — fall through to glob).
  if [ -e "$cont/.git" ] && [ "$(git -C "$cont" rev-parse --is-inside-work-tree 2>/dev/null)" = true ]; then
    printf '%s' "$cont"; return 0          # a bare container prints "false" here → skip
  fi
  anchor=""
  for w in "$cont"/*/; do w="${w%/}"; [ -e "$w/.git" ] || continue; anchor="$w"; break; done
  [ -n "$anchor" ] || return 1
  def=$(git -C "$anchor" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||')
  if [ -n "$def" ]; then
    while IFS=$'\t' read -r path br; do
      [ "$br" = "$def" ] && { printf '%s' "$path"; return 0; }
    done < <(git -C "$anchor" worktree list --porcelain 2>/dev/null \
               | awk '/^worktree /{p=$2} /^branch /{sub("refs/heads/","",$2); print p"\t"$2}')
  fi
  printf '%s' "$anchor"
}

cfg_short() { # repo name → pill label: tmuxinator→tmxn, long hyphenated→last segment
  local n="$1"
  case "$n" in tmuxinator) printf 'tmxn'; return ;; esac
  (( ${#n} > PILL_W )) && case "$n" in *-*) n="${n##*-}" ;; esac
  printf '%s' "$n"
}

config_live() {
  CFG_RAW=""; CFG_NP=0; CFG_LABEL="repos"
  local root; root=$(dash_root); [ -n "$root" ] || return 0
  # Live map: built-in pc-tune set, applied only when the resolved root IS the
  # pc-tune root. Keyed by canonical path so $PWD/symlink variants still match;
  # both sides must be non-empty to avoid an empty==empty false positive.
  local -a specs=(); local -A livemap=()
  local s n p rc pc
  rc=$(readlink -f "$root" 2>/dev/null)
  pc=$(readlink -f "$PC_TUNE_ROOT" 2>/dev/null)
  if [ -n "$rc" ] && [ -n "$pc" ] && [ "$rc" = "$pc" ]; then
    specs=(
      "nvim|$HOME/.config/nvim"
      "tmux|$HOME/.tmux.conf"
      "tmuxinator|$HOME/.config/tmuxinator"
      "fleet|$HOME/.local/bin/fleet"
    )
    CFG_LABEL="live"
    for s in "${specs[@]}"; do IFS='|' read -r n p <<<"$s"; livemap[$n]="$p"; done
  fi
  # Repo list: live-map order when present (pc-tune → byte-for-byte today),
  # else all repos discovered under the root (alphabetical, generic projects).
  local -a names=()
  if (( ${#specs[@]} )); then
    for s in "${specs[@]}"; do IFS='|' read -r n p <<<"$s"; names+=("$n"); done
  else
    while IFS= read -r n; do [ -n "$n" ] && names+=("$n"); done \
      < <("$FLEET_BIN" repos 2>/dev/null)
  fi
  (( ${#names[@]} )) || return 0           # scratch / repo-less project → skip row
  local name cont prim g d a b col mark link canon got symok short gap count=0
  gap=$(printf '%*s' "$PILL_GAP" '')
  for name in "${names[@]}"; do
    (( count >= CFG_PILL_MAX )) && break    # bound pathological roots (noted)
    cont="$root/$name"
    prim=$(primary_worktree "$cont"); [ -n "$prim" ] || continue
    g=$(git_status "$prim"); read -r d a b <<<"${g:-0 0 0}"
    link="${livemap[$name]:-}"
    if [ -n "$link" ]; then
      # symlink integrity: deployed path resolves at/under the primary worktree
      canon=$(readlink -f "$prim" 2>/dev/null)
      got=$(readlink -f "$link" 2>/dev/null)
      if [ -z "$got" ] || [ -z "$canon" ]; then symok=0
      elif [ "$got" = "$canon" ] || case "$got" in "$canon"/*) true;; *) false;; esac; then symok=1
      else symok=0; fi
    else symok=1; fi                        # no live mapping → no `!` check
    if (( symok == 0 )); then col=1; mark="!"
    else
      col=$(git_pcol "$g")
      if   (( ${b:-0} > 0 )); then mark="v"
      elif (( ${d:-0} > 0 )); then mark="*"
      elif (( ${a:-0} > 0 )); then mark="+"
      else mark=""; fi
    fi
    short=$(cfg_short "$name")
    # state glyph is secondary: on names that fill PILL_W it truncates away, but
    # the pill colour (git_pcol: red behind / yellow dirty / cyan ahead) still
    # encodes state, so nothing is lost beyond the redundant glyph.
    [ -n "$CFG_RAW" ] && CFG_RAW+="$gap"
    CFG_RAW+=$(pill "$short${mark:+ $mark}" "$col")
    (( CFG_NP++ )); (( count++ ))
  done
}

config_live_cached() { # recompute CFG_RAW/CFG_NP at most every 30s
  if [ -z "$CFG_TS" ] || (( SECONDS - CFG_TS > 30 )); then config_live; CFG_TS=$SECONDS; fi
}

# --- data --------------------------------------------------------------------
# ROWS[] entries: state \t label \t window_id \t window_name \t since \t pane_id \t age
load_rows() {
  # stash the selected agent's window_id BEFORE rebuilding so sel can FOLLOW it
  # across the regroup/reload (else a 1s refresh re-ranks a card and the next
  # 'd'/'m' hits the wrong agent — data loss, not cosmetic).
  local prev_wid=""
  (( ${#ROWS[@]} > 0 )) && (( sel < ${#ROWS[@]} )) && prev_wid=$(field "$sel" 3)

  ROWS=()
  local line state label sess win wname since pane age order
  while IFS=$'\t' read -r state label sess win wname since pane age ready; do
    [ -n "$pane" ] || continue
    [ "$sess" = "$SESS" ] || [ "$sess" = "${SESS}_hidden" ] || continue   # this project + its parked scratch
    [ "$wname" = "main" ] && continue     # skip the orchestrator itself
    ROWS+=("$state"$'\t'"$label"$'\t'"$win"$'\t'"$wname"$'\t'"$since"$'\t'"$pane"$'\t'"${age:-0}"$'\t'"$ready")
  done < <("$FLEET_BIN" agents 2>/dev/null | sort -t$'\t' -k1,1 \
            | awk -F'\t' '
                $1=="blocked"{o=0} $1=="idle"{o=1} $1=="working"{o=2} $1!~/blocked|idle|working/{o=3}
                {print o"\t"$0}' | sort -n | cut -f2-)
  N=${#ROWS[@]}

  group_rows                              # reorder ROWS into per-card display order (fail-silent)

  if [ -n "$prev_wid" ]; then             # restore selection onto the same window_id
    local j
    for (( j=0; j<N; j++ )); do [ "$(field "$j" 3)" = "$prev_wid" ] && { sel=$j; break; }; done
  fi

  # selectable rows = live agents + the synthetic orphans/system rows (if any). The
  # *_ROW globals are kept fresh by the last load_inbox_index, so sel can rest on them.
  local tot=$(( N + ORPHAN_ROW + SYSTEM_ROW ))
  (( tot == 0 )) && sel=0
  (( sel >= tot )) && sel=$(( tot - 1 ))
  (( sel < 0 )) && sel=0
}

# Reorder ROWS[] into contiguous per-card display order and fill the parallel
# ROW_GID/ROW_ROLE/ROW_ANNOT + CARD_* arrays. Cards are ordered by MAX-SEVERITY-
# WITHIN the card (blocked floats up), tie-broken by NUMERIC dispatch id; the
# unowned bucket sorts last. Within a card: header first, then workers by urgency
# rank then name. Fail-silent: with no live sub-orch header it is a pure identity
# (byte-identical flat list, HAS_CARDS=0); it never half-rewrites ROWS[].
group_rows() {
  ROW_GID=(); ROW_ROLE=(); ROW_ANNOT=(); CARD_NWORK=(); CARD_WARN=(); CARD_STATE=(); HAS_CARDS=0
  (( N == 0 )) && return 0

  local i st wn wid r own gid role annot num have_hdr=0
  local -A IS_HEADER GMINRANK GNUM

  for (( i=0; i<N; i++ )); do             # pass 1: genuine live sub-orch headers
    wn=$(field "$i" 4)
    if is_suborch_name "$wn" && suborch_ledger "$wn"; then IS_HEADER[$wn]=1; have_hdr=1; fi
  done
  if (( have_hdr == 0 )); then            # no cards -> flat identity (zero-regression)
    for (( i=0; i<N; i++ )); do ROW_GID[i]=""; ROW_ROLE[i]=1; ROW_ANNOT[i]=""; done
    return 0
  fi
  HAS_CARDS=1

  local -a g_gid g_role g_rank g_annot
  for (( i=0; i<N; i++ )); do             # pass 2: classify + accumulate per-card min rank / numeric id
    st=$(field "$i" 1); wn=$(field "$i" 4); wid=$(field "$i" 3); r=$(urgrank "$st"); annot=""
    if [ -n "${IS_HEADER[$wn]:-}" ]; then
      gid="$wn"; role=0
    else
      # memoise into the parent's OWN_RAW (owner_of's own write is in a $() subshell;
      # caching HERE makes it process-lifetime — no re-query per refresh). owner is
      # immutable per window, so a cache hit is always correct.
      [ -n "${OWN_RAW[$wid]+x}" ] || OWN_RAW[$wid]=$(owner_of "$wid")
      own="${OWN_RAW[$wid]}"
      if [ -n "$own" ] && [ -n "${IS_HEADER[$own]:-}" ]; then
        gid="$own"; role=1
      elif [ -n "$own" ]; then           # orphan-owner: owner not a live header -> unowned, annotated
        gid=""; role=1
        if suborch_ledger "$own"; then annot="(owner $own out of scope)"; else annot="(owner $own gone)"; fi
      else
        gid=""; role=1
      fi
    fi
    g_gid[i]="$gid"; g_role[i]=$role; g_rank[i]=$r; g_annot[i]="$annot"
    if [ -n "$gid" ]; then
      if [ -z "${GMINRANK[$gid]:-}" ] || (( r < GMINRANK[$gid] )); then GMINRANK[$gid]=$r; fi
      num="${gid#so-}"; num="${num//[^0-9]/}"; GNUM[$gid]=$(( 10#${num:-0} ))
    fi
  done

  local -A GIDX; local gi=0 g                # order cards: (min-rank ASC, numeric id ASC); unowned last
  while IFS= read -r g; do [ -n "$g" ] && { GIDX[$g]=$gi; gi=$(( gi + 1 )); }; done < <(
    for g in "${!GMINRANK[@]}"; do printf '%d\t%d\t%s\n' "${GMINRANK[$g]}" "${GNUM[$g]:-0}" "$g"; done \
      | sort -t$'\t' -k1,1n -k2,2n | cut -f3)
  local unowned_idx=$gi

  local -a OLDROWS=("${ROWS[@]}") SEQ      # decorate -> stable sort -> display-order original indices
  mapfile -t SEQ < <(
    for (( i=0; i<N; i++ )); do
      gid="${g_gid[i]}"; local gidx wkey
      if [ -n "$gid" ]; then gidx=${GIDX[$gid]}; else gidx=$unowned_idx; fi
      if [ -n "$gid" ] && (( g_role[i] == 0 )); then wkey="0"                       # header first
      elif [ -n "$gid" ]; then wkey=$(printf '1:%02d:%s' "${g_rank[i]}" "$(field "$i" 4)")   # worker: rank, name
      else wkey=$(printf '%09d' "$i"); fi                                            # unowned: keep flat order
      printf '%d\t%d\t%s\t%d\n' "$gidx" "${g_role[i]}" "$wkey" "$i"
    done | sort -t$'\t' -k1,1n -k2,2n -k3,3 -k4,4n | cut -f4)

  ROWS=(); local oi
  for oi in "${SEQ[@]}"; do
    ROWS+=("${OLDROWS[$oi]}"); ROW_GID+=("${g_gid[$oi]}"); ROW_ROLE+=("${g_role[$oi]}"); ROW_ANNOT+=("${g_annot[$oi]}")
  done

  local k g2 st2 ag2                       # per-card aggregates for the divider label
  for (( k=0; k<N; k++ )); do
    g2="${ROW_GID[k]}"; { [ -n "$g2" ] && (( ROW_ROLE[k] == 1 )); } || continue
    CARD_NWORK[$g2]=$(( ${CARD_NWORK[$g2]:-0} + 1 ))
    st2=$(field "$k" 1); ag2=$(field "$k" 7)
    if [ "$st2" = blocked ] || { [ "$st2" = working ] && (( ${ag2:-0} > STALL_SEC )); }; then
      CARD_WARN[$g2]=$(( ${CARD_WARN[$g2]:-0} + 1 ))
    fi
  done
  for g2 in "${!IS_HEADER[@]}"; do CARD_STATE[$g2]=$(card_meta_state "$g2"); done
  return 0
}

field() { printf '%s' "${ROWS[$1]}" | cut -f"$2"; }  # field <rowidx> <col>

# --- inbox data --------------------------------------------------------------
# Live orchestrator inbox: <root>/.fleet/inbox/*.msg, newest-first (sort -r on the
# filename = id). Header accessors mirror `fleet`'s exactly (scan only the
# key=value region above the `--` separator) so a `--` inside the body can never
# be mistaken for the header end.
inbox_root() { printf '%s/.fleet/inbox' "$(dash_root)"; }
ibx_field()  { sed -n "/^--$/q; s/^$2=//p" "$1" 2>/dev/null | head -1; }   # ibx_field <file> <key>
ibx_body()   { sed -n '/^--$/,$p' "$1" 2>/dev/null | sed '1d'; }

# ARCHIVE-AS-TRUTH: no read cursor. unread == live (un-archived) *.msg. POP and
# mark-all-read consume by moving the file into archive/ (a single atomic mv);
# JUMP never archives, so glancing never clears the indicator.

# Bump the GATE token (nanosecond, NOT mtime — see fleet's inbox_mark_dirty) after
# a dash-side mutation (POP / mark-all) so the next index build re-scans at once.
ibx_mark_dirty() { date +%s%N > "$(inbox_root)/.dirty" 2>/dev/null || true; }

sev_color() { case "$1" in blocked) printf '\033[31m' ;; warn) printf '\033[33m' ;; *) printf '\033[2m' ;; esac; }
sev_rank()  { case "$1" in blocked) echo 3 ;; warn) echo 2 ;; info) echo 1 ;; *) echo 0 ;; esac; }
sev_max()   { # <a> <b> -> the higher-severity string
  local a="$1" b="$2"; [ "$(sev_rank "$b")" -gt "$(sev_rank "$a")" ] && printf '%s' "$b" || printf '%s' "$a"; }
sev_pcol()  { case "$1" in blocked) echo 1 ;; warn) echo 3 ;; *) echo 6 ;; esac; }  # ✉ pill colour by max sev

# THE join, localized behind one accessor (Q3/Q7). A message's id is epoch.nanos.pane.
# It attaches to a LIVE agent row iff its 'from' names a live window AND its pane
# suffix is still a live pane. A respawned same-name agent has fresh pane ids, so a
# prior incarnation's msg (dead pane) routes to the orphan bucket, not the new row.
# Relies on LIVEWIN/LIVEPANE populated by load_inbox_index. Echoes the agent key, or
# "" for an orphan.
msg_agent_key() { # <from> <pane-no-%> -> live agent key | ""
  local from="$1" pane="${2#%}"
  if [ -n "$from" ] && [ -n "${LIVEWIN[$from]:-}" ] && [ -n "${LIVEPANE[$pane]:-}" ]; then
    printf '%s' "$from"
  fi
}

# An UNATTACHED message (no live agent key) is one of two things: a SYSTEM/orchestrator
# note (the main window's own gate/conclusion post, or a sender-less "-") which is NOT a
# reaped worker, OR a true ORPHAN whose worker window is gone. This split keeps gate/system
# messages out of the "reaped/gone senders" bucket. Mirrors fleet:inbox_from_is_system.
msg_from_is_system() { case "${1:-}" in ""|-|main) return 0 ;; *) return 1 ;; esac; }

# THE GATE. Rebuild the per-agent unread index ONLY when the inbox changed (the
# .dirty token inbox_put/clear/gc/pop write differs from the one seen at the last
# build) or a 30s safety TTL elapsed (catches external archive moves: reap/gc).
# Called every refresh, but the common path is a single cheap `cat` of a tiny token
# file that returns immediately — the 1s hot loop NEVER sweeps the *.msg files
# unless something actually wrote one. THIS IS THE COST GATE: without it this would
# be a 200-file sed sweep every second.
load_inbox_index() { # [force]
  local dir; dir=$(inbox_root)
  local tok; tok=$(cat "$dir/.dirty" 2>/dev/null || echo 0)   # nanosecond GATE token
  if [ "${1:-}" != force ] && (( IBX_TS != 0 )) && [ "$tok" = "$IBX_DIRTY" ] && (( SECONDS - IBX_TS < 30 )); then
    return                                   # token unchanged, within TTL — skip the sweep
  fi
  IBX_TS=$SECONDS; IBX_DIRTY="$tok"
  UNREAD=(); MAXSEV=(); LIVEWIN=(); LIVEPANE=()
  IBX_TOTAL=0; IBX_WARN=0; ORPHAN_N=0; ORPHAN_MAXSEV=""; SYSTEM_N=0; SYSTEM_MAXSEV=""
  local i wn p
  for (( i=0; i<N; i++ )); do wn=$(field "$i" 4); [ -n "$wn" ] && LIVEWIN["$wn"]=1; done
  while IFS= read -r p; do p="${p#%}"; [ -n "$p" ] && LIVEPANE["$p"]=1; done < <(
    tmux list-panes -s -t "$SESS" -F '#{pane_id}' 2>/dev/null
    tmux list-panes -s -t "${SESS}_hidden" -F '#{pane_id}' 2>/dev/null)
  local f id from pane sev key
  if [ -d "$dir" ]; then
    for f in "$dir"/*.msg; do
      [ -e "$f" ] || continue
      id=$(basename "$f" .msg); pane="${id##*.}"
      from=$(ibx_field "$f" from); sev=$(ibx_field "$f" sev)
      key=$(msg_agent_key "$from" "$pane")
      if [ -n "$key" ]; then
        UNREAD["$key"]=$(( ${UNREAD["$key"]:-0} + 1 ))
        MAXSEV["$key"]=$(sev_max "${MAXSEV[$key]:-}" "$sev")
      elif msg_from_is_system "$from"; then
        SYSTEM_N=$(( SYSTEM_N + 1 )); SYSTEM_MAXSEV=$(sev_max "$SYSTEM_MAXSEV" "$sev")
      else
        ORPHAN_N=$(( ORPHAN_N + 1 )); ORPHAN_MAXSEV=$(sev_max "$ORPHAN_MAXSEV" "$sev")
      fi
      IBX_TOTAL=$(( IBX_TOTAL + 1 ))
      case "$sev" in warn|blocked) IBX_WARN=$(( IBX_WARN + 1 )) ;; esac
    done
  fi
  ORPHAN_ROW=0; (( ORPHAN_N > 0 )) && ORPHAN_ROW=1
  SYSTEM_ROW=0; (( SYSTEM_N > 0 )) && SYSTEM_ROW=1
  # re-clamp selection now that the synthetic rows' existence is known
  local tot=$(( N + ORPHAN_ROW + SYSTEM_ROW ))
  (( tot == 0 )) && sel=0
  (( sel >= tot )) && sel=$(( tot - 1 ))
  (( sel < 0 )) && sel=0
}

fmt_age() { # seconds -> compact 5s/3m/2h/4d
  local s="${1:-0}"; (( s < 0 )) && s=0
  if   (( s < 60 ));    then printf '%ds' "$s"
  elif (( s < 3600 ));  then printf '%dm' "$(( s / 60 ))"
  elif (( s < 86400 )); then printf '%dh' "$(( s / 3600 ))"
  else printf '%dd' "$(( s / 86400 ))"; fi
}

# IROWS[] = the .msg paths for the SCOPED 'e' view, newest-first. The scope is one
# agent (IFILTER) or the orphan bucket (IORPHAN). Archive-as-truth: every listed
# msg is unread, so IUNREAD == IN. Relies on LIVEWIN/LIVEPANE from load_inbox_index.
load_inbox() {
  IROWS=()
  local dir f id from pane key sortf="-r"; dir=$(inbox_root)
  # Triage (IALL) lists EVERYTHING unfiltered, default oldest-first (asc) — the
  # opposite of the per-agent view's newest-first; 'o' flips to desc. ids are
  # <epoch>.<nanos>.<pane> (fixed-width) so a lexical sort is chronological.
  if (( IALL )); then [ "$ISORT" = desc ] && sortf="-r" || sortf=""; fi
  if [ -d "$dir" ]; then
    while IFS= read -r f; do
      [ -e "$f" ] || continue
      if (( IALL )); then IROWS+=("$f"); continue   # triage: everything, no agent/orphan/system filter
      fi
      id=$(basename "$f" .msg); pane="${id##*.}"
      from=$(ibx_field "$f" from); key=$(msg_agent_key "$from" "$pane")
      if (( IORPHAN )); then
        { [ -z "$key" ] && ! msg_from_is_system "$from"; } || continue  # orphans: unattached & NOT system
      elif (( ISYSTEM )); then
        { [ -z "$key" ] &&   msg_from_is_system "$from"; } || continue  # system: unattached & system-origin
      else
        [ "$key" = "$IFILTER" ] || continue   # agent view: keep only this agent's msgs
      fi
      IROWS+=("$f")
    done < <(ls -1 "$dir"/*.msg 2>/dev/null | sort $sortf)
  fi
  IN=${#IROWS[@]}; IUNREAD=$IN
  (( IN == 0 )) && isel=0
  (( isel >= IN )) && isel=$((IN - 1))
  (( isel < 0 )) && isel=0
}

# Mode-aware navigation: act on the active view's index/count so the same j/k/g/G
# (and the arrow keys, and drain_nav's coalescing) drive whichever view is up. In
# agents mode the row count includes the synthetic orphans row (ORPHAN_ROW).
arows()    { echo $(( N + ORPHAN_ROW + SYSTEM_ROW )); }
nav_up()   { if [ "$MODE" = inbox ]; then (( isel > 0 )) && ((isel--)); else (( sel > 0 )) && ((sel--)); fi; }
nav_down() { if [ "$MODE" = inbox ]; then (( isel < IN-1 )) && ((isel++)); else (( sel < $(arows)-1 )) && ((sel++)); fi; }
nav_top()  { if [ "$MODE" = inbox ]; then isel=0; else sel=0; fi; }
nav_bot()  { if [ "$MODE" = inbox ]; then (( IN > 0 )) && isel=$((IN - 1)); else (( $(arows) > 0 )) && sel=$(( $(arows) - 1 )); fi; }

# Enter in the msg view = POP the selected message to the orchestrator. DELEGATES to
# the single never-clobber pop primitive `fleet inbox pop <file>` (advisor §B "one
# pop, two selectors"): the paste (send-keys -l, no C-m), archive-as-truth, mv-verify
# and orchestrator resolution live ONCE in bin/fleet, so the dashboard's per-agent
# Enter and the leader-menu FIFO drain are identical by construction rather than two
# copies that drift. Passing the file path selects this specific message (so the
# busy-gate — FIFO-only — does not apply: this is a deliberate pop on a visible row).
# The primitive surfaces its own outcome via tmux display-message; we always reload.
inbox_pop() {
  (( IN == 0 )) && { status="inbox empty"; return; }
  "$FLEET_BIN" inbox pop "${IROWS[$isel]}" >/dev/null 2>&1
  status="popped → orchestrator"
}

# c/a in the 'e' view = MARK ALL READ: archive every msg in the current scope (this
# agent's, or the orphan bucket). Reuses POP's archive = consume semantics in bulk.
inbox_mark_all() {
  (( IN == 0 )) && { status="nothing to mark"; return; }
  local dir f n=0; dir=$(inbox_root); mkdir -p "$dir/archive" 2>/dev/null
  for f in "${IROWS[@]}"; do [ -e "$f" ] && mv -f "$f" "$dir/archive/" 2>/dev/null && n=$((n+1)); done
  ibx_mark_dirty
  status="marked $n read"
}

# 'e' (or Enter on the orphan row) -> open the scoped message view. Scope = the
# selected agent, or the orphan bucket when the synthetic row is selected.
open_msgs() {
  if (( ORPHAN_ROW && sel == N )); then
    IORPHAN=1; ISYSTEM=0; IFILTER=""
  elif (( SYSTEM_ROW && sel == N + ORPHAN_ROW )); then
    ISYSTEM=1; IORPHAN=0; IFILTER=""
  else
    (( N == 0 )) && return 1
    IORPHAN=0; ISYSTEM=0; IFILTER=$(field "$sel" 4)
  fi
  MODE=inbox; isel=0; load_inbox_index force; load_inbox; status=""
}

# 't' (agents view) or the leader 'triage' -> open the CROSS-AGENT triage: the inbox
# view with the per-agent filter removed (IALL=1), every queued msg listed oldest-first,
# multi-select armed (a fresh MARKED set). Built by EXTENDING the inbox view — no new
# popup, no second key loop (advisor D1 / B-minimal). ITOK records the load-time .dirty
# token so render can flag a list that changed underneath the open view.
open_triage() {
  IALL=1; IORPHAN=0; ISYSTEM=0; IFILTER=""
  ISORT=asc; MARKED=()
  MODE=inbox; isel=0
  load_inbox_index force; load_inbox
  ITOK=$(cat "$(inbox_root)/.dirty" 2>/dev/null || echo 0)
  status=""
}

# Leave triage (or the per-agent inbox view) back to the agents list, clearing the
# triage scope + marks so the next open starts clean.
close_inbox_view() {
  MODE=agents; IALL=0; MARKED=()
  load_rows; load_inbox_index; status=""
}

# The triage header label (scope · direction · counts · stale-flag). Factored out so it
# is render-free and unit-testable. 'oldest↑' / 'newest↓' makes the sort direction (and
# the toggle) legible; 'N marked' is the selection counter; 'changed—r' appears when the
# inbox .dirty token moved since the view loaded (a non-stale "everything" view).
triage_header() {
  local arrow nm=0 k stale="" cur
  [ "$ISORT" = desc ] && arrow="newest↓" || arrow="oldest↑"
  for k in "${!MARKED[@]}"; do [ -n "${MARKED[$k]:-}" ] && nm=$((nm+1)); done
  cur=$(cat "$(inbox_root)/.dirty" 2>/dev/null || echo 0)
  [ -n "$ITOK" ] && [ "$cur" != "$ITOK" ] && stale=" · changed—r"
  printf 'MSGS · triage · %s · %d msgs · %d marked%s' "$arrow" "$IN" "$nm" "$stale"
}

# The marked messages in CURRENT DISPLAY order (advisor D2): iterate IROWS (already
# sorted per ISORT) and emit those marked. Deterministic — NEVER bash associative-array
# order (advisor S3). This is the order Enter pops them, so the human pops the set in the
# order they read it.
triage_marked_order() {
  local f
  for f in "${IROWS[@]}"; do [ -n "${MARKED[$f]:-}" ] && printf '%s\n' "$f"; done
}

# Enter in triage = pop every marked message, in display order, into the orchestrator.
# Each goes through the shared `fleet inbox pop <file>` primitive (no-submit bracketed
# paste that appends + archive-verify + the D4 separator), so a batch concatenates,
# self-separates and never auto-submits. SAFETY: the whole batch is gated ONCE up front
# via the SAME extracted busy helper the FIFO pop uses (`fleet inbox orch-busy`); if the
# orch is mid-generation it pops NOTHING and KEEPS the marks (advisor D3). Nothing marked
# = no-op + hint (D5/Q4). Vanished marked files are skipped + counted (S3). On success
# the view closes and we land in the orch pane to review the assembled batch (D5/Q7).
triage_pop() {
  local order=() f
  while IFS= read -r f; do [ -n "$f" ] && order+=("$f"); done < <(triage_marked_order)
  if (( ${#order[@]} == 0 )); then status="nothing marked — Space to mark, then Enter to pop"; return; fi
  local bstate
  if bstate=$("$FLEET_BIN" inbox orch-busy 2>/dev/null); then
    status="orchestrator ${bstate:-busy} — retry when idle (${#order[@]} marks kept)"; return
  fi
  local popped=0 gone=0
  for f in "${order[@]}"; do
    if [ -e "$f" ]; then
      "$FLEET_BIN" inbox pop "$f" >/dev/null 2>&1 && popped=$((popped+1))
    else
      gone=$((gone+1))
    fi
    unset 'MARKED[$f]'
  done
  close_inbox_view                          # clears status -> set the outcome AFTER
  status="popped $popped → orch"; (( gone )) && status="$status, $gone already gone"
  "$FLEET_BIN" orch-jump >/dev/null 2>&1    # land in the orch pane to review the batch
}

# J in inbox = JUMP to the message's source agent. 'from' is a window name at send
# time; resolve it to a LIVE window in this project (visible session or its parked
# <sess>_hidden) and select it, surfacing a hidden window first (same as the agents
# view's Enter=jump). No live match (agent reaped, or from='-') -> open the stored
# .msg in a popup pager. Jumping never archives or marks read.
inbox_jump() {
  (( IN == 0 )) && { status="inbox empty"; return; }
  local f="${IROWS[$isel]}" from win wsess
  from=$(ibx_field "$f" from)
  if [ -n "$from" ] && [ "$from" != "-" ]; then
    win=$(tmux list-windows -a -F $'#{session_name}\t#{window_name}\t#{window_id}' 2>/dev/null \
      | awk -F'\t' -v n="$from" -v s="$SESS" -v h="${SESS}_hidden" \
          '($1==s||$1==h)&&$2==n{print $3; exit}')
  fi
  if [ -n "$win" ]; then
    wsess=$(tmux display -p -t "$win" '#{session_name}' 2>/dev/null)
    if [ -n "$wsess" ] && [ "$wsess" != "$SESS" ]; then
      tmux move-window -s "$win" -t "$SESS:" 2>/dev/null
      tmux set -w -t "$win" @fleet_hidden 0 2>/dev/null
    fi
    tmux select-window -t "$win" 2>/dev/null
    status="jumped → $from"
  else
    local q; q=$(printf '%q' "$f") pager="less -R"
    command -v less >/dev/null 2>&1 || pager=cat
    tmux display-popup -E -b rounded -w 80% -h 70% -T " msg · ${from:-?} " \
      "cat $q | $pager" 2>/dev/null
    status="$from not live — showed stored message"
  fi
}

# --- render ------------------------------------------------------------------
# Rounded box drawn inside the pane (tmux pane borders can't be rounded). Redraw
# in place (cursor-home, clear-to-EOL per line) so the pane never flashes.
# Border row helpers embed a title/hint label into a ─ rule between corners.
hrule() { # hrule <left-corner> <right-corner> <inner-width> [label]
  local l="$1" r="$2" w="$3" label="${4:-}" fill
  if [ -n "$label" ]; then
    # between the corners must be exactly w cols: "─" + lab + fill(n) = w.
    # Truncate an over-long label so the line can't wrap (which would scroll).
    local lab=" $label " avail=$(( w - 1 ))
    (( avail < 0 )) && avail=0
    (( ${#lab} > avail )) && lab="${lab:0:avail}"
    local n=$(( avail - ${#lab} )); (( n < 0 )) && n=0
    fill=""; (( n > 0 )) && fill=$(printf '%.0s─' $(seq 1 "$n"))   # n==0: no stray ─ (printf emits the format once on 0 args)
    printf '%s─%s%s%s' "$l" "$lab" "$fill" "$r"
  else
    fill=""; (( w > 0 )) && fill=$(printf '%.0s─' $(seq 1 "$w"))
    printf '%s%s%s' "$l" "$fill" "$r"
  fi
}

PAD_X=2          # blank columns inset on each side, inside the rails
PAD_Y=1          # blank rows of inset below the top border / above the bottom

render() {
  [ "$MODE" = inbox ] && { render_inbox; return; }
  local cols rows; cols=$(tput cols); rows=$(tput lines)
  # leave the pane's last column empty: writing a full-width last line scrolls
  # on auto-wrap terminals. cols-3 keeps the right rail one column in.
  local inner=$(( cols - 3 ))                 # columns between the │ │ rails
  local slots=$(( rows - 2 ))                 # content rows between the borders
  local cw=$(( inner - 2 * PAD_X ))           # usable width after horizontal pad
  (( cw < 0 )) && cw=0
  local ins; ins=$(printf '%*s' "$PAD_X" '')  # left/right inset spaces
  local ins1; ins1=$(printf '%*s' $(( PAD_X - 1 )) '')   # inset minus the marker col
  local blank; blank=$(printf '%*s' "$inner" '')
  # Selection marker colour reflects keyboard focus: green when this dashboard
  # pane is the active pane of the current window (keys land here), dim grey
  # otherwise (focus is on the orchestrator/claude pane or another window).
  local pa; pa=$(tmux display -p -t "$SELF_PANE" '#{pane_active}#{window_active}' 2>/dev/null)
  local markc='\033[38;5;240m'                # unfocused: dim grey
  [ "$pa" = "11" ] && markc='\033[1;32m'      # focused: green
  tput cup 0 0 2>/dev/null

  # top border with title. Keep label text to width-1 glyphs only (box-drawing
  # chars and · are reliable; wide/ambiguous glyphs like ⏎ or nerd icons break
  # the char-count = display-width assumption hrule relies on).
  # title carries the cross-agent unread summary (replaces the removed status badge):
  # '✉<total>' and, when any are warn/blocked, '⚠<count>'. Rendered only when >0 so
  # it costs zero width when everything is read.
  local title="FLEET · $SESS · $N agent$([ "$N" = 1 ] || echo s)"
  (( IBX_TOTAL > 0 )) && { title+=" · ✉$IBX_TOTAL"; (( IBX_WARN > 0 )) && title+=" ⚠$IBX_WARN"; }
  printf '\033[2m%s\033[0m\033[K\n' \
    "$(hrule '╭' '╮' "$inner" "$title")"

  local drawn=0 i
  for (( i=0; i<PAD_Y && drawn<slots; i++ )); do   # top padding rows
    printf '\033[2m│%s│\033[0m\033[K\n' "$blank"; (( drawn++ ))
  done

  # project repo glance row: one pill per repo, then a blank spacer. Skipped on
  # repo-less projects (CFG_NP==0) or when too narrow to fit. The label width is
  # derived from CFG_LABEL so "live " (pc-tune) and "repos " stay in budget.
  config_live_cached
  if (( CFG_NP > 0 && drawn < slots )); then
    local cpw=$(( PILL_W + 4 )) cused cpad clab
    clab="${CFG_LABEL:-live} "
    cused=$(( CFG_NP * cpw + (CFG_NP - 1) * PILL_GAP + ${#clab} ))
    cpad=$(( cw - cused ))
    if (( cpad >= 0 )); then
      printf '\033[2m│\033[0m%s\033[2m%s\033[0m%s%*s%s\033[2m│\033[0m\033[K\n' \
        "$ins" "$clab" "$CFG_RAW" "$cpad" '' "$ins"
      (( drawn++ ))
      (( drawn < slots )) && { printf '\033[2m│%s│\033[0m\033[K\n' "$blank"; (( drawn++ )); }
    fi
  fi

  if (( N == 0 && ORPHAN_ROW == 0 && SYSTEM_ROW == 0 )); then
    (( drawn < slots )) && { printf '\033[2m│\033[0m%s%-*s%s\033[2m│\033[0m\033[K\n' \
      "$ins" "$cw" "no agents yet — press n to spawn one" "$ins"; (( drawn++ )); }
  else
    # Row: <state pill>  repo/branch  <git pill>  <mode pill>. The label is the
    # flexible filler; pills (rounded capsules) have width len(text)+4. Content
    # width is kept exactly = cw so the right rail stays aligned.
    # every pill is the same display width (PW); the label is the flexible filler.
    # PILL_GAP-wide gaps separate the items.
    local PW=$(( PILL_W + 4 )) G=$PILL_GAP CF=12    # CF = cost field width
    local gap; gap=$(printf '%*s' "$G" '')
    local state label pane mode g gt content lblsgr LW git_show mode_show cost_show
    local age sdisp scol cost
    local unowned_ruled=0
    for (( i=0; i<N && drawn<slots; i++ )); do
      # --- orchestrator-card chrome: loose-between spacing, dividers, unowned --
      local cgid="" crole=1 cannot=""
      if (( HAS_CARDS )); then cgid="${ROW_GID[$i]:-}"; crole="${ROW_ROLE[$i]:-1}"; cannot="${ROW_ANNOT[$i]:-}"; fi
      if (( HAS_CARDS )) && (( i > 0 )) && (( drawn < slots )); then   # blank between cards / loose unowned pile
        local _pgid="${ROW_GID[$((i-1))]:-}" _prole="${ROW_ROLE[$((i-1))]:-1}"
        if [ "$cgid" != "$_pgid" ] || [ -z "$cgid" ]; then
          printf '\033[2m│%s│\033[0m\033[K\n' "$blank"; (( drawn++ ))
        elif (( crole == 1 )) && (( _prole == 1 )); then  # breathing room between consecutive same-card workers
          printf '\033[2m│%s│\033[0m\033[K\n' "$blank"; (( drawn++ ))
        fi
      fi
      if (( HAS_CARDS )) && [ -z "$cgid" ] && (( unowned_ruled == 0 )) && (( drawn < slots )); then  # '╶ unowned ╴' rule, once
        printf '\033[2m│%s│\033[0m\033[K\n' "$(unowned_rule "$inner")"; (( drawn++ )); unowned_ruled=1
      fi
      if (( HAS_CARDS )) && [ -n "$cgid" ] && (( crole == 0 )); then  # card header == labelled divider
        if (( drawn < slots )); then                         # draw only if it fits; a clipped header is skipped...
          local dn=${CARD_NWORK[$cgid]:-0} dwarn=${CARD_WARN[$cgid]:-0} dlabel="$cgid"
          dlabel+=" · $dn worker$([ "$dn" = 1 ] || echo s)"  # state now lives in the pill, not the '· state' text
          (( dwarn > 0 )) && dlabel+=" · ⚠$dwarn"
          # the so-<id> row IS the card header: render ITS OWN live state pill, same
          # stall/done overrides the worker path applies below.
          local hstate hsdisp hscol hage
          hstate=$(field "$i" 1); hage=$(field "$i" 7); hsdisp="$hstate"; hscol=$(state_pcol "$hstate")
          if [ "$hstate" = working ] && (( ${hage:-0} > STALL_SEC )); then hsdisp="stalled"; hscol=1; fi
          case "$hstate" in working|blocked) ;; *) [ -n "$(field "$i" 8)" ] && { hsdisp="done"; hscol=5; } ;; esac
          local hpill; hpill=$(pill "$hsdisp" "$hscol")
          local hw                                            # hrule width shrinks by the pill so content stays == inner
          if (( i == sel )); then
            hw=$(( inner - 1 - PW )); (( hw < 0 )) && hw=0    # marker(1) + pill(PW) + hrule(hw) == inner
            printf '\033[2m│\033[0m%b▌\033[0m%b\033[2m%s│\033[0m\033[K\n' "$markc" "$hpill" "$(hrule '' '' "$hw" "$dlabel")"
          else
            hw=$(( inner - PW )); (( hw < 0 )) && hw=0        # pill(PW) + hrule(hw) == inner
            printf '\033[2m│\033[0m%b\033[2m%s│\033[0m\033[K\n' "$hpill" "$(hrule '' '' "$hw" "$dlabel")"
          fi
          (( drawn++ ))
          if (( dn == 0 )) && (( drawn < slots )); then       # empty card placeholder
            printf '\033[2m│\033[0m%s%-*s%s\033[2m│\033[0m\033[K\n' "$ins" "$cw" "  (no workers yet)" "$ins"; (( drawn++ ))
          fi
        fi
        continue                                             # ...never fall through to the worker-row printer
      fi
      state=$(field "$i" 1); label=$(field "$i" 2); pane=$(field "$i" 6); age=$(field "$i" 7)
      # show the agent/task name (window name) ahead of the repo/folder so rows
      # sharing a repo are distinguishable: "<task>  <repo/folder>".
      local wname; wname=$(field "$i" 4)
      [ -n "$wname" ] && [ "$wname" != "$label" ] && label="$wname  $label"
      if (( HAS_CARDS )); then
        if [ -n "$cgid" ] && (( crole == 1 )); then        # owned worker: 2-space indent + tree glyph (└─ last, ├─ otherwise)
          local _last=1
          (( i < N-1 )) && [ "${ROW_GID[$((i+1))]:-}" = "$cgid" ] && _last=0
          local _gl="├─"; (( _last )) && _gl="└─"
          label="  $_gl $label"
        elif [ -z "$cgid" ] && [ -n "$cannot" ]; then       # orphan-owner folded into the unowned bucket
          label="$label  $cannot"
        fi
      fi
      g=$(git_cached "$pane"); gt=$(gitfmt "$g")
      # mode pill only for harnesses with a runtime permission-mode cycle (claude)
      local hmode np
      if harness_has_modes "$(harness_of "$pane")"; then mode=$(mode_label "$pane"); hmode=1; np=3
      else mode=""; hmode=0; np=2; fi
      git_show=1; mode_show=$hmode; cost_show=1
      # per-agent unread pill (✉N), coloured by the agent's max unread severity.
      # Rendered only when this agent has unread msgs, so all-read rows cost nothing.
      local iunread=${UNREAD[$wname]:-0} ibx_show=0
      (( iunread > 0 )) && ibx_show=1
      np=$(( 1 + git_show + mode_show + ibx_show ))   # state always + git/mode/✉ optional
      LW=$(( cw - np*PW - CF - (np+1)*G ))         # np pills + cost + gaps
      (( LW < 1 )) && { cost_show=0; LW=$(( cw - np*PW - np*G )); }                 # drop cost
      (( LW < 1 )) && (( mode_show )) && { mode_show=0; np=$((np-1)); LW=$(( cw - np*PW - np*G )); }  # drop mode
      (( LW < 1 )) && (( ibx_show )) && { ibx_show=0; np=$((np-1)); LW=$(( cw - np*PW - np*G )); }    # drop ✉
      (( LW < 1 )) && { git_show=0; ibx_show=0; mode_show=0; LW=$(( cw - PW - G )); }                 # state+label only
      (( LW < 0 )) && LW=0
      # stall: an agent stuck "working" too long shows a red 'stalled' pill
      sdisp="$state"; scol=$(state_pcol "$state")
      if [ "$state" = working ] && (( ${age:-0} > STALL_SEC )); then sdisp="stalled"; scol=1; fi
      # flagged ready for deletion (fleet ready) → magenta 'done' pill. Only
      # override a NON-live state: a working/blocked agent carrying a stale or
      # inherited .fleet/ready marker is still busy, so keep its live pill.
      # idle/stalled/dead/unknown + flagged = genuinely done.
      case "$state" in
        working|blocked) ;;
        *) [ -n "$(field "$i" 8)" ] && { sdisp="done"; scol=5; } ;;
      esac
      (( i == sel )) && lblsgr='\033[1m' || lblsgr='\033[2m'
      content=$(pill "$sdisp" "$scol")
      content+=$(printf "%s${lblsgr}%b\033[22m" "$gap" "$(fit_left "$label" "$LW")")
      (( git_show )) && content+="$gap$(pill "$gt" "$(git_pcol "$g")")"
      (( mode_show )) && content+="$gap$(pill "$(mode_short "$mode")" "$(mode_pcol "$mode")")"
      (( ibx_show )) && content+="$gap$(pill "✉$iunread" "$(sev_pcol "${MAXSEV[$wname]:-}")")"
      if (( cost_show )); then
        cost=$(cost_cached "$pane")
        content+=$(printf "%s\033[2m%-*.*s\033[0m" "$gap" "$CF" "$CF" "$cost")
      fi
      if (( drawn < slots )); then   # guard the row print: pre-row card chrome may have just consumed the last slot
        if (( i == sel )); then   # focus-coloured marker bar marks the selection
          printf '\033[2m│\033[0m%b▌\033[0m%s%b%s\033[2m│\033[0m\033[K\n' \
            "$markc" "$ins1" "$content" "$ins"
        else
          printf '\033[2m│\033[0m%s%b%s\033[2m│\033[0m\033[K\n' "$ins" "$content" "$ins"
        fi
        (( drawn++ ))
      fi
      if (( ! HAS_CARDS )); then                # flat list: blank between agents (card mode spaces at loop top)
        local gi                                # vertical gap between agents
        for (( gi=0; gi<ROW_GAP && i<N-1 && drawn<slots; gi++ )); do
          printf '\033[2m│%s│\033[0m\033[K\n' "$blank"; (( drawn++ ))
        done
      fi
    done
    # Closing rule under the unowned pile: unowned rows always sort last, so the loop
    # has just emitted them. Mirror the top '╶ unowned ╴' rule with a plain ─ divider
    # (no label), same inner width — only when a top rule was drawn and a slot remains.
    if (( HAS_CARDS )) && (( unowned_ruled )) && (( drawn < slots )); then
      printf '\033[2m│%s│\033[0m\033[K\n' "$(hrule '' '' "$inner")"; (( drawn++ ))
    fi
    # Synthetic '⌫ orphans' row (combined bucket, trailing position) for unread msgs
    # whose sender matches no live window — reaped/gone agents, or a prior incarnation
    # of a respawned name (pane-suffix mismatch). Selectable at index N; 'e'/Enter
    # opens its filtered view. Rendered only when ORPHAN_N>0.
    if (( ORPHAN_ROW && drawn < slots )); then
      (( N > 0 && drawn < slots )) && { printf '\033[2m│%s│\033[0m\033[K\n' "$blank"; (( drawn++ )); }
      if (( drawn < slots )); then
        local oidx=$N olbl ocont ocol OLW
        olbl="⌫ orphans ($ORPHAN_N) — reaped/gone senders"
        ocol=$(sev_pcol "$ORPHAN_MAXSEV")
        OLW=$(( cw - PW - G )); (( OLW < 0 )) && OLW=0
        (( oidx == sel )) && lblsgr='\033[1m' || lblsgr='\033[2m'
        ocont=$(pill "✉$ORPHAN_N" "$ocol")
        ocont+=$(printf "%s${lblsgr}%b\033[22m" "$gap" "$(fit_left "$olbl" "$OLW")")
        if (( oidx == sel )); then
          printf '\033[2m│\033[0m%b▌\033[0m%s%b%s\033[2m│\033[0m\033[K\n' \
            "$markc" "$ins1" "$ocont" "$ins"
        else
          printf '\033[2m│\033[0m%s%b%s\033[2m│\033[0m\033[K\n' "$ins" "$ocont" "$ins"
        fi
        (( drawn++ ))
      fi
    fi
    # Synthetic '⚙ system' row for unread orchestrator/gate notes (sender == main or
    # systemic '-') — these are NOT reaped workers, so they get their own bucket below
    # the orphans row, never folded into it. Selectable at index N+ORPHAN_ROW.
    if (( SYSTEM_ROW && drawn < slots )); then
      (( (N > 0 || ORPHAN_ROW) && drawn < slots )) && { printf '\033[2m│%s│\033[0m\033[K\n' "$blank"; (( drawn++ )); }
      if (( drawn < slots )); then
        local sysidx=$(( N + ORPHAN_ROW )) syslbl syscont syscol SLW
        syslbl="⚙ system ($SYSTEM_N) — orchestrator/gate notes"
        syscol=$(sev_pcol "$SYSTEM_MAXSEV")
        SLW=$(( cw - PW - G )); (( SLW < 0 )) && SLW=0
        (( sysidx == sel )) && lblsgr='\033[1m' || lblsgr='\033[2m'
        syscont=$(pill "✉$SYSTEM_N" "$syscol")
        syscont+=$(printf "%s${lblsgr}%b\033[22m" "$gap" "$(fit_left "$syslbl" "$SLW")")
        if (( sysidx == sel )); then
          printf '\033[2m│\033[0m%b▌\033[0m%s%b%s\033[2m│\033[0m\033[K\n' \
            "$markc" "$ins1" "$syscont" "$ins"
        else
          printf '\033[2m│\033[0m%s%b%s\033[2m│\033[0m\033[K\n' "$ins" "$syscont" "$ins"
        fi
        (( drawn++ ))
      fi
    fi
  fi

  # empty side rails fill the box down to the bottom border (also = bottom pad)
  while (( drawn < slots )); do
    printf '\033[2m│%s│\033[0m\033[K\n' "$blank"
    (( drawn++ ))
  done

  # bottom border with key hints (or a transient status)
  local hint
  if [ -n "$status" ]; then hint="$status"
  else hint="Spc leader · j/k · Ent jump · e msgs · h hide · v diff · m mode · s send · n new · d close · r/R refresh"; fi
  tput cup $(( rows - 1 )) 0 2>/dev/null
  printf '\033[2m%s\033[0m\033[K' "$(hrule '╰' '╯' "$inner" "$hint")"
}

# inbox view: one row per live .msg (newest-first), with the same box, padding and
# focus-coloured selection bar as the agents view. Field-access machinery is the
# per-file ibx_field/ibx_body accessors (same as fleet).
render_inbox() {
  local cols rows; cols=$(tput cols); rows=$(tput lines)
  local inner=$(( cols - 3 ))
  local slots=$(( rows - 2 ))
  local cw=$(( inner - 2 * PAD_X )); (( cw < 0 )) && cw=0
  local ins; ins=$(printf '%*s' "$PAD_X" '')
  local ins1; ins1=$(printf '%*s' $(( PAD_X - 1 )) '')
  local blank; blank=$(printf '%*s' "$inner" '')
  local pa; pa=$(tmux display -p -t "$SELF_PANE" '#{pane_active}#{window_active}' 2>/dev/null)
  local markc='\033[38;5;240m'; [ "$pa" = "11" ] && markc='\033[1;32m'
  local now; now=$(date +%s 2>/dev/null); [ -n "$now" ] || now=0
  tput cup 0 0 2>/dev/null

  local htitle
  if (( IALL )); then
    htitle="$(triage_header)"
  else
    local scope
    if   (( IORPHAN )); then scope="orphans"
    elif (( ISYSTEM )); then scope="system"
    else scope="${IFILTER:-?}"; fi
    htitle="MSGS · $scope · $IUNREAD"
  fi
  printf '\033[2m%s\033[0m\033[K\n' \
    "$(hrule '╭' '╮' "$inner" "$htitle")"

  local drawn=0 i
  for (( i=0; i<PAD_Y && drawn<slots; i++ )); do
    printf '\033[2m│%s│\033[0m\033[K\n' "$blank"; (( drawn++ ))
  done

  if (( IN == 0 )); then
    local msg="inbox empty" mpad
    while (( drawn < slots )); do
      if (( drawn == slots / 2 )); then
        mpad=$(( (cw - ${#msg}) / 2 )); (( mpad < 0 )) && mpad=0
        printf '\033[2m│\033[0m%s%*s%-*s%s\033[2m│\033[0m\033[K\n' \
          "$ins" "$mpad" '' "$(( cw - mpad ))" "$msg" "$ins"
      else
        printf '\033[2m│%s│\033[0m\033[K\n' "$blank"
      fi
      (( drawn++ ))
    done
  else
    # archive-as-truth: every listed msg is unread, so the leading '*' is constant.
    # The 'from' column is shown only in the orphan view (Q4 — identify each dead
    # sender); in an agent-scoped view 'from' is constant (== IFILTER) so it's dropped.
    local SEVW=9 FROMW=14 AGEW=5 showfrom=0 base
    (( IORPHAN || ISYSTEM || IALL )) && showfrom=1   # show 'from' in the cross-sender views (incl. triage)
    if (( showfrom )); then base=33; else base=18; fi   # see width math below
    local f id sev from title epoch age sevf
    local sevtxt fromtxt titletxt agetxt content LW ageshow lblsgr
    for (( i=0; i<IN && drawn<slots; i++ )); do
      f="${IROWS[$i]}"; id=$(basename "$f" .msg)
      sev=$(ibx_field "$f" sev); from=$(ibx_field "$f" from); title=$(ibx_field "$f" title)
      epoch="${id%%.*}"; case "$epoch" in *[!0-9]*|'') epoch=$now ;; esac
      age=$(fmt_age $(( now - epoch )))
      # widths: '*'(1) sp(1) sev(SEVW) sp(1) [from(FROMW) sp(1)] title sp(1) age(AGEW)
      ageshow=1; LW=$(( cw - base ))
      (( LW < 1 )) && { ageshow=0; LW=$(( cw - base + AGEW + 1 )); }   # drop age
      (( LW < 1 )) && LW=0
      sevf=$(printf '[%s]' "$sev")
      sevtxt=$(printf '%s%-*.*s\033[0m' "$(sev_color "$sev")" "$SEVW" "$SEVW" "$sevf")
      # Leading slot: constant '*' in the per-agent views; in triage it is the
      # multi-select marker — '◉' (bright) when marked, '·' (dim) when not.
      local mk='*'
      if (( IALL )); then
        if [ -n "${MARKED[$f]:-}" ]; then mk=$'\033[1;32m◉\033[0m'; else mk=$'\033[2m·\033[0m'; fi
      fi
      # In triage, de-emphasise (dim) system/orchestrator-origin senders so worker
      # pleas stand out — shown, never filtered (advisor D5/Q5).
      fromtxt=""
      if (( showfrom )); then
        if (( IALL )) && msg_from_is_system "$from"; then
          fromtxt=$(printf '\033[2m%-*.*s\033[0m ' "$FROMW" "$FROMW" "$from")
        else
          fromtxt=$(printf '%-*.*s ' "$FROMW" "$FROMW" "$from")
        fi
      fi
      titletxt=$(fit_left "$title" "$LW")
      agetxt=""; (( ageshow )) && agetxt=$(printf ' %*s' "$AGEW" "$age")
      (( i == isel )) && lblsgr='\033[1m' || lblsgr='\033[2m'
      content=$(printf '%b %s %s%b%s\033[22m%s' \
        "$mk" "$sevtxt" "$fromtxt" "$lblsgr" "$titletxt" "$agetxt")
      if (( i == isel )); then
        printf '\033[2m│\033[0m%b▌\033[0m%s%s%s\033[2m│\033[0m\033[K\n' \
          "$markc" "$ins1" "$content" "$ins"
      else
        printf '\033[2m│\033[0m%s%s%s\033[2m│\033[0m\033[K\n' "$ins" "$content" "$ins"
      fi
      (( drawn++ ))
    done
  fi

  while (( drawn < slots )); do
    printf '\033[2m│%s│\033[0m\033[K\n' "$blank"; (( drawn++ ))
  done

  local hint
  if [ -n "$status" ]; then hint="$status"
  elif (( IALL )); then hint="Space mark · o order · Ent pop marked → orch · c mark all read · q/Esc back · r refresh"
  else hint="j/k · Ent pop → orch · J jump to source · c mark all read · q/Esc back · r refresh"; fi
  tput cup $(( rows - 1 )) 0 2>/dev/null
  printf '\033[2m%s\033[0m\033[K' "$(hrule '╰' '╯' "$inner" "$hint")"
}

# read one line from the user at the bottom, cursor shown
ask() { # ask "prompt> " -> echoes reply
  local reply; local rows; rows=$(tput lines)
  tput cnorm 2>/dev/null
  tput cup $((rows - 1)) 0 2>/dev/null; tput el 2>/dev/null
  cooked_mode                       # readline (read -ep) needs echo + canonical input
  IFS= read -rep "$1" reply
  raw_mode                          # back to no-echo char-at-a-time
  tput civis 2>/dev/null
  printf '%s' "$reply"
}

# --- modal popups -------------------------------------------------------------
# These draw a centred rounded box directly to /dev/tty and read keys from
# /dev/tty, so they can run inside $(...) and return only their result on stdout.
tsize() { stty size </dev/tty 2>/dev/null || echo "24 80"; }   # -> "rows cols"
at()  { printf '\033[%d;%dH' $(( $1 + 1 )) $(( $2 + 1 )) >/dev/tty; }   # cup row col (0-based)
mtop() { at "$1" "$2"; printf '\033[2m%s\033[0m' "$(hrule '╭' '╮' $(( $3 - 2 )) "$4")" >/dev/tty; }
mbot() { at "$1" "$2"; printf '\033[2m%s\033[0m' "$(hrule '╰' '╯' $(( $3 - 2 )) "")" >/dev/tty; }
mrow() { # row col width text [selected]
  local r="$1" x="$2" w="$3" t="$4" s="${5:-}"
  at "$r" "$x"
  if [ -n "$s" ]; then
    printf '\033[2m│\033[0m\033[7m %-*.*s \033[0m\033[2m│\033[0m' $(( w-4 )) $(( w-4 )) "$t" >/dev/tty
  else
    printf '\033[2m│\033[0m %-*.*s \033[2m│\033[0m' $(( w-4 )) $(( w-4 )) "$t" >/dev/tty
  fi
}

# --- permission-mode selection ------------------------------------------------
# Claude only exposes mode *cycling* (Shift+Tab), not "set mode X". The MODES list
# above is the Shift+Tab cycle order (verified empirically: default → accept-edits
# → plan → auto, looping; bypass is NOT in the Shift+Tab cycle in current claude).
# We present it as a pick-list, then drive the agent toward the chosen mode with
# apply_mode — which reads the live footer after each press, so it stays correct
# even if a claude version reorders the cycle (MODES only affects display order).

mode_desc() { # short hint per known mode
  case "$1" in
    default)      echo "prompt for each tool" ;;
    auto)         echo "auto mode" ;;
    accept-edits) echo "auto-accept edits" ;;
    plan)         echo "read-only planning" ;;
    bypass)       echo "skip all permission prompts" ;;
    *)            echo "" ;;
  esac
}

# pane -> true if claude is idle at its input prompt (the only state where
# Shift+Tab actually cycles the permission mode — not busy, not in a dialog).
agent_at_prompt() {
  tmux capture-pane -p -t "$1" 2>/dev/null | grep -qE '\? for shortcuts|shift\+tab to cycle'
}

msg_box() { # title line -> small centred notice box (drawn to /dev/tty)
  local title="$1" line="$2" R C bw=46
  read -r R C < <(tsize)
  local bx=$(( (C - bw) / 2 )) by=$(( (R - 3) / 2 ))
  (( bx < 0 )) && bx=0; (( by < 1 )) && by=1
  mtop "$by" "$bx" "$bw" "$title"; mrow $(( by+1 )) "$bx" "$bw" "  $line"; mbot $(( by+2 )) "$bx" "$bw"
}

settle_read() { # pane prev -> the mode once it has changed from prev AND is
  local pane="$1" prev="$2" cur last="__init__" i   # stable (seen twice). The
  for (( i=0; i<25; i++ )); do          # footer settles in ~100ms, so this polls
    sleep 0.1; cur=$(mode_label "$pane")   # fast and returns in ~0.2-0.3s; the
    [ "$cur" != "$prev" ] && [ "$cur" = "$last" ] && { printf '%s' "$cur"; return; }
    last="$cur"                         # stability check ignores transient frames.
  done
  printf '%s' "$cur"                    # gave up (~2.5s) — return latest
}


# apply_mode pane label target -> Shift+Tab toward target. Robust: stops if the
# cycle loops back to start (target not reachable) or the agent isn't responding,
# and restores the agent to its original mode on failure (bounded keystrokes).
apply_mode() {
  local pane="$1" label="$2" target="$3" start cur n=0
  start=$(mode_label "$pane"); cur="$start"
  [ "$cur" = "$target" ] && return 0
  while (( n < 8 )); do
    "$FLEET_BIN" mode "$label" >/dev/null 2>&1
    cur=$(settle_read "$pane" "$cur"); (( n++ ))
    [ "$cur" = "$target" ] && return 0
    [ "$cur" = "$start" ] && break          # full loop, or no change (stuck) → give up
  done
  while [ "$(mode_label "$pane")" != "$start" ] && (( n < 16 )); do
    "$FLEET_BIN" mode "$label" >/dev/null 2>&1; cur=$(settle_read "$pane" "$cur"); (( n++ ))
  done
  return 1
}

# pick_mode <pane> <label> -> centred mode picker; sets global `status`.
pick_mode() {
  local pane="$1" label="$2" k r R C bw=46
  local cur n=${#MODES[@]} mi=0 i
  cur=$(mode_label "$pane")
  for (( i=0; i<n; i++ )); do [ "${MODES[i]}" = "$cur" ] && mi=$i; done
  read -r R C < <(tsize)
  local bx=$(( (C - bw) / 2 )) by=$(( (R - (n + 2)) / 2 ))
  (( bx < 0 )) && bx=0; (( by < 1 )) && by=1
  while :; do
    mtop "$by" "$bx" "$bw" "Select permission mode"
    for (( i=0; i<n; i++ )); do
      local txt; txt=$(printf '%-13s %s' "${MODES[i]}" "$(mode_desc "${MODES[i]}")")
      if (( i == mi )); then mrow $(( by+1+i )) "$bx" "$bw" "$txt" 1
      else mrow $(( by+1+i )) "$bx" "$bw" "$txt"; fi
    done
    mbot $(( by+1+n )) "$bx" "$bw"
    IFS= read -rsN1 -t 120 k </dev/tty || return
    case "$k" in
      $'\e') IFS= read -rsN2 -t 0.01 r </dev/tty
        case "$r" in '[A') (( mi>0 ))&&((mi--));; '[B') (( mi<n-1 ))&&((mi++));; '') return;; esac ;;
      k) (( mi>0 ))&&((mi--)) ;;
      j) (( mi<n-1 ))&&((mi++)) ;;
      $'\n'|$'\r')
        local target="${MODES[mi]}"
        if [ "$target" = "$cur" ]; then status="mode: $target ($label)"; return; fi
        # Claude only cycles permission mode at its idle prompt — never poke a
        # busy agent or a permission dialog with Shift+Tab.
        if ! agent_at_prompt "$pane"; then
          status="$label is busy — set mode when it's idle at its prompt"; return
        fi
        msg_box "Permission mode" "setting $target ..."
        if apply_mode "$pane" "$label" "$target"; then status="mode -> $target ($label)"
        else status="couldn't reach $target — $label may lack that mode"; fi
        return ;;
      q) return ;;
    esac
  done
}

# list_pick <title> <cur-index> <item>... -> echoes the chosen index (or cur on
# cancel). Centred scrollable popup — used for the Repo/Base dropdowns.
list_pick() {
  local title="$1" cur="$2"; shift 2
  local items=("$@") n=${#items[@]}
  (( n == 0 )) && { echo "$cur"; return; }
  local mi="$cur"; (( mi<0 || mi>=n )) && mi=0
  local k r R C bw=50
  read -r R C < <(tsize)
  local maxv=$(( R - 6 )); (( maxv > n )) && maxv=$n; (( maxv < 3 )) && maxv=3
  local bx=$(( (C - bw) / 2 )) by=$(( (R - (maxv + 2)) / 2 )) vs=0
  (( bx < 0 )) && bx=0; (( by < 1 )) && by=1
  printf '\033[2J\033[H' >/dev/tty          # clean backdrop (not stdout — that's the result)
  while :; do
    (( mi < vs )) && vs=$mi
    (( mi >= vs + maxv )) && vs=$(( mi - maxv + 1 ))
    mtop "$by" "$bx" "$bw" "$title"
    local i row=0
    for (( i=vs; i<vs+maxv && i<n; i++ )); do
      if (( i == mi )); then mrow $(( by+1+row )) "$bx" "$bw" "${items[i]}" 1
      else mrow $(( by+1+row )) "$bx" "$bw" "${items[i]}"; fi
      ((row++))
    done
    while (( row < maxv )); do mrow $(( by+1+row )) "$bx" "$bw" ""; ((row++)); done
    mbot $(( by+1+maxv )) "$bx" "$bw"
    IFS= read -rsN1 -t 120 k </dev/tty || { echo "$cur"; return; }
    case "$k" in
      $'\e') IFS= read -rsN2 -t 0.01 r </dev/tty
        case "$r" in '[A') (( mi>0 ))&&((mi--));; '[B') (( mi<n-1 ))&&((mi++));; '') echo "$cur"; return;; esac ;;
      k) (( mi>0 ))&&((mi--)) ;;
      j) (( mi<n-1 ))&&((mi++)) ;;
      $'\n'|$'\r') echo "$mi"; return ;;
      q) echo "$cur"; return ;;
    esac
  done
}

# new_agent_form -> centred in-box form. Repo is a dropdown; Branch picks an
# EXISTING worktree to launch on, or "+ new branch" to create one (then a text
# field + Base appear). j/k or ↑/↓ move between fields. Sets global `status`.
NEWSENT="+ new branch"
new_agent_form() {
  local R C bw=58 prompt="" bare="no" scratch="no" ai=0 note="" k r x s newbranch="" editing=0
  local nitems=8    # 0 Repo,1 Branch,2 Base,3 Prompt,4 Scratch,5 Bare,6 Harness,7 Create
  # `editing` (0/1): text fields (Prompt; new-branch name) only capture keystrokes
  # while editing=1. Enter on a text field enters edit mode; Enter/Esc commits and
  # returns to nav mode. In nav mode j/k/arrows navigate every field uniformly.
  # Scratch is a plain toggle (not a text field) — it never uses editing mode.
  read -r R C < <(tsize)
  local REPOS=() ri=0
  while IFS= read -r x; do [ -n "$x" ] && REPOS+=("$x"); done < <("$FLEET_BIN" repos 2>/dev/null)
  local repo=""
  # No repos under the project root? A repo-less scratch agent is still possible.
  if (( ${#REPOS[@]} )); then repo="${REPOS[0]}"; else scratch="yes"; note="no repos found — scratch only"; ai=4; fi
  local HARN=() hi=0
  while IFS= read -r x; do [ -n "$x" ] && HARN+=("$x"); done < <("$FLEET_BIN" harnesses 2>/dev/null)
  (( ${#HARN[@]} == 0 )) && HARN=(claude)
  # default to claude if present
  local _i; for _i in "${!HARN[@]}"; do [ "${HARN[_i]}" = claude ] && hi=$_i; done
  local WT=() wi=0 BRANCHES=() bi=0
  _load_repo() {  # existing worktrees (+ a "new branch" entry) and base branches
    WT=(); while IFS= read -r x; do [ -n "$x" ] && WT+=("$x"); done < <("$FLEET_BIN" worktrees "$repo" 2>/dev/null)
    WT+=("$NEWSENT"); wi=0
    BRANCHES=(); bi=0
    while IFS= read -r x; do [ -n "$x" ] && BRANCHES+=("$x"); done < <("$FLEET_BIN" branches "$repo" 2>/dev/null)
  }
  _load_repo
  local bx=$(( (C - bw) / 2 )) by=$(( (R - 16) / 2 ))
  (( bx < 0 )) && bx=0; (( by < 1 )) && by=1

  _isnew() { [ "${WT[wi]}" = "$NEWSENT" ]; }
  _base() { (( ${#BRANCHES[@]} )) && printf '%s' "${BRANCHES[bi]}" || printf '(default)'; }
  _active() { # idx -> 0 if the field is navigable in the current mode
    [ "$scratch" = yes ] && case "$1" in 0|1|2|5) return 1 ;; esac   # repo/branch/base/bare off
    return 0
  }
  _step() { # move ai by <dir>, skipping inactive fields, clamped to the range
    local d="$1" j=$ai
    while :; do j=$(( j + d )); (( j<0 || j>=nitems )) && return; _active "$j" && { ai=$j; return; }; done
  }
  _toggle_scratch() { # repo-less needs at least the option; lock on when no repos
    (( ${#REPOS[@]} == 0 )) && { scratch=yes; note="no repos found — scratch only"; return; }
    [ "$scratch" = no ] && scratch=yes || scratch=no
  }
  _field() { # off idx label value type [placeholder]
    local off="$1" idx="$2" lbl="$3" v="$4" ty="$5" ph="${6:-}" disp txt
    if (( ai == idx )); then
      case "$ty" in
        text)   if (( editing )); then disp="${v}_"   # edit mode: trailing cursor
                else disp="${v:-$ph}"; fi ;;          # nav mode: plain value/placeholder
        select) disp="< ${v:-$ph} >" ;;
        *)      disp="$v" ;;
      esac
    else disp="${v:-$ph}"; fi
    txt=$(printf '%-8s %s' "$lbl" "$disp")
    if (( ai == idx )); then mrow $(( by+off )) "$bx" "$bw" "$txt" 1
    else mrow $(( by+off )) "$bx" "$bw" "$txt"; fi
  }
  _draw() {
    mtop "$by" "$bx" "$bw" "New fleet agent"
    mrow $(( by+1 )) "$bx" "$bw" ""
    if [ "$scratch" = yes ]; then
      _field 2 0 "Repo"   "(scratch — repo-less)" info
      _field 3 1 "Branch" "(scratch — repo-less)" info
      _field 4 2 "Base"   "(scratch — repo-less)" info
    elif _isnew; then
      _field 2 0 "Repo" "$repo" select
      _field 3 1 "Branch" "$newbranch" text "<new branch>"
      _field 4 2 "Base" "$(_base)" select
    else
      _field 2 0 "Repo" "$repo" select
      _field 3 1 "Branch" "${WT[wi]}" select
      _field 4 2 "Base" "(existing worktree)" info
    fi
    _field 5 3 "Prompt" "$prompt" text "(optional)"
    _field 6 4 "Scratch" "$scratch" toggle
    if [ "$scratch" = yes ]; then _field 7 5 "Bare" "(forced)" info
    else                          _field 7 5 "Bare" "$bare" toggle; fi
    _field 8 6 "Harness" "${HARN[hi]}" select
    mrow $(( by+9 )) "$bx" "$bw" ""
    if (( ai == 7 )); then mrow $(( by+10 )) "$bx" "$bw" "[ Create agent ]" 1
    else mrow $(( by+10 )) "$bx" "$bw" "  Create agent"; fi
    mrow $(( by+11 )) "$bx" "$bw" ""
    mrow $(( by+12 )) "$bx" "$bw" "${note:-j/k or up/down move . <> cycle . Enter=edit/list . Esc}"
    mbot $(( by+13 )) "$bx" "$bw"
  }
  _cyc() { # field <dir:1|-1> — cycle the active select
    local d="$1"
    case "$ai" in
      0) (( ${#REPOS[@]} )) && { ri=$(( (ri + d + ${#REPOS[@]}) % ${#REPOS[@]} )); repo="${REPOS[ri]}"; _load_repo; } ;;
      1) wi=$(( (wi + d + ${#WT[@]}) % ${#WT[@]} )) ;;
      2) _isnew && (( ${#BRANCHES[@]} )) && bi=$(( (bi + d + ${#BRANCHES[@]}) % ${#BRANCHES[@]} )) ;;
      4) _toggle_scratch ;;
      5) [ "$bare" = no ] && bare=yes || bare=no ;;
      6) hi=$(( (hi + d + ${#HARN[@]}) % ${#HARN[@]} )) ;;
    esac
  }
  _spawn() {
    local args
    if [ "$scratch" = yes ]; then   # repo-less: no repo/branch/worktree
      msg_box "New fleet agent" "launching scratch agent (${HARN[hi]}) ..."
      args=(--scratch)
      [ -n "$prompt" ] && args+=(-p "$prompt")
      args+=(--harness "${HARN[hi]}")
      if "$FLEET_BIN" new "${args[@]}" >/dev/null 2>&1; then status="launched: scratch (${HARN[hi]})"
      else status="spawn failed: scratch"; fi
      return 0
    fi
    local branch; if _isnew; then branch="$newbranch"; else branch="${WT[wi]}"; fi
    [ -n "$branch" ] || { note="pick a worktree or enter a new branch name"; return; }
    msg_box "New fleet agent" "launching $repo / $branch ..."
    args=("$repo" "$branch")
    [ -n "$prompt" ] && args+=(-p "$prompt")
    [ "$bare" = yes ] && args+=(--bare)
    if _isnew && (( ${#BRANCHES[@]} )); then args+=(--base "${BRANCHES[bi]}"); fi
    args+=(--harness "${HARN[hi]}")
    if "$FLEET_BIN" new "${args[@]}" >/dev/null 2>&1; then status="launched: $repo $branch"
    else status="spawn failed: $repo $branch"; fi
    return 0
  }

  while :; do
    _draw
    IFS= read -rsN1 -t 300 k </dev/tty || return
    case "$k" in
      $'\e')
        IFS= read -rsN2 -t 0.01 r </dev/tty || r=''
        # In edit mode: bare Esc commits the text (does NOT cancel the form);
        # arrow keys are swallowed so they don't navigate mid-edit.
        if (( editing )); then [ -z "$r" ] && { editing=0; note=""; }; continue; fi
        case "$r" in
          '[A') _step -1 ;;
          '[B') _step 1 ;;
          '[C') _cyc 1 ;;
          '[D') _cyc -1 ;;
          '') return ;;
        esac ;;
      $'\t') if (( ! editing )); then local _n=0; while (( _n++ < nitems )); do ai=$(( (ai+1) % nitems )); _active "$ai" && break; done; fi ;;
      $'\n'|$'\r')
        if (( editing )); then editing=0; note=""; continue; fi  # Enter commits text
        case "$ai" in
          0) s=$(list_pick "Select repo" "$ri" "${REPOS[@]}"); clear
             [ -n "$s" ] && { ri="$s"; repo="${REPOS[ri]}"; _load_repo; } ;;
          1) if _isnew; then editing=1; note="type branch name . Enter/Esc commits"
             else s=$(list_pick "Launch on worktree" "$wi" "${WT[@]}"); clear
               [ -n "$s" ] && wi="$s"; fi ;;
          2) if _isnew && (( ${#BRANCHES[@]} )); then s=$(list_pick "Branch off of" "$bi" "${BRANCHES[@]}"); clear
               [ -n "$s" ] && bi="$s"; fi ;;
          3) editing=1; note="type prompt . Enter/Esc commits" ;;  # enter prompt edit mode
          6) s=$(list_pick "Harness" "$hi" "${HARN[@]}"); clear
             [ -n "$s" ] && hi="$s" ;;
          7) _spawn; [ "$status" ] && return ;;
          *) _step 1 ;;
        esac ;;
      $'\177'|$'\b')
        if (( editing )); then
          if (( ai == 1 )); then newbranch="${newbranch%?}"; else prompt="${prompt%?}"; fi
        fi ;;
      ' ')
        if (( editing )); then
          if (( ai == 1 )); then newbranch+=" "; else prompt+=" "; fi
        elif (( ai == 4 )); then _toggle_scratch
        elif (( ai == 5 )); then [ "$bare" = no ] && bare=yes || bare=no
        fi ;;
      *)
        case "$k" in
          [[:print:]])
            if (( editing )); then
              if (( ai == 1 )); then newbranch+="$k"; else prompt+="$k"; fi
            elif [ "$k" = k ]; then _step -1
            elif [ "$k" = j ]; then _step 1
            fi ;;
        esac ;;
    esac
  done
}

# --- teardown -----------------------------------------------------------------
agent_wt() { # dir -> 1 if it's a linked git worktree (safe to `worktree remove`)
  local gd; gd=$(git -C "$1" rev-parse --git-dir 2>/dev/null) || { echo 0; return; }
  case "$gd" in *"/worktrees/"*) echo 1 ;; *) echo 0 ;; esac
}

# confirm_teardown <label> <win> <pane> <dir> -> centred confirm popup; closes
# the agent window and optionally removes its worktree. Sets global `status`.
confirm_teardown() {
  local label="$1" win="$2" pane="$3" dir="$4"
  local iswt=0; [ -n "$dir" ] && iswt=$(agent_wt "$dir")
  local opts=() acts=()
  opts+=("Close window (keep files)");                acts+=("close")
  if (( iswt == 1 )); then
    opts+=("Close + remove worktree");                acts+=("remove")
    opts+=("Close + FORCE remove (discard changes)"); acts+=("force")
  fi
  opts+=("Cancel");                                   acts+=("cancel")
  local n=${#opts[@]} mi=0 k r R C bw=54
  read -r R C < <(tsize)
  local bx=$(( (C - bw) / 2 )) by=$(( (R - (n + 4)) / 2 ))
  (( bx < 0 )) && bx=0; (( by < 1 )) && by=1
  while :; do
    mtop "$by" "$bx" "$bw" "Close agent"
    mrow $(( by+1 )) "$bx" "$bw" "  $label"
    mrow $(( by+2 )) "$bx" "$bw" ""
    local i
    for (( i=0; i<n; i++ )); do
      if (( i == mi )); then mrow $(( by+3+i )) "$bx" "$bw" "${opts[i]}" 1
      else mrow $(( by+3+i )) "$bx" "$bw" "${opts[i]}"; fi
    done
    mbot $(( by+3+n )) "$bx" "$bw"
    IFS= read -rsN1 -t 120 k </dev/tty || return
    case "$k" in
      $'\e') IFS= read -rsN2 -t 0.01 r </dev/tty
        case "$r" in '[A') (( mi>0 ))&&((mi--));; '[B') (( mi<n-1 ))&&((mi++));; '') return;; esac ;;
      k) (( mi>0 ))&&((mi--)) ;;
      j) (( mi<n-1 ))&&((mi++)) ;;
      $'\n'|$'\r')
        [ -n "$win" ] || return
        case "${acts[mi]}" in
          cancel) return ;;
          close) tmux kill-window -t "$win" 2>/dev/null
                 "$FLEET_BIN" forget "$dir" 2>/dev/null
                 status="closed $label"; return ;;
          remove|force)
            local force="" main
            [ "${acts[mi]}" = force ] && force="--force"
            # main working tree (or bare container) to run `worktree remove` from
            main=$(git -C "$dir" worktree list --porcelain 2>/dev/null | awk '/^worktree /{print $2; exit}')
            tmux kill-window -t "$win" 2>/dev/null
            "$FLEET_BIN" forget "$dir" 2>/dev/null
            if git -C "${main:-$dir}" worktree remove $force "$dir" 2>/dev/null; then
              status="removed worktree: $label"
            else
              status="closed; worktree kept (uncommitted? use FORCE): $label"
            fi
            return ;;
        esac ;;
      q) return ;;
    esac
  done
}

# view_diff <dir> <label> -> show the agent's `git diff HEAD` in a popup pager
# (delta if available, else less). Blocks until the user quits the pager.
view_diff() {
  local dir="$1" label="$2" pager="less -R" q
  command -v delta >/dev/null 2>&1 && pager="delta"
  q=$(printf '%q' "$dir")
  local cmd="d=\$(git -C $q -c color.ui=always diff HEAD 2>/dev/null); if [ -n \"\$d\" ]; then printf '%s\\n' \"\$d\" | $pager; else printf 'working tree clean vs HEAD\\n'; sleep 1.2; fi"
  tmux display-popup -E -b rounded -w 90% -h 90% -T " diff · $label " "$cmd" 2>/dev/null
}

# drain_nav -> apply any *already-buffered* j/k/g/G/arrow keys to `sel` WITHOUT
# rendering, so a fast nav burst collapses into ~one render instead of N. The 3ms
# timeout is BELOW the key-autorepeat gap (~33ms), so it coalesces only genuine
# backlog (keys queued during a slow render, or a paste), not normal repeat — the
# bar still tracks each held-key step smoothly. Stops at the first non-nav key,
# stashing it in PENDING for the main loop (the tty has no pushback).
drain_nav() {
  local k2 r2
  while IFS= read -rsN1 -t 0.003 k2; do
    case "$k2" in
      k) nav_up ;;
      j) nav_down ;;
      g) nav_top ;;
      G) nav_bot ;;
      $'\e') IFS= read -rsN2 -t 0.01 r2 || r2=''
        case "$r2" in
          '[A') nav_up ;;
          '[B') nav_down ;;
          *) : ;;                       # focus/other ESC seq: ignore, keep draining
        esac ;;
      *) PENDING="$k2"; return ;;        # non-nav: stash, stop draining
    esac
  done
}

# --- main loop ---------------------------------------------------------------
# Test/lib seam: under DASH_LIB the functions are loaded but the interactive loop
# (and its tty/render side effects) never runs — the sourcing test drives the
# functions directly.
[ -n "${DASH_LIB:-}" ] && return 0 2>/dev/null

clear
load_rows                       # initial data; thereafter only on refresh/actions
last_load=$SECONDS
PENDING=""                      # a non-nav key stashed by drain_nav (tty has no pushback)
while :; do
  # Cap staleness at ~REFRESH regardless of nav activity. A sustained key-hold
  # keeps resetting the `read -t` timer so the idle timeout alone never fires
  # (load_rows would starve); this forces a reload when data is older than
  # REFRESH while keeping the ~34ms `fleet agents` RPC off every keypress
  # (≤1 RPC/sec even under a mash). Nav itself never reloads — it only moves sel.
  if (( SECONDS - last_load >= REFRESH )); then
    load_rows                       # ROWS feed both the agents view AND the index's live-window set
    load_inbox_index                # GATE: stat-only no-op unless the inbox changed (or 30s TTL)
    [ "$MODE" = inbox ] && load_inbox
    last_load=$SECONDS
  fi
  render

  if [ -n "$PENDING" ]; then key="$PENDING"; PENDING=""        # handle stashed key first
  elif ! IFS= read -rsN1 -t "$REFRESH" key; then status=""; continue; fi   # timeout -> top reloads
  case "$key" in
    $'\e')  # arrow keys: ESC [ A/B  (also swallows focus \033[I/O harmlessly)
      IFS= read -rsN2 -t 0.01 rest || rest=''
      case "$rest" in
        '[A') nav_up ;;
        '[B') nav_down ;;
        '')   # bare Esc: leave the msg/triage view back to the agents list
          [ "$MODE" = inbox ] && { close_inbox_view; last_load=$SECONDS; } ;;
      esac
      drain_nav ;;
    k) nav_up; drain_nav ;;
    j) nav_down; drain_nav ;;
    g) nav_top; drain_nav ;;
    G) nav_bot; drain_nav ;;
    ' ')           # triage: toggle the marked-set on the cursor row. Otherwise: leader.
      if [ "$MODE" = inbox ] && (( IALL )); then
        if (( IN > 0 )); then
          tf="${IROWS[$isel]}"
          if [ -n "${MARKED[$tf]:-}" ]; then unset 'MARKED[$tf]'; else MARKED["$tf"]=1; fi
        fi
        continue
      fi
      # leader: open the which-key popup (dash-local trigger). Bare Space is free
      # inside this TUI loop (it never types text), so this needs NO tmux root binding
      # — nvim/claude/shell Space stays untouched. Same popup as prefix+Space.
      "$FLEET_BIN" menu-popup 2>/dev/null   # fit-to-content frame; blocks until the popup closes
      clear; status="" ;;
    t)             # agents view: open the cross-agent message triage (all queued msgs)
      [ "$MODE" = agents ] || continue
      open_triage; last_load=$SECONDS ;;
    o)             # triage: toggle sort direction (oldest↑ <-> newest↓)
      [ "$MODE" = inbox ] && (( IALL )) || continue
      [ "$ISORT" = asc ] && ISORT=desc || ISORT=asc
      load_inbox; status="" ;;
    e)             # agents view: open the selected agent's (or orphan bucket's) messages
      [ "$MODE" = agents ] || continue
      open_msgs; last_load=$SECONDS ;;
    P)             # agents view: DRAIN — pop the global-oldest (FIFO) message to the
                   # orchestrator. The repeat-press home for draining several in a row
                   # (the leader-menu pop is one-press-one-pop). Same primitive as the
                   # menu's 'popmsg'; here the human is in the dashboard, not drafting.
      [ "$MODE" = agents ] || continue
      "$FLEET_BIN" inbox pop >/dev/null 2>&1
      load_rows; load_inbox_index force; last_load=$SECONDS ;;
    u)             # agents view: UNPOP — re-paste the most-recently-popped message back
                   # into the orchestrator (recover a pop whose draft was lost). Mirror of
                   # the leader-menu 'unpop'. Pure re-paste: no archive change, but refresh
                   # to keep the view honest.
      [ "$MODE" = agents ] || continue
      "$FLEET_BIN" inbox unpop >/dev/null 2>&1
      load_rows; load_inbox_index force; last_load=$SECONDS ;;
    c|a)           # msg view: mark all read (archive this scope's live msgs), then back
      [ "$MODE" = inbox ] || continue
      inbox_mark_all; close_inbox_view; last_load=$SECONDS ;;
    q)             # msg/triage view: back to the agents list (no-op in agents view)
      # bin/fleet cmd_dash_new/cmd_dash_triage inject 'q' to leave inbox before n/t — keep in sync.
      [ "$MODE" = inbox ] || continue
      close_inbox_view; last_load=$SECONDS ;;
    r) status=""; load_rows; load_inbox_index; [ "$MODE" = inbox ] && load_inbox; last_load=$SECONDS ;;   # manual refresh
    R) cleanup; exec "$SELF" "$SESS" ;;   # reload the dashboard with fresh code
    $'\n'|$'\r')   # inbox: pop to orchestrator. agents: jump (orphan row: open its msgs)
      if [ "$MODE" = inbox ]; then
        if (( IALL )); then triage_pop; last_load=$SECONDS; continue; fi   # triage: pop the marked set
        inbox_pop; load_inbox; last_load=$SECONDS; continue
      fi
      (( (ORPHAN_ROW && sel == N) || (SYSTEM_ROW && sel == N + ORPHAN_ROW) )) && { open_msgs; last_load=$SECONDS; continue; }
      (( N == 0 )) && continue
      win=$(field "$sel" 3)
      # A window parked in <sess>_hidden is not a member of $SESS, so a bare
      # select-window only changes the active window of the OWNING session and the
      # $SESS client never sees it. Re-derive the window's session (avoids threading
      # a session column through ROWS[]) and move it onto the bar first.
      wsess=$(tmux display -p -t "$win" '#{session_name}' 2>/dev/null)
      if [ -n "$wsess" ] && [ "$wsess" != "$SESS" ]; then
        tmux move-window -s "$win" -t "$SESS:" 2>/dev/null   # pull onto the bar + make navigable
        tmux set -w -t "$win" @fleet_hidden 0 2>/dev/null    # surfaced: re-enable notifications
      fi
      tmux select-window -t "$win" 2>/dev/null
      load_rows; last_load=$SECONDS ;;
    J)             # inbox: jump to the message's source agent (no-op in agents view)
      [ "$MODE" = inbox ] || continue
      inbox_jump; load_inbox; last_load=$SECONDS ;;
    h)             # hide the selected scratch agent back off the bar (into <sess>_hidden)
      [ "$MODE" = inbox ] && continue
      (( N == 0 )) && continue
      (( sel >= N )) && { status="orphans row — press e for messages"; continue; }
      win=$(field "$sel" 3); wname=$(field "$sel" 4)
      # Gate on the @fleet_hidden marker so ONLY scratch agents are hideable —
      # worker windows must never be yanked off the bar. (Unset on workers; 0/1 on
      # scratch depending on surfaced/parked.)
      if [ -z "$(tmux show -w -t "$win" -v @fleet_hidden 2>/dev/null)" ]; then
        status="$wname is not a scratch agent"; continue
      fi
      hidden="${SESS}_hidden"; ph=""
      if ! tmux has-session -t "=$hidden" 2>/dev/null; then
        # tmux cannot create an EMPTY session: spin a throwaway placeholder window,
        # move the scratch window in, then drop the placeholder. _hold is a plain
        # sh with no @agent_state, so it never flickers into the dashboard.
        ph=$(tmux new-session -d -P -F '#{window_id}' -s "$hidden" -n _hold sh 2>/dev/null)
        # set-option on a SESSION rejects the "=" prefix (unlike move-window/etc.),
        # so plain "$hidden" — exact anyway, no glob chars in a session name.
        tmux set -t "$hidden" @fleet_root "$(tmux show -t "$SESS" -v @fleet_root 2>/dev/null)" 2>/dev/null
      fi
      tmux move-window -s "$win" -t "=$hidden:" 2>/dev/null
      tmux set -w -t "$win" @fleet_hidden 1 2>/dev/null
      # LOAD-BEARING guard: do NOT drop the [ -n "$ph" ] test. Under a concurrent 'h'
      # the loser's new-session fails and $ph is EMPTY; `kill-window -t ""` falls
      # through to the CURRENT window and would kill a live scratch agent. The
      # loser's move-window still succeeds (the winner created the session).
      [ -n "$ph" ] && tmux kill-window -t "$ph" 2>/dev/null
      status="hid $wname"; load_rows; last_load=$SECONDS ;;
    m)             # permission-mode pick-list for the selected agent (sets status)
      [ "$MODE" = inbox ] && continue
      (( N == 0 )) && continue
      (( sel >= N )) && { status="orphans row — press e for messages"; continue; }
      label=$(field "$sel" 2); pane=$(field "$sel" 6)
      case "$(field "$sel" 1)" in
        starting|stale) status="$label still starting — no hook yet" ;;
        *) if harness_has_modes "$(harness_of "$pane")"; then pick_mode "$pane" "$label"; clear
           else status="$(harness_of "$pane") has no permission modes"; fi ;;
      esac
      load_rows; last_load=$SECONDS ;;
    s)             # send a message to selected agent
      [ "$MODE" = inbox ] && continue
      (( N == 0 )) && continue
      (( sel >= N )) && { status="orphans row — press e for messages"; continue; }
      label=$(field "$sel" 2)
      msg=$(ask "send to $label> "); clear   # repaint: read -e may have scrolled
      [ -n "$msg" ] && { "$FLEET_BIN" send "$label" "$msg" >/dev/null 2>&1 \
        && status="sent → $label" || status="send failed → $label"; }
      load_rows; last_load=$SECONDS ;;
    n)             # spawn a new agent via the in-box form (sets status)
      # bin/fleet cmd_dash_new injects this key for the leader 'new' action — keep in sync.
      [ "$MODE" = inbox ] && continue
      new_agent_form; clear; load_rows; last_load=$SECONDS ;;
    d)             # close/teardown the selected agent (confirm popup)
      [ "$MODE" = inbox ] && continue
      (( N == 0 )) && continue
      (( sel >= N )) && { status="orphans row — press e for messages"; continue; }
      label=$(field "$sel" 2); win=$(field "$sel" 3); pane=$(field "$sel" 6)
      dir=$(tmux display -p -t "$pane" '#{pane_current_path}' 2>/dev/null)
      confirm_teardown "$label" "$win" "$pane" "$dir"; clear; load_rows; last_load=$SECONDS ;;
    v)             # view the selected agent's git diff in a popup pager
      [ "$MODE" = inbox ] && continue
      (( N == 0 )) && continue
      (( sel >= N )) && { status="orphans row — press e for messages"; continue; }
      label=$(field "$sel" 2); pane=$(field "$sel" 6)
      dir=$(tmux display -p -t "$pane" '#{pane_current_path}' 2>/dev/null)
      view_diff "$dir" "$label"; clear ;;
    *) : ;;        # ignore everything else (q only backs out of the msg view)
  esac
done
