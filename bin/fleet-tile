#!/usr/bin/env bash
# fleet-tile <agent_pane_id> — read-only live view of an agent pane.
# Polls `tmux capture-pane` (~1s). pipe-pane is NOT used on purpose: raw
# escape-code streams from full-screen TUIs (nvim, claude REPL) render as
# garbage in a different-sized tile; capture-pane gives clean rendered text.
# For nvim panes the claude split is the rightmost ~30% — clip to it.

set -u
pane="${1:-}"
[ -n "$pane" ] || { echo "usage: fleet-tile <pane_id>"; exit 1; }

clip_pct="${FLEET_TILE_CLIP:-32}"   # % of columns kept from the right for nvim panes

state_glyph() {
  case "$1" in
    working) printf '\033[34m● working\033[0m' ;;
    blocked) printf '\033[31m● BLOCKED\033[0m' ;;
    idle)    printf '\033[32m● idle\033[0m' ;;
    *)       printf '\033[90m○ no agent\033[0m' ;;
  esac
}

while :; do
  if ! info=$(tmux display -p -t "$pane" \
      '#{pane_current_command}\t#{pane_current_path}\t#{pane_width}' 2>/dev/null); then
    clear
    echo "agent pane $pane gone — tile exiting"
    sleep 2
    exit 0
  fi
  cmd=${info%%$'\t'*}; rest=${info#*$'\t'}
  path=${rest%%$'\t'*}; src_width=${rest##*$'\t'}
  state=$(tmux show -w -t "$pane" -v @agent_state 2>/dev/null || true)

  rows=$(tput lines); cols=$(tput cols)
  body_rows=$((rows - 2))

  label=$(echo "$path" | awk -F/ '{n=NF; if (n>=2) print $(n-1)"/"$n; else print $0}')

  capture=$(tmux capture-pane -p -e -t "$pane" 2>/dev/null || true)
  if [ "$cmd" = "nvim" ] || [ "$cmd" = "vi" ] || [ "$cmd" = "vim" ]; then
    # keep rightmost clip_pct% of columns (the claude split)
    keep=$((src_width * clip_pct / 100))
    start=$((src_width - keep + 1))
    # strip escape sequences first — column-cutting colored text mid-sequence
    # corrupts the terminal; tile stays monochrome for nvim panes.
    capture=$(printf '%s\n' "$capture" \
      | sed -e 's/\x1b\[[0-9;]*[a-zA-Z]//g' -e 's/\x1b\][^\x07]*\x07//g' \
      | cut -c"$start"- )
  fi

  out=$(printf '%s\n' "$capture" | tail -n "$body_rows" | cut -c1-"$cols")

  clear
  printf '%b  \033[1m%s\033[0m\n' "$(state_glyph "$state")" "$label"
  printf '%s\n' "──────────────────────────────────────────────" | cut -c1-"$cols"
  printf '%s\n' "$out"
  sleep 1
done
