#!/usr/bin/env python3
"""fleetd — tiny agent-state daemon for the fleet tmux agent manager.

Listens on $XDG_RUNTIME_DIR/fleet.sock (ndjson request/response).
Tracks Claude Code agent state per tmux pane, mirrors it into tmux
user options (@agent_state/@agent_since/@agent_glyph), and sends
desktop notifications when an unfocused agent blocks or finishes.

Stdlib only. Every tmux/notify failure is swallowed — fleetd must
never take anything else down with it.
"""

import fcntl
import json
import os
import selectors
import socket
import re
import subprocess
import sys
import time

RUNTIME_DIR = os.environ.get("XDG_RUNTIME_DIR") or f"/run/user/{os.getuid()}"
SOCKET_PATH = os.path.join(RUNTIME_DIR, "fleet.sock")

SEVERITY = {"blocked": 3, "working": 2, "idle": 1}
GLYPH_COLOR = {"working": "colour4", "blocked": "colour1", "idle": "colour2"}

SWEEP_INTERVAL = 60
SCRAPE_INTERVAL = 2          # how often hookless harnesses (omp, …) are polled
NOTIFY_COOLDOWN = 30
IDLE_FLAP_GUARD = 2.0
# A window stamped @fleet_harness that has never reported a hook is surfaced as a
# synthetic placeholder so a freshly-spawned agent shows immediately and a
# hook-broken agent never goes invisible. Recently-active -> "starting"
# (transient), idle past this grace -> "stale" (a loud "no hook arrived" signal).
SYNTH_STALE_AFTER = 45


def dispatch_pill(root):
    # Precomputed colored status pill for a project's dispatch mode (+ hook
    # marker). Mirror of bin/fleet's dispatch_pill() — KEEP THE TWO IN SYNC.
    # Fail-silent: missing/garbage mode file -> 'sigil'; missing settings -> off.
    mode = "sigil"
    try:
        with open(os.path.join(root, ".fleet", "dispatch-mode")) as f:
            m = f.read().strip()
        if m in ("all", "off", "sigil"):
            mode = m
    except Exception:
        pass
    dwired = False
    try:
        with open(os.path.join(root, ".claude", "settings.json")) as f:
            dwired = "fleet-dispatch" in f.read()
    except Exception:
        pass
    label, col = {"all": ("ALL", "fg=yellow,bold"),
                  "off": ("off", "fg=colour244")}.get(mode, ("sig", "fg=cyan"))
    mark = "#[fg=red,bold]!" if mode in ("sigil", "all") and not dwired else ""
    return "#[%s]d:%s%s#[default]" % (col, label, mark)


def tmux(*args):
    try:
        out = subprocess.run(
            ("tmux",) + args, capture_output=True, text=True, timeout=5
        )
        return out.stdout if out.returncode == 0 else None
    except Exception:
        return None


class Fleet:
    def __init__(self):
        # panes[pane_id][session_id] = {state, since, seq, cwd}
        self.panes = {}
        self.effective = {}  # pane_id -> state currently mirrored to tmux
        self.last_notify = {}  # (pane_id, state) -> ts
        self.last_working = {}  # pane_id -> ts of last working report
        self.last_sweep = 0.0
        self.last_scrape = 0.0

    # ---- state ingestion -------------------------------------------------

    def report(self, p):
        pane, sid = p.get("pane_id"), p.get("session_id") or "_"
        state, seq = p.get("state"), p.get("seq") or 0
        if not pane or state not in SEVERITY:
            return {"error": "bad params"}
        sessions = self.panes.setdefault(pane, {})
        cur = sessions.get(sid)
        if cur and seq <= cur["seq"]:
            return {"dropped": "stale seq"}
        sessions[sid] = {
            "state": state,
            "since": time.time(),
            "seq": seq,
            "cwd": p.get("cwd") or (cur or {}).get("cwd"),
        }
        if state == "working":
            self.last_working[pane] = time.time()
        self.refresh_pane(pane)
        return {"ok": True}

    def release(self, p):
        pane, sid = p.get("pane_id"), p.get("session_id") or "_"
        sessions = self.panes.get(pane)
        if sessions:
            sessions.pop(sid, None)
            if not sessions:
                self.panes.pop(pane, None)
        self.refresh_pane(pane)
        return {"ok": True}

    # ---- effective state + tmux mirroring --------------------------------

    def pane_state(self, pane):
        sessions = self.panes.get(pane) or {}
        if not sessions:
            return None
        return max(sessions.values(), key=lambda s: SEVERITY[s["state"]])

    def refresh_pane(self, pane):
        cur = self.pane_state(pane)
        prev = self.effective.get(pane)
        if cur is None:
            self.effective.pop(pane, None)
            tmux("set", "-w", "-t", pane, "-u", "@agent_state")
            tmux("set", "-w", "-t", pane, "-u", "@agent_since")
            tmux("set", "-w", "-t", pane, "-u", "@agent_glyph")
        else:
            state = cur["state"]
            self.effective[pane] = state
            tmux("set", "-w", "-t", pane, "@agent_state", state)
            tmux("set", "-w", "-t", pane, "@agent_since", str(int(cur["since"])))
            tmux(
                "set", "-w", "-t", pane, "@agent_glyph",
                f"#[fg={GLYPH_COLOR[state]},bg=default]●#[default]",
            )
            if prev == "working" and state in ("blocked", "idle"):
                self.maybe_notify(pane, state, cur)
        tmux("refresh-client", "-S")

    # ---- notifications ----------------------------------------------------

    def maybe_notify(self, pane, state, cur):
        now = time.time()
        if state == "idle" and now - self.last_working.get(pane, 0) < IDLE_FLAP_GUARD:
            return
        key = (pane, state)
        if now - self.last_notify.get(key, 0) < NOTIFY_COOLDOWN:
            return
        info = tmux(
            "display", "-p", "-t", pane,
            "#{window_active}#{session_attached}\t#{@fleet_hidden}",
        )
        if info is not None:
            focus, _, hidden = info.strip().partition("\t")
            if focus.startswith("11"):
                return  # window active in an attached session — user is looking at it
            # Parked/hidden agents (scratch helpers, dispatch sub-orchs) live in a
            # detached <sess>_hidden session — never focused, so they would notify on
            # EVERY block/finish. They're an internal mechanism the user usually
            # can't act on; stay quiet. Surfaced scratch (move-in sets @fleet_hidden
            # 0) and all main/worker agents (unset) still notify.
            if hidden not in ("", "0"):
                return
        self.last_notify[key] = now
        label = agent_label(cur.get("cwd") or pane)
        title, urgency = (
            ("Agent blocked", "low") if state == "blocked" else ("Agent done", "normal")
        )
        body = f"{label} — " + (
            "waiting for permission/input" if state == "blocked" else "turn finished"
        )
        try:
            subprocess.run(
                ["notify-send", "-a", "fleet", "-u", urgency, title, body],
                timeout=5, capture_output=True,
            )
        except Exception:
            pass

    # ---- liveness ----------------------------------------------------------

    def sweep(self, force=False):
        now = time.time()
        if not force and now - self.last_sweep < SWEEP_INTERVAL:
            return
        self.last_sweep = now
        out = tmux("list-panes", "-a", "-F", "#{pane_id}")
        if out is None:
            # tmux server gone: pane ids reset across restarts — drop everything
            if self.panes:
                self.panes.clear()
                self.effective.clear()
            return
        alive = set(out.split())
        for pane in [p for p in self.panes if p not in alive]:
            self.panes.pop(pane, None)
            self.effective.pop(pane, None)
        if self.panes:
            self.heal_status_format()

    def scrape_harnesses(self, force=False):
        # Hookless harnesses (omp, …) can't report via Claude-style hooks. fleet
        # stamps @fleet_state_src=scrape + @fleet_busy_re onto their windows; we
        # poll capture-pane and infer working/idle from whether the busy pattern
        # (e.g. the "esc to interrupt" hint) is on screen. fleetd stays harness-
        # agnostic — all harness knowledge lives in the window options.
        now = time.time()
        if not force and now - self.last_scrape < SCRAPE_INTERVAL:
            return
        self.last_scrape = now
        out = tmux(
            "list-panes", "-a", "-F",
            "#{pane_id}\t#{@fleet_state_src}\t#{@fleet_busy_re}\t#{pane_current_path}",
        )
        if not out:
            return
        for line in out.splitlines():
            parts = line.split("\t")
            if len(parts) != 4:
                continue
            pane, src, busy_re, path = parts
            if src != "scrape" or not busy_re:
                continue
            cap = tmux("capture-pane", "-p", "-t", pane)
            if cap is None:
                continue
            try:
                working = re.search(busy_re, cap, re.IGNORECASE) is not None
            except re.error:
                working = False
            state = "working" if working else "idle"
            # Only emit on change to avoid resetting "since" every tick.
            cur = (self.panes.get(pane) or {}).get("_scrape")
            if cur and cur["state"] == state:
                continue
            self.report({
                "pane_id": pane, "session_id": "_scrape", "state": state,
                "seq": time.time_ns(), "cwd": path,
            })

    def heal_status_format(self):
        # Theme switches regenerate omarchy's pill formats and drop our glyph;
        # re-append it to the runtime global value (config files untouched).
        for opt in ("window-status-format", "window-status-current-format"):
            fmt = tmux("show", "-g", "-v", opt)
            if fmt is None:
                continue
            fmt = fmt.rstrip("\n")
            if fmt and "@agent_glyph" not in fmt:
                tmux("set", "-g", opt, fmt + "#{?@agent_glyph, #{@agent_glyph},}")
        # status-left ship glyph used to be re-healed off the (now-deleted) inbox
        # poll; ride the same theme-switch healing as the window-status glyphs.
        self.heal_status_left()

    def heal_status_left(self):
        # Mirror the status-left fleet icon (inject_status_format in `bin/fleet`).
        # Theme switches wipe status-left too; re-inject the @fleet_root-gated
        # ship ( nf-fa-ship U+F21A) INSIDE the session-name pill, right before
        # #S, so the marker survives a theme switch until the next `fleet up`.
        # Idempotent: skip if the ship is already present; strip any legacy
        # outside-the-pill 󰭹 prepend; fail-silent if #S is absent.
        ship = ""  # nf-fa-ship U+F21A
        left = tmux("show", "-g", "-v", "status-left")
        if left is not None:
            left = left.rstrip("\n")
            new = left.replace("#{?@fleet_root,\U000f0b79 ,}", "")  # drop legacy prepend
            if ship not in new and "#S" in new:
                new = new.replace("#S", "#{?@fleet_root," + ship + " ,}#S", 1)
            # Dispatch-mode pill token: inject right after #S, gated per-session
            # on @fleet_dispatch (mirror of inject_status_format in `bin/fleet`).
            if "@fleet_dispatch" not in new and "#S" in new:
                new = new.replace("#S", "#S#{?@fleet_dispatch, #{@fleet_dispatch},}", 1)
            if new != left:
                tmux("set", "-g", "status-left", new)
        self.heal_dispatch_pills()

    def heal_dispatch_pills(self):
        # Re-stamp each fleet session's @fleet_dispatch pill from its mode file so
        # a hand-edited .fleet/dispatch-mode (or a wiped option) converges on the
        # ~60s sweep. Per-session @fleet_root carries the project root.
        out = tmux("list-sessions", "-F", "#{session_name}\t#{@fleet_root}")
        if not out:
            return
        for line in out.splitlines():
            parts = line.split("\t")
            if len(parts) != 2 or not parts[1]:
                continue
            sess, root = parts
            tmux("set", "-t", sess, "@fleet_dispatch", dispatch_pill(root))

    # ---- queries -----------------------------------------------------------

    def list_agents(self):
        self.sweep(force=True)
        # One tmux round-trip; also pulls @fleet_harness + pane_active +
        # window_activity so we can surface stamped-but-unreported windows below.
        out = tmux(
            "list-panes", "-a", "-F",
            "#{pane_id}\t#{window_id}\t#{session_name}\t#{window_name}"
            "\t#{pane_current_path}\t#{pane_active}\t#{@fleet_harness}"
            "\t#{window_activity}",
        ) or ""
        meta = {}
        for line in out.splitlines():
            parts = line.split("\t")
            if len(parts) == 8:
                meta[parts[0]] = parts[1:]
        agents = []
        covered = set()  # window_ids that already have a real reported pane
        for pane, sessions in self.panes.items():
            cur = self.pane_state(pane)
            if not cur:
                continue
            m = meta.get(pane)
            window_id, session, window_name, path = (m[0], m[1], m[2], m[3]) if m else ("", "", "", "")
            if window_id:
                covered.add(window_id)
            agents.append(
                {
                    "pane_id": pane,
                    "window_id": window_id,
                    "session": session,
                    "window_name": window_name,
                    "state": cur["state"],
                    "since": cur["since"],
                    "cwd": cur.get("cwd") or path,
                }
            )

        # Synthetic pass: any window stamped @fleet_harness with no reported pane
        # gets one placeholder row, keyed to a real agent pane so the dashboard
        # (which drops empty-pane rows) and `fleet send`/mode can target it. The
        # orchestrator's own "main" window is excluded — it reports on its own and
        # listing itself as an agent is confusing.
        now = time.time()
        synth = {}  # window_id -> chosen meta row
        for pane, m in meta.items():
            window_id, session, window_name, path, pane_active, harness, activity = m
            if not harness or not window_id or window_id in covered:
                continue
            if window_name == "main":
                continue
            prev = synth.get(window_id)
            # prefer the active pane as the window's representative agent pane
            if prev is None or (pane_active == "1" and prev[5] != "1"):
                synth[window_id] = (pane,) + tuple(m)
        for window_id, row in synth.items():
            pane, _wid, session, window_name, path, _pa, harness, activity = row
            try:
                since = float(activity)
            except (TypeError, ValueError):
                since = now
            state = "stale" if now - since > SYNTH_STALE_AFTER else "starting"
            agents.append(
                {
                    "pane_id": pane,
                    "window_id": window_id,
                    "session": session,
                    "window_name": window_name,
                    "state": state,
                    "since": since,
                    "cwd": path,
                }
            )
        return {"agents": agents}


def agent_label(cwd):
    parts = [p for p in cwd.split("/") if p]
    return "/".join(parts[-2:]) if len(parts) >= 2 else cwd


# ---- server loop ------------------------------------------------------------


def handle_request(fleet, line):
    try:
        req = json.loads(line)
    except Exception:
        return {"ok": False, "error": "bad json"}
    method = req.get("method", "")
    params = req.get("params") or {}
    rid = req.get("id")
    if method in ("agent.report", "pane.report_agent"):
        result = fleet.report(params)
    elif method in ("agent.release", "pane.release_agent"):
        result = fleet.release(params)
    elif method == "fleet.list":
        result = fleet.list_agents()
    elif method == "fleet.ping":
        result = {"pong": True}
    else:
        return {"id": rid, "ok": False, "error": f"unknown method {method}"}
    return {"id": rid, "ok": True, "result": result}


def main():
    # Single-instance guard: hold an exclusive advisory lock for our lifetime so
    # a second fleetd can't unlink the live socket out from under the first and
    # leave two daemons fighting over it. The fd is intentionally never closed.
    lock_fd = os.open(SOCKET_PATH + ".lock", os.O_CREAT | os.O_RDWR, 0o600)
    try:
        fcntl.flock(lock_fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
    except OSError:
        sys.stderr.write("fleetd: another instance is already running — exiting\n")
        return
    try:
        os.unlink(SOCKET_PATH)
    except FileNotFoundError:
        pass
    server = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    server.bind(SOCKET_PATH)
    os.chmod(SOCKET_PATH, 0o600)
    server.listen(16)
    server.setblocking(False)

    sel = selectors.DefaultSelector()
    sel.register(server, selectors.EVENT_READ, None)
    fleet = Fleet()
    buffers = {}

    while True:
        for key, _ in sel.select(timeout=SCRAPE_INTERVAL):
            if key.data is None:
                try:
                    conn, _ = server.accept()
                except OSError:
                    continue
                conn.setblocking(False)
                sel.register(conn, selectors.EVENT_READ, "client")
                buffers[conn] = b""
            else:
                conn = key.fileobj
                try:
                    data = conn.recv(65536)
                except OSError:
                    data = b""
                if not data:
                    sel.unregister(conn)
                    buffers.pop(conn, None)
                    conn.close()
                    continue
                buffers[conn] += data
                while b"\n" in buffers[conn]:
                    line, buffers[conn] = buffers[conn].split(b"\n", 1)
                    if not line.strip():
                        continue
                    resp = handle_request(fleet, line)
                    try:
                        conn.sendall((json.dumps(resp) + "\n").encode())
                    except OSError:
                        pass
        fleet.scrape_harnesses()
        fleet.sweep()


if __name__ == "__main__":
    main()
