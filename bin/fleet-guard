#!/bin/sh
# fleet-guard — Claude Code PreToolUse hook. Two protections:
#  (1) ALWAYS-ON: a worker agent (FLEET_ROLE=worker) may not `git merge` or
#      `git push`. Integration is the ORCHESTRATOR's job — it reviews returned
#      diffs and merges/pushes. A worker that self-merges into main bypasses
#      review (and worktree isolation only stops it from *checking out* main, not
#      from `git push . HEAD:main` or merging via another worktree). This block is
#      independent of the opt-in marker below.
#  (2) OPT-IN (`fleet guard on`): ask/deny before edits to protected paths
#      (tests, CI configs, lockfiles) so agents can't quietly delete tests or
#      rewrite CI to make things pass.
# Fail-silent and fast — on any doubt, allow.
set -eu

CFG="${XDG_CONFIG_HOME:-$HOME/.config}/fleet"
command -v python3 >/dev/null 2>&1 || exit 0

in="$(cat 2>/dev/null || true)"
[ -n "$in" ] || exit 0

# The guard-on marker gates protection (2) only; protection (1) is always active.
GUARD_ON=0; [ -f "$CFG/guard-on" ] && GUARD_ON=1

FLEET_GUARD_INPUT="$in" FLEET_GUARD_CFG="$CFG" FLEET_GUARD_ON="$GUARD_ON" python3 - <<'PY' || exit 0
import json, os, fnmatch, sys, re, shlex

try:
    h = json.loads(os.environ["FLEET_GUARD_INPUT"])
except Exception:
    sys.exit(0)

tool = str(h.get("tool_name") or "")
role = os.environ.get("FLEET_ROLE", "")

def deny(reason):
    print(json.dumps({"hookSpecificOutput": {
        "hookEventName": "PreToolUse",
        "permissionDecision": "deny",
        "permissionDecisionReason": reason,
    }}))
    sys.exit(0)

# --- (1) ALWAYS-ON: workers must not merge or push -------------------------------
# Find `git merge`/`git push` only when `git` is the COMMAND WORD of a statement,
# not when the words "git merge" merely appear inside some other command's quoted
# argument (e.g. `fleet send x "... do the git merge now"`). The old scan split on
# separators with a naive `seg.split()` and matched `git` ANYWHERE in the token
# list, so any quoted body containing "git merge"/"git push" was falsely denied.
#
# The fix tokenizes QUOTE-AWARE *once* per line (shlex), so a quoted "git push"
# stays a single token and never matches; it then segments on the shell operator
# tokens (; & | && ||) and takes the first non-`VAR=value` token of each run as the
# command word. A separator INSIDE a quote can no longer desync the parse (the bug
# a split-before-parse scheme reintroduces). Newlines are real statement separators
# in the common (unquoted) case, so we split on them first; a newline buried inside
# a quoted string is data, not a command, so splitting it is harmless.
#
# fail-CLOSED for THIS block (the inverse of the guard's general "on any doubt,
# allow"): the always-on merge/push floor is an integrity control, so on an
# unbalanced-quote parse error we fall back to the conservative whitespace scan —
# which over-denies but never lets a real `git merge`/`git push` (e.g. a trailing
# `"`) slip past. A false deny on malformed input is recoverable (rephrase); a
# false allow merges unreviewed code into main. Opt-out: a worker spawned with
# `fleet new --self-merge` carries FLEET_SELF_MERGE=1 and is exempt.
#
# Known accepted gaps (pre-existing; this block is a speed-bump against ACCIDENTAL
# self-merge, not an airtight sandbox): `sh -c 'git push'`, `eval`, aliases, and
# wrapper scripts all have a non-`git` command word and are not caught.
ENV_ASSIGN = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*=")

def is_op(tok):  # an operator token is made solely of shell metacharacters
    return tok != "" and all(c in "();<>|&" for c in tok)

def git_sub_in_run(run):  # subcommand iff `git` is this run's command word, else None
    k = 0
    while k < len(run) and ENV_ASSIGN.match(run[k]):   # skip FOO=bar prefixes
        k += 1
    if k >= len(run) or run[k] != "git":
        return None
    j = k + 1
    while j < len(run) and run[j].startswith("-"):     # skip git global opts
        if run[j] in ("-C", "-c") and j + 1 < len(run):
            j += 2
        else:
            j += 1
    return run[j] if j < len(run) else ""

def git_subcommands(line):  # all command-word git subcommands on one line
    try:
        lex = shlex.shlex(line, posix=True, punctuation_chars=True)
        lex.whitespace_split = True
        toks = list(lex)
    except ValueError:
        toks = line.split()            # fall CLOSED: conservative whitespace scan
    subs, run = [], []
    for tok in toks + ["\n"]:          # sentinel flushes the final run
        if tok == "\n" or is_op(tok):
            s = git_sub_in_run(run)
            if s is not None:
                subs.append(s)
            run = []
        else:
            run.append(tok)
    return subs

if tool == "Bash" and role == "worker" and os.environ.get("FLEET_SELF_MERGE") != "1":
    cmd = str((h.get("tool_input") or {}).get("command") or "")
    for line in cmd.split("\n"):
        for sub in git_subcommands(line):
            if sub in ("merge", "push"):
                deny("fleet-guard: workers must not run 'git %s'. Integration is the "
                     "orchestrator's job — it reviews your diff and merges/pushes. "
                     "Commit on your own branch and run 'fleet ready' to signal done." % sub)

# --- (2) OPT-IN: protected-path edits (tests / CI / lockfiles) -------------------
if os.environ.get("FLEET_GUARD_ON") != "1":
    sys.exit(0)
if tool not in ("Edit", "Write", "MultiEdit", "NotebookEdit"):
    sys.exit(0)
path = str((h.get("tool_input") or {}).get("file_path") or "")
if not path:
    sys.exit(0)
base = os.path.basename(path)

# Built-in defaults: test files, CI configs, lockfiles. A leading '!' on a
# pattern means hard-deny instead of ask.
patterns = [
    "*_test.go", "*_test.py", "test_*.py", "*.test.*", "*.spec.*",
    "*Tests.cs", "*Test.cs", "*Tests.java", "*Test.java",
    "*/tests/*", "*/test/*", "*/__tests__/*", "*/spec/*",
    ".github/workflows/*", "*/.github/workflows/*", "*.yml.ci", "azure-pipelines*.yml",
    "*.lock", "package-lock.json", "yarn.lock", "pnpm-lock.yaml", "Cargo.lock",
    "Gemfile.lock", "poetry.lock", "composer.lock", "go.sum",
]

# Per-repo + global overrides: <cwd ancestor>/.fleet/protected and $CFG/protected.
def load(p):
    try:
        with open(p, encoding="utf-8") as f:
            return [l.strip() for l in f if l.strip() and not l.startswith("#")]
    except Exception:
        return []

cwd = str(h.get("cwd") or "")
extra = []
d = cwd
for _ in range(40):
    extra += load(os.path.join(d, ".fleet", "protected"))
    nd = os.path.dirname(d)
    if nd == d:
        break
    d = nd
extra += load(os.path.join(os.environ["FLEET_GUARD_CFG"], "protected"))
patterns += extra

def matches(pat, path, base):
    pat = pat.strip()
    return fnmatch.fnmatch(path, pat) or fnmatch.fnmatch(base, pat) \
        or fnmatch.fnmatch(path, "*/" + pat)

deny_flag = False
hit = None
# Evaluate ALL patterns, not just the first match: a user's bang-prefixed hard
# deny must win over a built-in soft-ask regardless of list order. A hard deny is
# terminal (stop early); a soft match is only provisional — keep scanning in case
# a later pattern denies.
for pat in patterns:
    hard = pat.startswith("!")
    p = pat[1:] if hard else pat
    if matches(p, path, base):
        if hard:
            deny_flag = True
            hit = p
            break
        if hit is None:
            hit = p

if hit is None:
    sys.exit(0)

decision = "deny" if deny_flag else "ask"
reason = ("fleet-guard: %s is protected (%s). %s"
          % (base, hit,
             "Edit blocked — remove it from .fleet/protected to allow."
             if deny_flag else "Confirm this change is intended."))
print(json.dumps({"hookSpecificOutput": {
    "hookEventName": "PreToolUse",
    "permissionDecision": decision,
    "permissionDecisionReason": reason,
}}))
PY
exit 0
