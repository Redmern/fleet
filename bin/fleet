#!/usr/bin/env bash
# fleet — standalone agent fleet manager for tmux + nvim + Claude Code.
# Subcommands: up new ls pick send main status doctor
# Design rule: fleet only *calls* tmux/nvim/git/claude. Every integration is
# fail-silent: if the daemon, tmux, or nvim plumbing is missing, each command
# degrades to a working subset instead of erroring out.

set -u

FLEET_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
SOCK="$RUNTIME_DIR/fleet.sock"
CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/fleet"
HARNESS_DIR="$FLEET_DIR/harness.d"

die() { echo "fleet: $*" >&2; exit 1; }

# ---- harness adapters --------------------------------------------------------
# A "harness" is the agent CLI fleet drives (claude, omp, …). Each is described
# by a harness.d/<name>.conf sourced into H_* vars. Add a harness = add a file.

harness_select() { # resolve the active harness name (precedence: flag handled by
  # caller, then $FLEET_HARNESS, project .fleet/harness, config, default claude)
  if [ -n "${FLEET_HARNESS:-}" ]; then echo "$FLEET_HARNESS"; return; fi
  local root; root=$(fleet_root 2>/dev/null)
  if [ -n "$root" ] && [ -f "$root/.fleet/harness" ]; then
    local h; h=$(head -1 "$root/.fleet/harness" 2>/dev/null | tr -d '[:space:]')
    [ -n "$h" ] && { echo "$h"; return; }
  fi
  if [ -f "$CONF_DIR/config" ]; then
    local h; h=$(grep -E '^harness=' "$CONF_DIR/config" 2>/dev/null | tail -1 | cut -d= -f2 | tr -d '[:space:]')
    [ -n "$h" ] && { echo "$h"; return; }
  fi
  echo claude
}

harness_list() { # names of installed harness adapters
  for f in "$HARNESS_DIR"/*.conf; do [ -e "$f" ] && basename "$f" .conf; done
}

harness_load() { # populate H_* for <name>; defaults first, then the conf overrides
  local name="${1:-claude}"
  H_NAME="$name"
  H_BIN="$name"; H_PROMPT_FLAG=""; H_TERM_MATCH="$name"; H_NVIM_PLUGIN=0
  H_STATE_SRC="scrape"; H_MODE_KEYS=""; H_MODE_LIST=""; H_COST_KIND=""
  H_GUARD_KIND="none"; H_BUSY_RE=""
  local conf="$HARNESS_DIR/$name.conf"
  [ -f "$conf" ] || die "unknown harness '$name' (have: $(harness_list | tr '\n' ' '))"
  # shellcheck disable=SC1090
  . "$conf"
}

harness_bin() { # first launchable binary from H_BIN candidates
  local c; for c in $H_BIN; do command -v "$c" >/dev/null 2>&1 && { command -v "$c"; return 0; }; done
  return 1
}

# ---- daemon RPC --------------------------------------------------------------

rpc() { # rpc <method> [params-json]  → result json on stdout, rc 1 if daemon down
  [ -S "$SOCK" ] || return 1
  python3 - "$SOCK" "$1" "${2:-{}}" <<'PY' 2>/dev/null
import json, socket, sys
sock_path, method, params = sys.argv[1], sys.argv[2], json.loads(sys.argv[3])
c = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
c.settimeout(2)
c.connect(sock_path)
c.sendall((json.dumps({"id": "cli", "method": method, "params": params}) + "\n").encode())
buf = b""
while b"\n" not in buf:
    chunk = c.recv(65536)
    if not chunk:
        break
    buf += chunk
resp = json.loads(buf.decode().splitlines()[0])
if not resp.get("ok"):
    sys.exit(1)
print(json.dumps(resp.get("result", {})))
PY
}

# ---- project resolution -------------------------------------------------------

session_name() { # FLEET_SESSION overrides (used by `fleet up` cross-session)
  [ -n "${FLEET_SESSION:-}" ] && { echo "$FLEET_SESSION"; return 0; }
  tmux display -p '#{session_name}' 2>/dev/null
}

fleet_root() { # project root for the current session
  local s; s=$(session_name) || return 1
  local r; r=$(tmux show -t "$s" -v @fleet_root 2>/dev/null)
  [ -n "$r" ] && { echo "$r"; return 0; }
  [ -n "${FLEET_ROOT:-}" ] && { echo "$FLEET_ROOT"; return 0; }
  pwd
}

discover_repos() { # discover_repos <root> → "name<TAB>path" lines
  local root="$1" d sub
  for d in "$root"/*/; do
    [ -d "$d" ] || continue
    d="${d%/}"
    if [ -e "$d/.git" ]; then
      printf '%s\t%s\n' "$(basename "$d")" "$d"
    else
      # worktree container: a dir whose subdirs are git checkouts
      for sub in "$d"/*/; do
        [ -e "${sub%/}/.git" ] && { printf '%s\t%s\n' "$(basename "$d")" "$d"; break; }
      done
    fi
  done
}

resolve_repo() { # resolve_repo <root> <name> → path
  local root="$1" want="$2" line name path match=""
  while IFS=$'\t' read -r name path; do
    [ "${name,,}" = "${want,,}" ] && { echo "$path"; return 0; }
    case "${name,,}" in *"${want,,}"*) match="$path" ;; esac
  done < <(discover_repos "$root")
  [ -n "$match" ] && { echo "$match"; return 0; }
  return 1
}

agent_label() { # last two path components
  local p="$1"; p="${p%/}"
  local b="${p##*/}" parent="${p%/*}"
  echo "${parent##*/}/$b"
}

# ---- ls -----------------------------------------------------------------------

agents_tsv() { # state<TAB>label<TAB>session<TAB>window_id<TAB>window_name<TAB>since<TAB>pane_id
  local json
  if json=$(rpc fleet.list); then
    python3 - "$json" <<'PY'
import json, sys, time
for a in json.loads(sys.argv[1]).get("agents", []):
    cwd = (a.get("cwd") or "").rstrip("/")
    label = "/".join(cwd.split("/")[-2:]) if cwd else a.get("window_name", "?")
    age = int(time.time() - a.get("since", time.time()))
    print("\t".join([a.get("state","?"), label, a.get("session",""),
                     a.get("window_id",""), a.get("window_name",""),
                     f"{age//60}m{age%60:02d}s", a.get("pane_id",""), str(age)]))
PY
  else
    # daemon down: fall back to window options mirrored earlier (may be stale)
    tmux list-panes -a -F $'#{?@agent_state,#{@agent_state}\t#{pane_current_path}\t#{session_name}\t#{window_id}\t#{window_name}\t-\t#{pane_id},}' 2>/dev/null \
      | sed '/^$/d' \
      | while IFS=$'\t' read -r st path rest; do
          printf '%s\t%s\t%s\n' "$st" "$(agent_label "$path")" "$rest"
        done
  fi
}

cmd_ls() {
  local out; out=$(agents_tsv)
  [ -n "$out" ] || { echo "no agents registered"; return 0; }
  printf 'STATE\tAGENT\tWINDOW\tIN-STATE\n'
  echo "$out" | sort -t$'\t' -k1,1 | awk -F'\t' '{printf "%s\t%s\t%s:%s\t%s\n", $1, $2, $3, $5, $6}'
}

# ---- pick ---------------------------------------------------------------------

cmd_pick() {
  command -v fzf >/dev/null || die "fzf not installed"
  local rows
  rows=$(agents_tsv | sort -t$'\t' -k1,1 | awk -F'\t' '
    $1=="blocked"{c="\033[31m"; o=0}
    $1=="idle"   {c="\033[32m"; o=1}
    $1=="working"{c="\033[34m"; o=2}
    {printf "%d\t%s\t%s\t%s● %-8s\033[0m %-40s %s:%s  %s\n", o, $3, $4, c, $1, $2, $3, $5, $6}' \
    | sort -n | cut -f2-)
  [ -n "$rows" ] || { echo "no agents to pick"; return 0; }
  local choice
  choice=$(echo "$rows" | fzf --ansi --delimiter='\t' --with-nth=3 \
            --no-sort --prompt='agent> ' --height=100% --border=rounded) || return 0
  local sess win
  sess=$(echo "$choice" | cut -f1)
  win=$(echo "$choice" | cut -f2)
  tmux switch-client -t "$sess" 2>/dev/null
  tmux select-window -t "$win" 2>/dev/null
}

# ---- repos / branches (used by the dashboard new-agent form) ------------------

cmd_harnesses() { harness_list; }   # installed harness adapter names (for the form)

cmd_repos() { # list discoverable repo names under the project root
  local root; root=$(fleet_root) || die "not inside tmux"
  discover_repos "$root" | cut -f1 | awk 'NF && !seen[$0]++'
}

repo_anchor() { # repo_base -> a dir git can run in (the repo, bare container, or a worktree)
  local repo_base="$1" is_bare sub
  is_bare=$(git -C "$repo_base" rev-parse --is-bare-repository 2>/dev/null)
  if [ -e "$repo_base/.git" ] && [ "$is_bare" != "true" ]; then echo "$repo_base"; return 0; fi
  [ "$is_bare" = "true" ] && { echo "$repo_base"; return 0; }
  for sub in "$repo_base"/*/; do [ -e "${sub%/}/.git" ] && { echo "${sub%/}"; return 0; }; done
  return 1
}

cmd_worktrees() { # list branches of <repo>'s existing worktrees (launch targets)
  local repo="${1:-}"; [ -n "$repo" ] || die "usage: fleet worktrees <repo>"
  local root; root=$(fleet_root) || die "not inside tmux"
  local repo_base; repo_base=$(resolve_repo "$root" "$repo") || die "repo '$repo' not found under $root"
  local anchor; anchor=$(repo_anchor "$repo_base") || return 0
  git -C "$anchor" worktree list --porcelain 2>/dev/null \
    | awk '/^branch /{sub("refs/heads/","",$2); print $2}' | awk 'NF && !seen[$0]++'
}

cmd_branches() { # list candidate base branches for <repo>, default branch first
  local repo="${1:-}"; [ -n "$repo" ] || die "usage: fleet branches <repo>"
  local root; root=$(fleet_root) || die "not inside tmux"
  local repo_base; repo_base=$(resolve_repo "$root" "$repo") || die "repo '$repo' not found under $root"
  local anchor; anchor=$(repo_anchor "$repo_base") || return 0
  local def; def=$(git -C "$anchor" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||')
  {
    [ -n "$def" ] && echo "$def"
    git -C "$anchor" for-each-ref --format='%(refname:short)' refs/remotes/origin 2>/dev/null | sed 's|^origin/||'
    git -C "$anchor" for-each-ref --format='%(refname:short)' refs/heads 2>/dev/null
  } | grep -vxE 'HEAD|origin' | awk 'NF && !seen[$0]++'
}

# ---- session persistence (restore agents after a tmux/server restart) ---------
# One file per session: $CONF_DIR/sessions/<session>.agents, tab-separated
# lines: dir <TAB> repo <TAB> branch <TAB> bare(0/1) <TAB> base.

agents_file() { echo "$CONF_DIR/sessions/$1.agents"; }

persist_agent() { # session dir repo branch bare base harness
  local sess="$1" f; f=$(agents_file "$sess"); mkdir -p "$(dirname "$f")" 2>/dev/null
  [ -f "$f" ] && { awk -F'\t' -v d="$2" '$1!=d' "$f" >"$f.tmp" 2>/dev/null && mv "$f.tmp" "$f"; }
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$2" "$3" "$4" "$5" "$6" "${7:-claude}" >>"$f"
}

cmd_forget() { # forget <dir> — drop a saved agent (called by the dashboard on teardown)
  local dir="${1:-}"; [ -n "$dir" ] || return 0
  local sess; sess=$(session_name) || return 0
  local f; f=$(agents_file "$sess"); [ -f "$f" ] || return 0
  awk -F'\t' -v d="$dir" '$1!=d' "$f" >"$f.tmp" 2>/dev/null && mv "$f.tmp" "$f"
}

cmd_fan() { # best-of-N: spawn N agents on the same prompt, branches <name>-1..N
  local repo="" name="" n=3 prompt="" bare="" base=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -n) n="$2"; shift 2 ;;
      -p) prompt="$2"; shift 2 ;;
      --base) base="$2"; shift 2 ;;
      --bare) bare="--bare"; shift ;;
      -*) die "unknown flag $1" ;;
      *) if [ -z "$repo" ]; then repo="$1"; elif [ -z "$name" ]; then name="$1"; else die "extra arg $1"; fi; shift ;;
    esac
  done
  [ -n "$repo" ] && [ -n "$name" ] || die "usage: fleet fan <repo> <name> -n N [-p prompt] [--base br] [--bare]"
  local i args
  for i in $(seq 1 "$n"); do
    args=("$repo" "${name}-${i}")
    [ -n "$prompt" ] && args+=(-p "$prompt")
    [ -n "$base" ] && args+=(--base "$base")
    [ -n "$bare" ] && args+=("$bare")
    cmd_new "${args[@]}"
  done
  echo "fanned $n agents on '$name' (review with v, promote by closing the rest)"
}

# ---- cost / tokens ------------------------------------------------------------
# Per-harness: claude records a transcript path per pane (the hook writes it to
# $RUNTIME_DIR/fleet/tx/<pane>); omp writes session JSONL we locate by cwd.
txfile() { echo "$RUNTIME_DIR/fleet/tx/${1#%}"; }

pane_harness() { # pane -> harness name from its window (@fleet_harness), default claude
  local h; h=$(tmux display -p -t "${1:-}" '#{@fleet_harness}' 2>/dev/null)
  echo "${h:-claude}"
}

cost_for_pane() { # pane -> "$X.YZ Nk" (cost + total tokens), or "-" if unknown
  local pane="${1:-}"; [ -n "$pane" ] || { echo "-"; return 0; }
  local h; h=$(pane_harness "$pane")
  harness_load "$h" 2>/dev/null || { echo "-"; return 0; }
  case "$H_COST_KIND" in
    claude-tx)   cost_claude_tx "$pane" ;;
    omp-session) cost_omp_session "$pane" ;;
    *)           echo "-" ;;
  esac
}

cost_omp_session() { # pane -> cost from the omp session JSONL matching its cwd
  local pane="$1" cwd root="${OMP_DATA_DIR:-$HOME/.omp/agent/sessions}"
  cwd=$(tmux display -p -t "$pane" '#{pane_current_path}' 2>/dev/null)
  [ -n "$cwd" ] && [ -d "$root" ] || { echo "-"; return 0; }
  python3 - "$root" "$cwd" <<'PY' 2>/dev/null || echo "-"
import json, os, sys, glob
root, cwd = sys.argv[1], sys.argv[2].rstrip("/")
# pick the newest session file that references this agent's cwd
best=None; best_mt=-1
for fp in glob.glob(os.path.join(root, "**", "*.jsonl"), recursive=True):
    try:
        with open(fp, encoding="utf-8") as fh:
            head = fh.read(4096)
    except Exception:
        continue
    if cwd not in head:
        continue
    mt = os.path.getmtime(fp)
    if mt > best_mt:
        best_mt, best = mt, fp
if not best:
    print("-"); raise SystemExit
cost=0.0; toks=0
for line in open(best, encoding="utf-8"):
    line=line.strip()
    if not line: continue
    try: o=json.loads(line)
    except Exception: continue
    u=o.get("usage") or (o.get("message") or {}).get("usage")
    if not isinstance(u, dict): continue
    c=u.get("cost")
    if isinstance(c, dict): cost += c.get("total", 0) or 0
    elif isinstance(c, (int,float)): cost += c
    for k in ("input","output","cacheRead","cacheWrite"):
        v=u.get(k);  toks += v if isinstance(v,(int,float)) else 0
    if u.get("totalTokens"): toks = max(toks, u["totalTokens"])
k=toks/1000.0
print(f"${cost:.2f} " + (f"{k:.0f}k" if k < 1000 else f"{k/1000:.1f}M"))
PY
}

cost_claude_tx() { # pane -> cost from the claude transcript recorded by the hook
  local pane="$1" f tp; f=$(txfile "$pane")
  [ -f "$f" ] || { echo "-"; return 0; }
  tp=$(cat "$f" 2>/dev/null); [ -n "$tp" ] && [ -f "$tp" ] || { echo "-"; return 0; }
  python3 - "$tp" <<'PY' 2>/dev/null || echo "-"
import json, sys
# per-MTok: (input, output, cache_write, cache_read); cache_write=1.25x in, cache_read=0.1x in
P = {"opus":(5,25,6.25,0.5), "sonnet":(3,15,3.75,0.30), "haiku":(1,5,1.25,0.10), "fable":(10,50,12.5,1.0)}
def rate(m):
    m = m or ""
    for k in ("fable","opus","sonnet","haiku"):
        if k in m: return P[k]
    return P["opus"]
cost = 0.0; toks = 0
for line in open(sys.argv[1], encoding="utf-8"):
    line = line.strip()
    if not line: continue
    try: o = json.loads(line)
    except Exception: continue
    u = (o.get("message") or {}).get("usage")
    if not u: continue
    i, out, cw, cr = rate((o.get("message") or {}).get("model"))
    it=u.get("input_tokens",0) or 0; ot=u.get("output_tokens",0) or 0
    ct=u.get("cache_creation_input_tokens",0) or 0; rt=u.get("cache_read_input_tokens",0) or 0
    cost += (it*i + ot*out + ct*cw + rt*cr)/1e6
    toks += it+ot+ct+rt
k = toks/1000.0
print(f"${cost:.2f} " + (f"{k:.0f}k" if k < 1000 else f"{k/1000:.1f}M"))
PY
}

cmd_cost() { # cost <agent> — show its token spend
  local target="${1:-}"; [ -n "$target" ] || die "usage: fleet cost <agent>"
  local line pane
  line=$(agents_tsv | awk -F'\t' -v t="$target" 'index($2,t)||index($5,t){print; exit}')
  [ -n "$line" ] || die "no agent matching '$target' (try: fleet ls)"
  pane=$(echo "$line" | cut -f7)
  echo "$target: $(cost_for_pane "$pane")"
}

cmd_guard() { # on | off | status — toggle the test/CI write-guard PreToolUse hook
  local sub="${1:-status}" marker="$CONF_DIR/guard-on"
  case "$sub" in
    on)  mkdir -p "$CONF_DIR"; : >"$marker"; echo "write-guard ON (asks before editing tests/CI/lockfiles)" ;;
    off) rm -f "$marker"; echo "write-guard OFF" ;;
    *)   [ -f "$marker" ] && echo "write-guard: ON" || echo "write-guard: off (enable with: fleet guard on)" ;;
  esac
}

cmd_restore() { # respawn saved agents whose windows are gone
  local sess; sess=$(session_name) || die "not inside tmux"
  local f; f=$(agents_file "$sess")
  [ -f "$f" ] || { echo "no saved agents for $sess"; return 0; }
  # match by window name (<repo>/<branchdir>, as cmd_new names them) — precise,
  # unlike pane cwd which the dashboard/other panes can share.
  local openwins; openwins=$(tmux list-windows -t "$sess" -F '#{window_name}' 2>/dev/null)
  local dir repo branch bare base harness n=0
  while IFS=$'\t' read -r dir repo branch bare base harness; do
    [ -n "$dir" ] && [ -n "$repo" ] && [ -n "$branch" ] || continue
    printf '%s\n' "$openwins" | grep -qxF "$repo/${branch//\//_}" && continue   # already running
    local args=("$repo" "$branch")
    [ "$bare" = 1 ] && args+=(--bare)
    [ -n "$base" ] && args+=(--base "$base")
    [ -n "$harness" ] && args+=(--harness "$harness")
    echo "restoring $repo/$branch..."
    cmd_new "${args[@]}" >/dev/null 2>&1 && n=$((n+1))
  done < "$f"
  echo "restored $n agent(s)"
}

# ---- new ----------------------------------------------------------------------

cmd_new() {
  local repo="" branch="" prompt="" bare=0 base="" harness=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -p) prompt="$2"; shift 2 ;;
      --bare) bare=1; shift ;;
      --base) base="$2"; shift 2 ;;
      --harness) harness="$2"; shift 2 ;;
      -*) die "unknown flag $1" ;;
      *) if [ -z "$repo" ]; then repo="$1"; elif [ -z "$branch" ]; then branch="$1"; else die "extra arg $1"; fi; shift ;;
    esac
  done
  [ -n "$repo" ] && [ -n "$branch" ] || die "usage: fleet new <repo> <branch> [-p prompt] [--bare] [--base branch] [--harness name]"
  [ -n "$harness" ] || harness=$(harness_select)
  harness_load "$harness"

  local root; root=$(fleet_root) || die "not inside tmux"
  local repo_base; repo_base=$(resolve_repo "$root" "$repo") || die "repo '$repo' not found under $root"

  local branchdir="${branch//\//_}" dir anchor=""
  local is_bare_repo; is_bare_repo=$(git -C "$repo_base" rev-parse --is-bare-repository 2>/dev/null)
  if [ -e "$repo_base/.git" ] && [ "$is_bare_repo" != "true" ]; then
    dir="$repo_base"   # plain working repo, no worktree layout
  else
    dir="$repo_base/$branchdir"
    if [ ! -d "$dir" ]; then
      if [ "$is_bare_repo" = "true" ]; then
        anchor="$repo_base"   # container holds a bare repo (.git) + worktree subdirs
      else
        local sub
        for sub in "$repo_base"/*/; do
          [ -e "${sub%/}/.git" ] && { anchor="${sub%/}"; break; }
        done
      fi
      [ -n "$anchor" ] || die "no git worktree found under $repo_base to anchor from"
      echo "creating worktree $dir ($branch)..."
      git -C "$anchor" fetch --quiet 2>/dev/null
      if git -C "$anchor" rev-parse --verify --quiet "refs/heads/$branch" >/dev/null \
         || git -C "$anchor" rev-parse --verify --quiet "refs/remotes/origin/$branch" >/dev/null; then
        git -C "$anchor" worktree add "$dir" "$branch" || die "worktree add failed"
      else
        local from="${base:-$(git -C "$anchor" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|origin/||')}"
        from="${from:-main}"
        git -C "$anchor" worktree add -b "$branch" "$dir" "origin/$from" \
          || git -C "$anchor" worktree add -b "$branch" "$dir" "$from" \
          || die "worktree add failed"
      fi
    fi
  fi

  local sess; sess=$(session_name) || die "not inside tmux"
  local wname; wname="$(basename "$repo_base")/$branchdir"
  local hbin
  hbin=$(harness_bin) || die "$H_NAME not found (looked for: $H_BIN)"

  local win_id
  if [ "$bare" = 1 ]; then
    # bare pane: run the harness directly; prompt is one arg, via the flag (or
    # positional when H_PROMPT_FLAG is empty, e.g. claude).
    local argv=("$hbin")
    if [ -n "$prompt" ]; then
      [ -n "$H_PROMPT_FLAG" ] && argv+=("$H_PROMPT_FLAG")
      argv+=("$prompt")
    fi
    win_id=$(tmux new-window -P -F '#{window_id}' -t "$sess" -n "$wname" -c "$dir" \
      "${argv[@]}")
  else
    # nvim pane: claude autostarts via claudecode.nvim; other harnesses open in a
    # generic :terminal. Both seed the prompt + take FleetSend over the nvim RPC.
    local nsock="$RUNTIME_DIR/fleet/nvim-$(date +%s%N).sock"
    mkdir -p "$RUNTIME_DIR/fleet"
    win_id=$(tmux new-window -P -F '#{window_id}' -t "$sess" -n "$wname" -c "$dir" \
      -e FLEET_AUTOCLAUDE="$([ "$H_NVIM_PLUGIN" = 1 ] && echo 1 || echo 0)" \
      -e FLEET_HARNESS="$H_NAME" -e FLEET_HARNESS_BIN="$hbin" \
      -e FLEET_TERM_MATCH="$H_TERM_MATCH" -e FLEET_PROMPT="$prompt" \
      nvim . --cmd "lua pcall(dofile, '$FLEET_DIR/nvim/fleet.lua')" --listen "$nsock")
    tmux set -w -t "$win_id" @fleet_nvim_sock "$nsock"
  fi
  tmux set -w -t "$win_id" @fleet_harness "$H_NAME"
  # Let fleetd derive state for hookless harnesses without knowing them: stamp
  # the state source + the "busy" scrape pattern onto the window.
  tmux set -w -t "$win_id" @fleet_state_src "$H_STATE_SRC"
  [ -n "$H_BUSY_RE" ] && tmux set -w -t "$win_id" @fleet_busy_re "$H_BUSY_RE"
  echo "spawned $wname ($H_NAME) in window $win_id"
  persist_agent "$sess" "$dir" "$(basename "$repo_base")" "$branch" "$bare" "$base" "$H_NAME"
  sync_main_tiles "$sess" 2>/dev/null || true
}

# ---- send ---------------------------------------------------------------------

cmd_send() {
  local target="${1:-}" text="${2:-}"
  [ -n "$target" ] && [ -n "$text" ] || die "usage: fleet send <agent> \"message\""
  local line
  line=$(agents_tsv | awk -F'\t' -v t="$target" 'index($2,t)||index($5,t){print; exit}')
  [ -n "$line" ] || die "no agent matching '$target' (try: fleet ls)"
  local win pane
  win=$(echo "$line" | cut -f4)
  pane=$(echo "$line" | cut -f7)
  local nsock; nsock=$(tmux show -w -t "$win" -v @fleet_nvim_sock 2>/dev/null)
  if [ -n "$nsock" ] && [ -S "$nsock" ]; then
    local res
    res=$(nvim --headless --server "$nsock" --remote-expr "v:lua.FleetSend(\"$(printf '%s' "$text" | sed 's/[\\"]/\\&/g')\")" 2>/dev/null)
    case "$res" in
      sent|opening) echo "delivered via nvim ($res)"; return 0 ;;
    esac
    echo "nvim RPC failed ($res), falling back to send-keys" >&2
  fi
  tmux send-keys -t "$pane" -l "$text" && tmux send-keys -t "$pane" Enter \
    && echo "delivered via send-keys (focus-dependent for nvim agents)"
}

# ---- watch (don't busy-poll: get pinged when agents finish) --------------------
# `fleet watch <agents> -m "msg"` returns immediately and spawns a detached
# watcher bound to the calling pane (the orchestrator). When all the named
# agents are idle, it delivers "msg" into that pane — waking the orchestrator —
# so the orchestrator can dispatch work, end its turn, and be notified later
# instead of holding itself hostage in a poll loop.
cmd_watch() {
  local msg="" targets=()
  while [ $# -gt 0 ]; do
    case "$1" in
      -m) msg="$2"; shift 2 ;;
      -*) die "unknown flag $1" ;;
      *) targets+=("$1"); shift ;;
    esac
  done
  [ ${#targets[@]} -gt 0 ] || die "usage: fleet watch <agent>... -m \"message when done\""
  local pane="${TMUX_PANE:-}"
  [ -n "$pane" ] || die "run fleet watch from a tmux pane (orchestrator)"
  [ -n "$msg" ] || msg="fleet: agents now idle — ${targets[*]}"
  local self="$FLEET_DIR/bin/fleet"
  if command -v setsid >/dev/null; then
    setsid "$self" watch-run "$pane" "$msg" "${targets[@]}" </dev/null >/dev/null 2>&1 &
  else
    nohup "$self" watch-run "$pane" "$msg" "${targets[@]}" </dev/null >/dev/null 2>&1 &
  fi
  echo "watching ${targets[*]} in the background — this pane gets pinged when they're all idle. End your turn; you'll be woken."
}

cmd_watch_run() { # watch-run <pane> <msg> <target...>  (detached; internal)
  local pane="$1" msg="$2"; shift 2
  local targets=("$@") streak=0 i tsv state t alldone
  for (( i=0; i<2700; i++ )); do          # ~90min cap at 2s/iteration
    sleep 2
    tmux display -p -t "$pane" '#{pane_id}' >/dev/null 2>&1 || return 0   # pane gone
    tsv=$(agents_tsv 2>/dev/null)
    alldone=1
    for t in "${targets[@]}"; do
      state=$(printf '%s\n' "$tsv" | awk -F'\t' -v x="$t" 'index($2,x)||index($5,x){print $1; exit}')
      [ "$state" = idle ] || alldone=0
    done
    if [ "$alldone" = 1 ]; then streak=$((streak+1)); else streak=0; fi
    (( streak >= 3 )) && break             # idle for ~6s straight → done (not a blip)
  done
  tmux send-keys -t "$pane" -l "$msg" 2>/dev/null
  tmux send-keys -t "$pane" Enter 2>/dev/null
}

# ---- mode ---------------------------------------------------------------------
# Cycle an agent's Claude permission mode by injecting Shift+Tab into its claude.
# claude cycles default → accept-edits → plan → bypass on each press, and prints
# the current mode in its footer (the dash reads that back authoritatively).

cmd_mode() {
  local target="${1:-}"
  [ -n "$target" ] || die "usage: fleet mode <agent>"
  local line
  line=$(agents_tsv | awk -F'\t' -v t="$target" 'index($2,t)||index($5,t){print; exit}')
  [ -n "$line" ] || die "no agent matching '$target' (try: fleet ls)"
  local win pane nsock
  win=$(echo "$line" | cut -f4)
  pane=$(echo "$line" | cut -f7)
  nsock=$(tmux show -w -t "$win" -v @fleet_nvim_sock 2>/dev/null)
  if [ -n "$nsock" ] && [ -S "$nsock" ]; then
    # (Re)source the current fleet.lua first, then call — so this works even for
    # agents whose nvim started before FleetCycleMode existed. Inline lua avoids
    # single quotes (the luaeval string is VimL-single-quoted); _A = the path.
    local res
    # --headless: without it, nvim --remote-expr launched from inside a terminal
    # (e.g. the dashboard pane) starts a TUI and the result comes back wrapped in
    # escape codes — so the "sent" check failed and we double-tapped via fallback.
    res=$(nvim --headless --server "$nsock" --remote-expr \
      "luaeval('(function() dofile(_A) return (_G.FleetCycleMode and _G.FleetCycleMode()) or 0 end)()', '$FLEET_DIR/nvim/fleet.lua')" \
      2>/dev/null)
    case "$res" in
      sent|opening) echo "cycled mode via nvim ($res)"; return 0 ;;
    esac
    echo "nvim RPC failed ($res), falling back to send-keys" >&2
  fi
  # BTab is tmux's name for Shift+Tab (emits \x1b[Z).
  tmux send-keys -t "$pane" BTab \
    && echo "cycled mode via send-keys (focus-dependent for nvim agents)"
}

# ---- main window / command center ---------------------------------------------

main_window_id() { # find existing main window in session
  tmux list-windows -t "$1" -F $'#{window_id}\t#{window_name}' 2>/dev/null \
    | awk -F'\t' '$2=="main"{print $1; exit}'
}

sync_main_tiles() { # ensure exactly one fleet-dash pane next to the orchestrator
  local sess="$1"
  local win; win=$(main_window_id "$sess")
  [ -n "$win" ] || return 1

  # Migrate: kill any legacy per-agent tile panes (old @fleet_tile layout).
  local p
  for p in $(tmux list-panes -t "$win" -F $'#{pane_id}\t#{@fleet_tile}' \
              | awk -F'\t' '$2=="1"{print $1}'); do
    tmux kill-pane -t "$p" 2>/dev/null
  done

  # The dash self-refreshes its whole agent list, so we only ever need one and
  # it should survive across fleet new/main calls — flagged @fleet_dash.
  local dash
  dash=$(tmux list-panes -t "$win" -F $'#{pane_id}\t#{@fleet_dash}' \
          | awk -F'\t' '$2=="1"{print $1; exit}')
  if [ -z "$dash" ]; then
    local orch
    orch=$(tmux list-panes -t "$win" -F '#{pane_id}' | head -1)
    dash=$(tmux split-window -P -F '#{pane_id}' -h -t "$orch" -l '40%' \
      "$FLEET_DIR/bin/fleet-dash" "$sess")
    tmux set -p -t "$dash" @fleet_dash 1
    tmux set -w -t "$win" main-pane-width '60%'
    tmux select-pane -t "$orch" 2>/dev/null
  fi
  # uncoloured pane divider — the active-pane border shouldn't light up between
  # the orchestrator and the dashboard. Match active to inactive (dim grey).
  tmux set -w -t "$win" pane-border-style 'fg=colour238' 2>/dev/null
  tmux set -w -t "$win" pane-active-border-style 'fg=colour238' 2>/dev/null
}

dash_pane_id() { # pane_id of the dashboard in the session's main window, if any
  local win; win=$(main_window_id "$1") || return 1
  [ -n "$win" ] || return 1
  tmux list-panes -t "$win" -F $'#{pane_id}\t#{@fleet_dash}' 2>/dev/null \
    | awk -F'\t' '$2=="1"{print $1; exit}'
}

reload_dash() { # restart the dash process in place — keeps pane size/position;
  local sess="$1"                       # orchestrator + agent windows untouched.
  local dash; dash=$(dash_pane_id "$sess")
  if [ -n "$dash" ]; then
    tmux respawn-pane -k -t "$dash" "$FLEET_DIR/bin/fleet-dash" "$sess"
    echo "dashboard reloaded ($dash)"
  else
    sync_main_tiles "$sess"             # none yet (or legacy tiles) — build fresh
    echo "dashboard built"
  fi
}

cmd_main() {
  if [ "${1:-}" = "--reload" ] || [ "${1:-}" = "reload" ]; then
    local sess; sess=$(session_name) || die "not inside tmux"
    reload_dash "$sess"
    return
  fi
  local sess; sess=$(session_name) || die "not inside tmux"
  local root; root=$(fleet_root)
  local win; win=$(main_window_id "$sess")
  if [ -z "$win" ]; then
    local claude_bin
    claude_bin=$(command -v claude-profile || command -v claude) || die "claude not found"
    win=$(tmux new-window -P -F '#{window_id}' -t "$sess" -n main -c "$root" "$claude_bin")
    tmux move-window -t "$sess" -s "$win" 2>/dev/null || true
  fi
  sync_main_tiles "$sess"
  tmux select-window -t "$win"
  echo "command center ready (window 'main')"
}

# ---- up -----------------------------------------------------------------------

ensure_daemon() {
  [ -S "$SOCK" ] && rpc fleet.ping >/dev/null 2>&1 && return 0
  systemctl --user start fleetd 2>/dev/null && sleep 0.3 && [ -S "$SOCK" ] && return 0
  if command -v fleetd >/dev/null; then
    nohup fleetd >/dev/null 2>&1 &
  else
    nohup "$FLEET_DIR/bin/fleetd" >/dev/null 2>&1 &
  fi
  sleep 0.3
}

inject_status_format() { # append agent glyph to window-status formats.
  # window-status-* are window options — tmux has no per-session scope for
  # them, so inject into the runtime GLOBAL value (never the config file).
  # Theme switches that regenerate pills wipe this; fleetd re-injects on its
  # sweep, fleet up on every run.
  local fmt opt
  for opt in window-status-format window-status-current-format; do
    fmt=$(tmux show -g -v "$opt" 2>/dev/null)
    [ -n "$fmt" ] || continue
    case "$fmt" in *@agent_glyph*) ;; *) tmux set -g "$opt" "$fmt#{?@agent_glyph, #{@agent_glyph},}" ;; esac
  done
}

# ---- keybinds -----------------------------------------------------------------
# Keys are bound under the tmux prefix and stored in keybinds.conf as
# `action=key` lines. Bindings are server-global and re-applied on every
# `fleet up`, never written to tmux.conf. The menu (and `fleet rebind`) edit
# this file and re-apply live.

KEYBINDS_CONF="$CONF_DIR/keybinds.conf"

# action|default-key|menu label|description
fleet_actions() {
  cat <<'EOF'
menu|F|Feature menu|Open this menu
pick|a|Pick / jump to agent|fzf popup of all agents, Enter jumps
new|n|New agent|Prompt for "repo branch", spawn agent
main|m|Rebuild command center|Re-tile the main window
reload|R|Reload dashboard|Restart the dashboard pane in place (picks up new code)
ls|l|List agents|Show agent states in a popup
EOF
}

keybind_for() { # keybind_for <action> → key (config override or default)
  local action="$1" key=""
  if [ -f "$KEYBINDS_CONF" ]; then
    key=$(awk -F= -v a="$action" '$1==a{print $2; exit}' "$KEYBINDS_CONF")
  fi
  [ -n "$key" ] && { echo "$key"; return; }
  fleet_actions | awk -F'|' -v a="$action" '$1==a{print $2; exit}'
}

action_tmux_command() { # tmux command string run when an action's key is pressed
  local action="$1" self="$FLEET_DIR/bin/fleet"
  case "$action" in
    menu) echo "run-shell '$self menu'" ;;
    pick) echo "display-popup -E -b rounded -w 80% -h 60% '$self pick'" ;;
    new)  echo "command-prompt -p 'fleet new (repo branch):' \"run-shell '$self new %%'\"" ;;
    main)   echo "run-shell '$self main'" ;;
    reload) echo "run-shell '$self main --reload'" ;;
    ls)     echo "display-popup -E -b rounded -w 70% -h 60% \"$self ls; echo; read -n1 -r -p 'press any key'\"" ;;
  esac
}

apply_keybinds() {
  local action key cmd
  while IFS='|' read -r action _ _ _; do
    key=$(keybind_for "$action")
    cmd=$(action_tmux_command "$action")
    [ -n "$key" ] && [ -n "$cmd" ] || continue
    eval "tmux bind-key '$key' $cmd"
  done < <(fleet_actions)
}

cmd_menu() {
  local args=() action key label
  while IFS='|' read -r action key_default label _; do
    key=$(keybind_for "$action")
    args+=("$label  (prefix $key)" "$key" "$(action_tmux_command "$action")")
  done < <(fleet_actions)
  tmux display-menu -b rounded -T "#[align=centre]󰭹 Fleet" -x C -y C \
    "${args[@]}" \
    "" \
    "Change a keybind" "c" "run-shell '$FLEET_DIR/bin/fleet rebind'" \
    "Close" "q" ""
}

cmd_rebind() {
  local args=() action key label
  while IFS='|' read -r action key_default label _; do
    key=$(keybind_for "$action")
    args+=("$label  [$key]" "" \
      "command-prompt -1 -p 'new key for $action:' \"run-shell '$FLEET_DIR/bin/fleet rebind-set $action %%'\"")
  done < <(fleet_actions)
  tmux display-menu -b rounded -T "#[align=centre]Rebind which feature?" -x C -y C "${args[@]}"
}

cmd_rebind_set() { # rebind-set <action> <key>
  local action="$1" key="$2"
  [ -n "$action" ] && [ -n "$key" ] || return 0
  mkdir -p "$CONF_DIR"
  touch "$KEYBINDS_CONF"
  # release the action's previous key unless another action still uses it
  local oldkey; oldkey=$(keybind_for "$action")
  if [ -n "$oldkey" ] && [ "$oldkey" != "$key" ]; then
    local still=""
    while IFS='|' read -r a _ _ _; do
      [ "$a" = "$action" ] && continue
      [ "$(keybind_for "$a")" = "$oldkey" ] && still=1
    done < <(fleet_actions)
    [ -z "$still" ] && tmux unbind-key "$oldkey" 2>/dev/null
  fi
  # warn (don't block) if the key already drives another fleet action
  local clash; clash=$(
    while IFS='|' read -r a _ _ _; do
      [ "$a" = "$action" ] && continue
      [ "$(keybind_for "$a")" = "$key" ] && echo "$a"
    done < <(fleet_actions)
  )
  local tmp; tmp=$(mktemp)
  awk -F= -v a="$action" '$1!=a' "$KEYBINDS_CONF" > "$tmp"
  echo "$action=$key" >> "$tmp"
  mv "$tmp" "$KEYBINDS_CONF"
  apply_keybinds
  if [ -n "$clash" ]; then
    tmux display-message "fleet: $action → prefix $key (also bound: $clash)"
  else
    tmux display-message "fleet: $action → prefix $key"
  fi
}

cmd_keys() { # plain text listing
  printf 'ACTION\tKEY\tDESCRIPTION\n'
  local action key label desc
  while IFS='|' read -r action key_default label desc; do
    key=$(keybind_for "$action")
    printf '%s\tprefix %s\t%s\n' "$action" "$key" "$desc"
  done < <(fleet_actions)
  echo
  echo "config: $KEYBINDS_CONF  (edit or use the menu / 'fleet rebind')"
}

cmd_up() {
  local arg="" root name restore=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --restore) restore=1; shift ;;
      *) [ -z "$arg" ] && arg="$1"; shift ;;
    esac
  done
  if [ -n "$arg" ] && [ -d "$arg" ]; then
    root=$(readlink -f "$arg")
    name=$(basename "$root" | tr -cd 'a-zA-Z0-9_-')
  elif [ -n "$arg" ]; then
    name="$arg"
    local yml="$CONF_DIR/projects/$arg.yml"
    if [ -f "$yml" ]; then
      root=$(awk -F': *' '$1=="root"{print $2; exit}' "$yml")
      root="${root/#\~/$HOME}"
    fi
    [ -n "${root:-}" ] || root="$PWD"
  else
    root="$PWD"
    name=$(basename "$root" | tr -cd 'a-zA-Z0-9_-')
  fi
  [ -d "$root" ] || die "project root $root does not exist"

  ensure_daemon

  if ! tmux has-session -t "=$name" 2>/dev/null; then
    if command -v tmuxinator >/dev/null && tmuxinator list -n 2>/dev/null | grep -qx "$name"; then
      tmuxinator start "$name" --no-attach 2>/dev/null || true
    fi
    if ! tmux has-session -t "=$name" 2>/dev/null; then
      # fresh session: main IS the first window, orchestrator runs in it —
      # no placeholder shell window
      local claude_bin
      claude_bin=$(command -v claude-profile || command -v claude) || die "claude not found"
      tmux new-session -d -s "$name" -c "$root" -n main "$claude_bin"
    fi
  fi

  tmux set -t "$name" @fleet_root "$root"
  inject_status_format "$name"
  # runtime keybinds (server-global; re-applied each `up`, never in tmux.conf)
  apply_keybinds

  # offer FLEET.md to the orchestrator
  if [ -f "$root/CLAUDE.md" ] && ! grep -q "fleet new" "$root/CLAUDE.md" 2>/dev/null; then
    echo "tip: append $FLEET_DIR/FLEET.md to $root/CLAUDE.md so the orchestrator knows fleet commands"
  elif [ ! -f "$root/CLAUDE.md" ]; then
    cp "$FLEET_DIR/FLEET.md" "$root/CLAUDE.md" 2>/dev/null \
      && echo "installed orchestrator instructions at $root/CLAUDE.md"
  fi

  # build command center, explicitly targeting the project session
  FLEET_SESSION="$name" FLEET_ROOT="$root" cmd_main || true

  # restore previously-open agents (after a tmux/server restart), or hint
  if [ "$restore" = 1 ]; then
    FLEET_SESSION="$name" FLEET_ROOT="$root" cmd_restore || true
  elif [ -s "$(agents_file "$name")" ]; then
    echo "  $(grep -c . "$(agents_file "$name")") saved agent(s) — run 'fleet restore' (or 'fleet up --restore')"
  fi

  if [ -t 0 ]; then
    if [ -n "${TMUX:-}" ]; then tmux switch-client -t "$name"; else tmux attach -t "$name"; fi
  else
    echo "session '$name' ready — attach with: tmux attach -t $name"
  fi
}

# ---- status / doctor ------------------------------------------------------------

cmd_status() {
  if rpc fleet.ping >/dev/null 2>&1; then
    local n; n=$(rpc fleet.list | python3 -c 'import json,sys; print(len(json.load(sys.stdin)["agents"]))' 2>/dev/null)
    echo "fleetd: running ($SOCK), agents: ${n:-?}"
  else
    echo "fleetd: NOT running"
  fi
}

cmd_doctor() {
  local ok=0
  for dep in tmux nvim git python3 fzf; do
    if command -v "$dep" >/dev/null; then echo "ok   $dep"; else echo "MISS $dep"; ok=1; fi
  done
  command -v notify-send >/dev/null && echo "ok   notify-send" || echo "warn notify-send missing (no desktop notifications)"
  command -v tmuxinator >/dev/null && echo "ok   tmuxinator (optional)" || echo "warn tmuxinator missing (fleet up builds sessions itself)"
  command -v claude-profile >/dev/null && echo "ok   claude-profile" \
    || { command -v claude >/dev/null && echo "ok   claude (no profile wrapper)" || { echo "MISS claude"; ok=1; }; }
  # harness adapters + whether each one's binary is on PATH
  local h; for h in $(harness_list); do
    if harness_load "$h" 2>/dev/null && harness_bin >/dev/null 2>&1; then
      echo "ok   harness: $h ($(harness_bin))"
    else echo "warn harness: $h (binary not found: $H_BIN)"; fi
  done
  echo "     default harness: $(harness_select)"
  [ -S "$SOCK" ] && rpc fleet.ping >/dev/null 2>&1 && echo "ok   fleetd socket" || echo "warn fleetd not running (fleet up starts it)"
  local prof hooked
  for prof in "$HOME/.claude" "$HOME/.claude_personal"; do
    [ -f "$prof/settings.json" ] || continue
    hooked=$(grep -c fleet-hook "$prof/settings.json" 2>/dev/null || true)
    if [ "${hooked:-0}" -gt 0 ]; then echo "ok   hooks wired in $prof"; else echo "warn hooks NOT wired in $prof (run install.sh)"; fi
  done
  if systemctl --user show-environment >/dev/null 2>&1; then
    systemctl --user is-enabled fleetd >/dev/null 2>&1 && echo "ok   fleetd.service enabled" \
      || echo "warn fleetd.service not enabled (ok if installed --no-systemd; 'fleet up' starts it)"
  else
    echo "ok   no systemd user bus — fleetd runs on demand (nohup via 'fleet up')"
  fi
  return $ok
}

# ---- dispatch -------------------------------------------------------------------

case "${1:-}" in
  up)      shift; cmd_up "$@" ;;
  new)     shift; cmd_new "$@" ;;
  ls)      shift; cmd_ls "$@" ;;
  agents)  shift; agents_tsv "$@" ;;   # raw TSV, consumed by fleet-dash
  repos)    shift; cmd_repos "$@" ;;     # repo names, for the new-agent form
  branches) shift; cmd_branches "$@" ;;  # base branches for a repo
  worktrees) shift; cmd_worktrees "$@" ;; # existing worktrees of a repo
  harnesses) shift; cmd_harnesses "$@" ;; # installed harness adapters (for the form)
  restore)  shift; cmd_restore "$@" ;;   # respawn saved agents
  forget)   shift; cmd_forget "$@" ;;    # drop a saved agent (dashboard teardown)
  guard)    shift; cmd_guard "$@" ;;     # toggle the test/CI write-guard
  fan)      shift; cmd_fan "$@" ;;        # best-of-N fan-out
  cost)     shift; cmd_cost "$@" ;;       # per-agent token/cost
  cost-pane) shift; cost_for_pane "$@" ;; # raw cost for a pane (dashboard)
  pick)    shift; cmd_pick "$@" ;;
  send)    shift; cmd_send "$@" ;;
  watch)     shift; cmd_watch "$@" ;;
  watch-run) shift; cmd_watch_run "$@" ;;  # internal: detached watcher
  mode)    shift; cmd_mode "$@" ;;
  main)       shift; cmd_main "$@" ;;
  menu)       shift; cmd_menu "$@" ;;
  keys)       shift; cmd_keys "$@" ;;
  rebind)     shift; cmd_rebind "$@" ;;
  rebind-set) shift; cmd_rebind_set "$@" ;;
  status)     shift; cmd_status "$@" ;;
  doctor)     shift; cmd_doctor "$@" ;;
  *) menu_key=$(keybind_for menu); cat <<EOF
fleet — agent fleet manager (tmux + nvim + Claude Code)

  fleet up [name|path]   boot project session + daemon + command center ([--restore])
  fleet restore          respawn saved agents from a previous session
  fleet new <repo> <br>  spawn agent (worktree + window + claude) [-p prompt] [--bare] [--base br]
  fleet ls               list agents and states
  fleet pick             fzf jump-to-agent
  fleet send <a> "msg"   send message to an agent's claude
  fleet fan <repo> <nm>  best-of-N: spawn N agents on one prompt [-n N] [-p prompt] [--base br] [--bare]
  fleet cost <a>         show an agent's token spend
  fleet guard on|off     test/CI write-guard (asks before editing tests/CI/lockfiles)
  fleet mode <a>         cycle an agent's Claude permission mode (Shift+Tab)
  fleet main [--reload]  (re)build command center window (--reload restarts just the dashboard)
  fleet menu             feature menu (bound to prefix+$menu_key by fleet up)
  fleet keys             list feature keybinds
  fleet rebind           change a keybind interactively
  fleet status           daemon status
  fleet doctor           dependency / wiring check
EOF
  ;;
esac
