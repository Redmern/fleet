#!/usr/bin/env bash
# fleet — standalone agent fleet manager for tmux + nvim + Claude Code.
# Subcommands: up new ls pick send main status doctor
# Design rule: fleet only *calls* tmux/nvim/git/claude. Every integration is
# fail-silent: if the daemon, tmux, or nvim plumbing is missing, each command
# degrades to a working subset instead of erroring out.

set -u

FLEET_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
SOCK="$RUNTIME_DIR/fleet.sock"
CONF_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/fleet"
HARNESS_DIR="$FLEET_DIR/harness.d"

die() { echo "fleet: $*" >&2; exit 1; }

# ---- harness adapters --------------------------------------------------------
# A "harness" is the agent CLI fleet drives (claude, omp, …). Each is described
# by a harness.d/<name>.conf sourced into H_* vars. Add a harness = add a file.

harness_select() { # resolve the active harness name (precedence: flag handled by
  # caller, then $FLEET_HARNESS, project .fleet/harness, config, default claude)
  if [ -n "${FLEET_HARNESS:-}" ]; then echo "$FLEET_HARNESS"; return; fi
  local root; root=$(fleet_root 2>/dev/null)
  if [ -n "$root" ] && [ -f "$root/.fleet/harness" ]; then
    local h; h=$(head -1 "$root/.fleet/harness" 2>/dev/null | tr -d '[:space:]')
    [ -n "$h" ] && { echo "$h"; return; }
  fi
  if [ -f "$CONF_DIR/config" ]; then
    local h; h=$(grep -E '^harness=' "$CONF_DIR/config" 2>/dev/null | tail -1 | cut -d= -f2 | tr -d '[:space:]')
    [ -n "$h" ] && { echo "$h"; return; }
  fi
  echo claude
}

harness_list() { # names of installed harness adapters
  for f in "$HARNESS_DIR"/*.conf; do [ -e "$f" ] && basename "$f" .conf; done
}

harness_load() { # populate H_* for <name>; defaults first, then the conf overrides
  local name="${1:-claude}"
  H_NAME="$name"
  H_BIN="$name"; H_ARGS=""; H_PROMPT_FLAG=""; H_TERM_MATCH="$name"; H_NVIM_PLUGIN=0
  H_STATE_SRC="scrape"; H_MODE_KEYS=""; H_MODE_LIST=""; H_COST_KIND=""
  H_GUARD_KIND="none"; H_BUSY_RE=""
  local conf="$HARNESS_DIR/$name.conf"
  [ -f "$conf" ] || die "unknown harness '$name' (have: $(harness_list | tr '\n' ' '))"
  # shellcheck disable=SC1090
  . "$conf"
}

harness_bin() { # first launchable binary from H_BIN candidates
  local c; for c in $H_BIN; do command -v "$c" >/dev/null 2>&1 && { command -v "$c"; return 0; }; done
  return 1
}

# ---- daemon RPC --------------------------------------------------------------

rpc() { # rpc <method> [params-json]  → result json on stdout, rc 1 if daemon down
  [ -S "$SOCK" ] || return 1
  python3 - "$SOCK" "$1" "${2:-{}}" <<'PY' 2>/dev/null
import json, socket, sys
sock_path, method, params = sys.argv[1], sys.argv[2], json.loads(sys.argv[3])
c = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
c.settimeout(2)
c.connect(sock_path)
c.sendall((json.dumps({"id": "cli", "method": method, "params": params}) + "\n").encode())
buf = b""
while b"\n" not in buf:
    chunk = c.recv(65536)
    if not chunk:
        break
    buf += chunk
resp = json.loads(buf.decode().splitlines()[0])
if not resp.get("ok"):
    sys.exit(1)
print(json.dumps(resp.get("result", {})))
PY
}

# ---- project resolution -------------------------------------------------------

session_name() { # FLEET_SESSION overrides (used by `fleet up` cross-session)
  [ -n "${FLEET_SESSION:-}" ] && { echo "$FLEET_SESSION"; return 0; }
  tmux display -p '#{session_name}' 2>/dev/null
}

fleet_root() { # project root for the current session
  local s; s=$(session_name) || return 1
  local r; r=$(tmux show -t "$s" -v @fleet_root 2>/dev/null)
  [ -n "$r" ] && { echo "$r"; return 0; }
  [ -n "${FLEET_ROOT:-}" ] && { echo "$FLEET_ROOT"; return 0; }
  pwd
}

discover_repos() { # discover_repos <root> → "name<TAB>path" lines
  local root="$1" d sub
  for d in "$root"/*/; do
    [ -d "$d" ] || continue
    d="${d%/}"
    if [ -e "$d/.git" ]; then
      printf '%s\t%s\n' "$(basename "$d")" "$d"
    else
      # worktree container: a dir whose subdirs are git checkouts
      for sub in "$d"/*/; do
        [ -e "${sub%/}/.git" ] && { printf '%s\t%s\n' "$(basename "$d")" "$d"; break; }
      done
    fi
  done
}

resolve_repo() { # resolve_repo <root> <name> → path
  local root="$1" want="$2" line name path match=""
  while IFS=$'\t' read -r name path; do
    [ "${name,,}" = "${want,,}" ] && { echo "$path"; return 0; }
    case "${name,,}" in *"${want,,}"*) match="$path" ;; esac
  done < <(discover_repos "$root")
  [ -n "$match" ] && { echo "$match"; return 0; }
  return 1
}

agent_label() { # last two path components
  local p="$1"; p="${p%/}"
  local b="${p##*/}" parent="${p%/*}"
  echo "${parent##*/}/$b"
}

# ---- ls -----------------------------------------------------------------------

agents_tsv() { # state<TAB>label<TAB>session<TAB>window_id<TAB>window_name<TAB>since<TAB>pane_id
  local json
  if json=$(rpc fleet.list); then
    python3 - "$json" <<'PY'
import json, sys, time, os
for a in json.loads(sys.argv[1]).get("agents", []):
    cwd = (a.get("cwd") or "").rstrip("/")
    label = "/".join(cwd.split("/")[-2:]) if cwd else a.get("window_name", "?")
    age = int(time.time() - a.get("since", time.time()))
    # "ready for deletion" marker: <worktree>/.fleet/ready (see `fleet ready`).
    # Field is "" when absent, else the reason (or "ready" with no reason given).
    ready = ""
    rp = os.path.join(cwd, ".fleet", "ready") if cwd else ""
    if rp and os.path.exists(rp):
        ready = "ready"
        try:
            for ln in open(rp):
                if ln.startswith("reason="):
                    ready = ln[7:].strip() or "ready"
        except OSError:
            pass
    print("\t".join([a.get("state","?"), label, a.get("session",""),
                     a.get("window_id",""), a.get("window_name",""),
                     f"{age//60}m{age%60:02d}s", a.get("pane_id",""), str(age), ready]))
PY
  else
    # daemon down: fall back to window options mirrored earlier (may be stale)
    tmux list-panes -a -F $'#{?@agent_state,#{@agent_state}\t#{pane_current_path}\t#{session_name}\t#{window_id}\t#{window_name}\t-\t#{pane_id},}' 2>/dev/null \
      | sed '/^$/d' \
      | while IFS=$'\t' read -r st path rest; do
          printf '%s\t%s\t%s\n' "$st" "$(agent_label "$path")" "$rest"
        done
  fi
}

cmd_ls() {
  local out; out=$(agents_tsv)
  [ -n "$out" ] || { echo "no agents registered"; return 0; }
  printf 'STATE\tAGENT\tWINDOW\tIN-STATE\n'
  # $9 is the "ready for deletion" flag (reason text, or empty). When set, show
  # the state as "done" and append the reason so reapable agents stand out.
  echo "$out" | sort -t$'\t' -k1,1 | awk -F'\t' '{
    st=$1; extra=""
    if ($9 != "") { st="done"; extra="  (ready: " $9 ")" }
    printf "%s\t%s\t%s:%s\t%s%s\n", st, $2, $3, $5, $6, extra
  }'
}

# ---- pick ---------------------------------------------------------------------

cmd_pick() {
  command -v fzf >/dev/null || die "fzf not installed"
  local rows
  rows=$(agents_tsv | sort -t$'\t' -k1,1 | awk -F'\t' '
    $1=="blocked"{c="\033[31m"; o=0}
    $1=="idle"   {c="\033[32m"; o=1}
    $1=="working"{c="\033[34m"; o=2}
    {printf "%d\t%s\t%s\t%s● %-8s\033[0m %-40s %s:%s  %s\n", o, $3, $4, c, $1, $2, $3, $5, $6}' \
    | sort -n | cut -f2-)
  [ -n "$rows" ] || { echo "no agents to pick"; return 0; }
  local choice
  choice=$(echo "$rows" | fzf --ansi --delimiter='\t' --with-nth=3 \
            --no-sort --prompt='agent> ' --height=100% --border=rounded) || return 0
  local sess win
  sess=$(echo "$choice" | cut -f1)
  win=$(echo "$choice" | cut -f2)
  tmux switch-client -t "$sess" 2>/dev/null
  tmux select-window -t "$win" 2>/dev/null
}

cmd_pick_project() { # fzf picker over saved projects -> fleet up <name> (bare `fleet`)
  # fzf-missing falls back to usage (do NOT popup); caller already gated on tty.
  command -v fzf >/dev/null || { print_usage; return 0; }
  local dir="$CONF_DIR/projects" ymls=()
  [ -d "$dir" ] && ymls=("$dir"/*.yml)
  # zero saved projects: friendly hint + usage, never an empty fzf.
  if [ ${#ymls[@]} -eq 0 ] || [ ! -e "${ymls[0]}" ]; then
    echo "no saved projects yet — run 'fleet save <name>' inside a session"
    echo
    print_usage
    return 0
  fi
  local rows="" f nm root
  for f in "${ymls[@]}"; do
    [ -f "$f" ] || continue
    nm=$(basename "$f" .yml)
    root=$(awk -F': *' '$1=="root"{print $2; exit}' "$f")
    if tmux has-session -t "=$nm" 2>/dev/null; then
      rows+=$(printf '%s\t\033[32m●\033[0m %-18s %s  \033[32m(running)\033[0m' "$nm" "$nm" "$root")$'\n'
    else
      rows+=$(printf '%s\t  %-18s %s' "$nm" "$nm" "$root")$'\n'
    fi
  done
  local choice
  choice=$(printf '%s' "$rows" | fzf --ansi --delimiter='\t' --with-nth=2 \
            --no-sort --prompt='project> ' --height=100% --border=rounded) || return 0
  [ -n "$choice" ] || return 0
  cmd_up "$(printf '%s' "$choice" | cut -f1)"
}

# ---- repos / branches (used by the dashboard new-agent form) ------------------

cmd_harnesses() { harness_list; }   # installed harness adapter names (for the form)

cmd_repos() { # list discoverable repo names under the project root
  local root; root=$(fleet_root) || die "not inside tmux"
  discover_repos "$root" | cut -f1 | awk 'NF && !seen[$0]++'
}

repo_anchor() { # repo_base -> a dir git can run in (the repo, bare container, or a worktree)
  local repo_base="$1" is_bare sub
  is_bare=$(git -C "$repo_base" rev-parse --is-bare-repository 2>/dev/null)
  if [ -e "$repo_base/.git" ] && [ "$is_bare" != "true" ]; then echo "$repo_base"; return 0; fi
  [ "$is_bare" = "true" ] && { echo "$repo_base"; return 0; }
  for sub in "$repo_base"/*/; do [ -e "${sub%/}/.git" ] && { echo "${sub%/}"; return 0; }; done
  return 1
}

cmd_worktrees() { # list branches of <repo>'s existing worktrees (launch targets)
  local repo="${1:-}"; [ -n "$repo" ] || die "usage: fleet worktrees <repo>"
  local root; root=$(fleet_root) || die "not inside tmux"
  local repo_base; repo_base=$(resolve_repo "$root" "$repo") || die "repo '$repo' not found under $root"
  local anchor; anchor=$(repo_anchor "$repo_base") || return 0
  git -C "$anchor" worktree list --porcelain 2>/dev/null \
    | awk '/^branch /{sub("refs/heads/","",$2); print $2}' | awk 'NF && !seen[$0]++'
}

cmd_branches() { # list candidate base branches for <repo>, default branch first
  local repo="${1:-}"; [ -n "$repo" ] || die "usage: fleet branches <repo>"
  local root; root=$(fleet_root) || die "not inside tmux"
  local repo_base; repo_base=$(resolve_repo "$root" "$repo") || die "repo '$repo' not found under $root"
  local anchor; anchor=$(repo_anchor "$repo_base") || return 0
  local def; def=$(git -C "$anchor" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||')
  {
    [ -n "$def" ] && echo "$def"
    git -C "$anchor" for-each-ref --format='%(refname:short)' refs/remotes/origin 2>/dev/null | sed 's|^origin/||'
    git -C "$anchor" for-each-ref --format='%(refname:short)' refs/heads 2>/dev/null
  } | grep -vxE 'HEAD|origin' | awk 'NF && !seen[$0]++'
}

# ---- session persistence (restore agents after a tmux/server restart) ---------
# One file per session: $CONF_DIR/sessions/<session>.agents, tab-separated
# lines: dir <TAB> repo <TAB> branch <TAB> bare(0/1) <TAB> base.

agents_file() { echo "$CONF_DIR/sessions/$1.agents"; }

scratch_wname() { # <sess> <label> -> a window name not already open in the session
  local sess="$1" base="${2:-scratch}" name; name="$base"
  local open i=2; open=$(tmux list-windows -t "$sess" -F '#{window_name}' 2>/dev/null)
  while printf '%s\n' "$open" | grep -qxF "$name" 2>/dev/null; do name="$base-$i"; i=$((i+1)); done
  printf '%s' "$name"
}

persist_agent() { # session dir repo branch bare base harness
  local sess="$1" f; f=$(agents_file "$sess"); mkdir -p "$(dirname "$f")" 2>/dev/null
  [ -f "$f" ] && { awk -F'\t' -v d="$2" '$1!=d' "$f" >"$f.tmp" 2>/dev/null && mv "$f.tmp" "$f"; }
  printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$2" "$3" "$4" "$5" "$6" "${7:-claude}" >>"$f"
}

cmd_forget() { # forget <dir> — drop a saved agent (called by the dashboard on teardown)
  local dir="${1:-}"; [ -n "$dir" ] || return 0
  local sess; sess=$(session_name) || return 0
  local f; f=$(agents_file "$sess"); [ -f "$f" ] || return 0
  awk -F'\t' -v d="$dir" '$1!=d' "$f" >"$f.tmp" 2>/dev/null && mv "$f.tmp" "$f"
}

cmd_fan() { # best-of-N: spawn N agents on the same prompt, branches <name>-1..N
  local repo="" name="" n=3 prompt="" bare="" base=""
  while [ $# -gt 0 ]; do
    case "$1" in
      -n) n="$2"; shift 2 ;;
      -p) prompt="$2"; shift 2 ;;
      --base) base="$2"; shift 2 ;;
      --bare) bare="--bare"; shift ;;
      -*) die "unknown flag $1" ;;
      *) if [ -z "$repo" ]; then repo="$1"; elif [ -z "$name" ]; then name="$1"; else die "extra arg $1"; fi; shift ;;
    esac
  done
  [ -n "$repo" ] && [ -n "$name" ] || die "usage: fleet fan <repo> <name> -n N [-p prompt] [--base br] [--bare]"
  local i args
  for i in $(seq 1 "$n"); do
    args=("$repo" "${name}-${i}")
    [ -n "$prompt" ] && args+=(-p "$prompt")
    [ -n "$base" ] && args+=(--base "$base")
    [ -n "$bare" ] && args+=("$bare")
    cmd_new "${args[@]}"
  done
  echo "fanned $n agents on '$name' (review with v, promote by closing the rest)"
}

# ---- cost / tokens ------------------------------------------------------------
# Per-harness: claude records a transcript path per pane (the hook writes it to
# $RUNTIME_DIR/fleet/tx/<pane>); omp writes session JSONL we locate by cwd.
txfile() { echo "$RUNTIME_DIR/fleet/tx/${1#%}"; }

pane_harness() { # pane -> harness name from its window (@fleet_harness), default claude
  local h; h=$(tmux display -p -t "${1:-}" '#{@fleet_harness}' 2>/dev/null)
  echo "${h:-claude}"
}

cost_for_pane() { # pane -> "$X.YZ Nk" (cost + total tokens), or "-" if unknown
  local pane="${1:-}"; [ -n "$pane" ] || { echo "-"; return 0; }
  local h; h=$(pane_harness "$pane")
  harness_load "$h" 2>/dev/null || { echo "-"; return 0; }
  case "$H_COST_KIND" in
    claude-tx)   cost_claude_tx "$pane" ;;
    omp-session) cost_omp_session "$pane" ;;
    *)           echo "-" ;;
  esac
}

cost_omp_session() { # pane -> cost from the omp session JSONL matching its cwd
  local pane="$1" cwd root="${OMP_DATA_DIR:-$HOME/.omp/agent/sessions}"
  cwd=$(tmux display -p -t "$pane" '#{pane_current_path}' 2>/dev/null)
  [ -n "$cwd" ] && [ -d "$root" ] || { echo "-"; return 0; }
  python3 - "$root" "$cwd" <<'PY' 2>/dev/null || echo "-"
import json, os, sys, glob
root, cwd = sys.argv[1], sys.argv[2].rstrip("/")
# pick the newest session file that references this agent's cwd
best=None; best_mt=-1
for fp in glob.glob(os.path.join(root, "**", "*.jsonl"), recursive=True):
    try:
        with open(fp, encoding="utf-8") as fh:
            head = fh.read(4096)
    except Exception:
        continue
    if cwd not in head:
        continue
    mt = os.path.getmtime(fp)
    if mt > best_mt:
        best_mt, best = mt, fp
if not best:
    print("-"); raise SystemExit
cost=0.0; toks=0
for line in open(best, encoding="utf-8"):
    line=line.strip()
    if not line: continue
    try: o=json.loads(line)
    except Exception: continue
    u=o.get("usage") or (o.get("message") or {}).get("usage")
    if not isinstance(u, dict): continue
    c=u.get("cost")
    if isinstance(c, dict): cost += c.get("total", 0) or 0
    elif isinstance(c, (int,float)): cost += c
    for k in ("input","output","cacheRead","cacheWrite"):
        v=u.get(k);  toks += v if isinstance(v,(int,float)) else 0
    if u.get("totalTokens"): toks = max(toks, u["totalTokens"])
k=toks/1000.0
print(f"${cost:.2f} " + (f"{k:.0f}k" if k < 1000 else f"{k/1000:.1f}M"))
PY
}

cost_claude_tx() { # pane -> cost from the claude transcript recorded by the hook
  local pane="$1" f tp; f=$(txfile "$pane")
  [ -f "$f" ] || { echo "-"; return 0; }
  tp=$(cat "$f" 2>/dev/null); [ -n "$tp" ] && [ -f "$tp" ] || { echo "-"; return 0; }
  python3 - "$tp" <<'PY' 2>/dev/null || echo "-"
import json, sys
# per-MTok: (input, output, cache_write, cache_read); cache_write=1.25x in, cache_read=0.1x in
P = {"opus":(5,25,6.25,0.5), "sonnet":(3,15,3.75,0.30), "haiku":(1,5,1.25,0.10), "fable":(10,50,12.5,1.0)}
def rate(m):
    m = m or ""
    for k in ("fable","opus","sonnet","haiku"):
        if k in m: return P[k]
    return P["opus"]
cost = 0.0; toks = 0
for line in open(sys.argv[1], encoding="utf-8"):
    line = line.strip()
    if not line: continue
    try: o = json.loads(line)
    except Exception: continue
    u = (o.get("message") or {}).get("usage")
    if not u: continue
    i, out, cw, cr = rate((o.get("message") or {}).get("model"))
    it=u.get("input_tokens",0) or 0; ot=u.get("output_tokens",0) or 0
    ct=u.get("cache_creation_input_tokens",0) or 0; rt=u.get("cache_read_input_tokens",0) or 0
    cost += (it*i + ot*out + ct*cw + rt*cr)/1e6
    toks += it+ot+ct+rt
k = toks/1000.0
print(f"${cost:.2f} " + (f"{k:.0f}k" if k < 1000 else f"{k/1000:.1f}M"))
PY
}

cmd_cost() { # cost <agent> — show its token spend
  local target="${1:-}"; [ -n "$target" ] || die "usage: fleet cost <agent>"
  local line pane
  line=$(agents_tsv | awk -F'\t' -v t="$target" 'index($2,t)||index($5,t){print; exit}')
  [ -n "$line" ] || die "no agent matching '$target' (try: fleet ls)"
  pane=$(echo "$line" | cut -f7)
  echo "$target: $(cost_for_pane "$pane")"
}

cmd_guard() { # on | off | status — toggle the test/CI write-guard PreToolUse hook
  local sub="${1:-status}" marker="$CONF_DIR/guard-on"
  case "$sub" in
    on)  mkdir -p "$CONF_DIR"; : >"$marker"; echo "write-guard ON (asks before editing tests/CI/lockfiles)" ;;
    off) rm -f "$marker"; echo "write-guard OFF" ;;
    *)   [ -f "$marker" ] && echo "write-guard: ON" || echo "write-guard: off (enable with: fleet guard on)" ;;
  esac
}

cmd_restore() { # respawn saved agents whose windows are gone
  local sess; sess=$(session_name) || die "not inside tmux"
  local f; f=$(agents_file "$sess")
  [ -f "$f" ] || { echo "no saved agents for $sess"; return 0; }
  # match by window name (<repo>/<branchdir>, as cmd_new names them) — precise,
  # unlike pane cwd which the dashboard/other panes can share.
  local openwins; openwins=$(tmux list-windows -t "$sess" -F '#{window_name}' 2>/dev/null)
  local dir repo branch bare base harness n=0
  while IFS=$'\t' read -r dir repo branch bare base harness; do
    [ -n "$dir" ] && [ -n "$repo" ] && [ -n "$branch" ] || continue
    printf '%s\n' "$openwins" | grep -qxF "$repo/${branch//\//_}" && continue   # already running
    local args=("$repo" "$branch")
    [ "$bare" = 1 ] && args+=(--bare)
    [ -n "$base" ] && args+=(--base "$base")
    [ -n "$harness" ] && args+=(--harness "$harness")
    echo "restoring $repo/$branch..."
    cmd_new "${args[@]}" >/dev/null 2>&1 && n=$((n+1))
  done < "$f"
  echo "restored $n agent(s)"
}

# ---- new ----------------------------------------------------------------------

cmd_new() {
  local repo="" branch="" prompt="" bare=0 base="" harness="" scratch=0 switch=0
  while [ $# -gt 0 ]; do
    case "$1" in
      -p) prompt="$2"; shift 2 ;;
      --bare) bare=1; shift ;;
      --scratch) scratch=1; shift ;;
      --switch|-s) switch=1; shift ;;
      --base) base="$2"; shift 2 ;;
      --harness|-h) harness="$2"; shift 2 ;;
      -*) die "unknown flag $1" ;;
      *) if [ -z "$repo" ]; then repo="$1"; elif [ -z "$branch" ]; then branch="$1"; else die "extra arg $1"; fi; shift ;;
    esac
  done
  [ -n "$harness" ] || harness=$(harness_select)
  harness_load "$harness"

  local root; root=$(fleet_root) || die "not inside tmux"
  local sess; sess=$(session_name) || die "not inside tmux"
  local dir wname repo_base=""

  if [ "$scratch" = 1 ]; then
    # repo-less scratch agent: no repo, no branch, no worktree. Always a plain
    # agent pane (nothing to edit in nvim), launched at the project root. The
    # first positional, if any, is just a window label.
    bare=1
    dir="$root"
    wname=$(scratch_wname "$sess" "${repo:-scratch}")
  else
    [ -n "$repo" ] && [ -n "$branch" ] || die "usage: fleet new <repo> <branch> [-p prompt] [--bare] [--switch|-s] [--base branch] [--harness|-h name]  (or: fleet new --scratch [label] for a repo-less agent)"
    repo_base=$(resolve_repo "$root" "$repo") || die "repo '$repo' not found under $root"
    local branchdir="${branch//\//_}" anchor=""
    local is_bare_repo; is_bare_repo=$(git -C "$repo_base" rev-parse --is-bare-repository 2>/dev/null)
    if [ -e "$repo_base/.git" ] && [ "$is_bare_repo" != "true" ]; then
      dir="$repo_base"   # plain working repo, no worktree layout
    else
      dir="$repo_base/$branchdir"
      if [ ! -d "$dir" ]; then
        if [ "$is_bare_repo" = "true" ]; then
          anchor="$repo_base"   # container holds a bare repo (.git) + worktree subdirs
        else
          local sub
          for sub in "$repo_base"/*/; do
            [ -e "${sub%/}/.git" ] && { anchor="${sub%/}"; break; }
          done
        fi
        [ -n "$anchor" ] || die "no git worktree found under $repo_base to anchor from"
        echo "creating worktree $dir ($branch)..."
        git -C "$anchor" fetch --quiet 2>/dev/null
        if git -C "$anchor" rev-parse --verify --quiet "refs/heads/$branch" >/dev/null \
           || git -C "$anchor" rev-parse --verify --quiet "refs/remotes/origin/$branch" >/dev/null; then
          git -C "$anchor" worktree add "$dir" "$branch" || die "worktree add failed"
        else
          local from="${base:-$(git -C "$anchor" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|origin/||')}"
          from="${from:-main}"
          git -C "$anchor" worktree add -b "$branch" "$dir" "origin/$from" \
            || git -C "$anchor" worktree add -b "$branch" "$dir" "$from" \
            || die "worktree add failed"
        fi
      fi
    fi
    wname="$(basename "$repo_base")/$branchdir"
  fi

  local hbin
  hbin=$(harness_bin) || die "$H_NAME not found (looked for: $H_BIN)"

  local win_id
  if [ "$bare" = 1 ]; then
    # bare pane: run the harness directly; prompt is one arg, via the flag (or
    # positional when H_PROMPT_FLAG is empty, e.g. claude).
    local argv=("$hbin")
    # shellcheck disable=SC2206
    [ -n "$H_ARGS" ] && argv+=($H_ARGS)
    if [ -n "$prompt" ]; then
      [ -n "$H_PROMPT_FLAG" ] && argv+=("$H_PROMPT_FLAG")
      argv+=("$prompt")
    fi
    win_id=$(tmux new-window -d -P -F '#{window_id}' -t "$sess" -n "$wname" -c "$dir" \
      "${argv[@]}")
  else
    # nvim pane: claude autostarts via claudecode.nvim; other harnesses open in a
    # generic :terminal. Both seed the prompt + take FleetSend over the nvim RPC.
    local nsock="$RUNTIME_DIR/fleet/nvim-$(date +%s%N).sock"
    mkdir -p "$RUNTIME_DIR/fleet"
    win_id=$(tmux new-window -d -P -F '#{window_id}' -t "$sess" -n "$wname" -c "$dir" \
      -e FLEET_AUTOCLAUDE="$([ "$H_NVIM_PLUGIN" = 1 ] && echo 1 || echo 0)" \
      -e FLEET_HARNESS="$H_NAME" -e FLEET_HARNESS_BIN="$hbin${H_ARGS:+ $H_ARGS}" \
      -e FLEET_TERM_MATCH="$H_TERM_MATCH" -e FLEET_PROMPT="$prompt" \
      nvim . --cmd "lua pcall(dofile, '$FLEET_DIR/nvim/fleet.lua')" --listen "$nsock")
    tmux set -w -t "$win_id" @fleet_nvim_sock "$nsock"
  fi
  tmux set -w -t "$win_id" @fleet_harness "$H_NAME"
  # Let fleetd derive state for hookless harnesses without knowing them: stamp
  # the state source + the "busy" scrape pattern onto the window.
  tmux set -w -t "$win_id" @fleet_state_src "$H_STATE_SRC"
  [ -n "$H_BUSY_RE" ] && tmux set -w -t "$win_id" @fleet_busy_re "$H_BUSY_RE"
  echo "spawned $wname ($H_NAME) in window $win_id"
  # Window is created detached (-d) so focus stays put; jump only on --switch.
  [ "$switch" = 1 ] && tmux select-window -t "$win_id" 2>/dev/null || true
  # scratch agents are repo-less + ephemeral — nothing to restore, so don't persist.
  [ "$scratch" = 1 ] || persist_agent "$sess" "$dir" "$(basename "$repo_base")" "$branch" "$bare" "$base" "$H_NAME"
  sync_main_tiles "$sess" 2>/dev/null || true
}

# ---- send ---------------------------------------------------------------------

cmd_send() {
  local target="${1:-}" text="${2:-}"
  [ -n "$target" ] && [ -n "$text" ] || die "usage: fleet send <agent> \"message\""
  local line
  line=$(agents_tsv | awk -F'\t' -v t="$target" 'index($2,t)||index($5,t){print; exit}')
  [ -n "$line" ] || die "no agent matching '$target' (try: fleet ls)"
  local win pane
  win=$(echo "$line" | cut -f4)
  pane=$(echo "$line" | cut -f7)
  local nsock; nsock=$(tmux show -w -t "$win" -v @fleet_nvim_sock 2>/dev/null)
  if [ -n "$nsock" ] && [ -S "$nsock" ]; then
    local res
    res=$(nvim --headless --server "$nsock" --remote-expr "v:lua.FleetSend(\"$(printf '%s' "$text" | sed 's/[\\"]/\\&/g')\")" 2>/dev/null)
    case "$res" in
      sent|opening) echo "delivered via nvim ($res)"; return 0 ;;
    esac
    echo "nvim RPC failed ($res), falling back to send-keys" >&2
  fi
  tmux send-keys -t "$pane" -l "$text" && tmux send-keys -t "$pane" Enter \
    && echo "delivered via send-keys (focus-dependent for nvim agents)"
}

# ---- watch (don't busy-poll: get pinged when agents finish) --------------------
# `fleet watch <agents> -m "msg"` returns immediately and spawns a detached
# watcher bound to the calling pane (the orchestrator). When all the named
# agents are idle, it delivers "msg" into that pane — waking the orchestrator —
# so the orchestrator can dispatch work, end its turn, and be notified later
# instead of holding itself hostage in a poll loop.
cmd_watch() {
  local msg="" targets=()
  while [ $# -gt 0 ]; do
    case "$1" in
      -m) msg="$2"; shift 2 ;;
      -*) die "unknown flag $1" ;;
      *) targets+=("$1"); shift ;;
    esac
  done
  [ ${#targets[@]} -gt 0 ] || die "usage: fleet watch <agent>... -m \"message when done\""
  local pane="${TMUX_PANE:-}"
  [ -n "$pane" ] || die "run fleet watch from a tmux pane (orchestrator)"
  [ -n "$msg" ] || msg="fleet: agents now idle — ${targets[*]}"
  local self="$FLEET_DIR/bin/fleet"
  if command -v setsid >/dev/null; then
    setsid "$self" watch-run "$pane" "$msg" "${targets[@]}" </dev/null >/dev/null 2>&1 &
  else
    nohup "$self" watch-run "$pane" "$msg" "${targets[@]}" </dev/null >/dev/null 2>&1 &
  fi
  echo "watching ${targets[*]} in the background — this pane gets pinged when they're all idle. End your turn; you'll be woken."
}

cmd_watch_run() { # watch-run <pane> <msg> <target...>  (detached; internal)
  local pane="$1" msg="$2"; shift 2
  local targets=("$@") streak=0 i tsv state t alldone
  for (( i=0; i<2700; i++ )); do          # ~90min cap at 2s/iteration
    sleep 2
    tmux display -p -t "$pane" '#{pane_id}' >/dev/null 2>&1 || return 0   # pane gone
    tsv=$(agents_tsv 2>/dev/null)
    alldone=1
    for t in "${targets[@]}"; do
      state=$(printf '%s\n' "$tsv" | awk -F'\t' -v x="$t" 'index($2,x)||index($5,x){print $1; exit}')
      [ "$state" = idle ] || alldone=0
    done
    if [ "$alldone" = 1 ]; then streak=$((streak+1)); else streak=0; fi
    (( streak >= 3 )) && break             # idle for ~6s straight → done (not a blip)
  done
  tmux send-keys -t "$pane" -l "$msg" 2>/dev/null
  tmux send-keys -t "$pane" Enter 2>/dev/null
}

# ---- ready / reap (signal a worktree is done, then remove it) ------------------
# A worker signals its own work item is finished by running `fleet ready` from
# inside its worktree; the orchestrator can flag any agent with
# `fleet ready <agent>`. Either way it drops a marker file <worktree>/.fleet/ready
# (timestamp, who, optional reason). The flag surfaces in `fleet ls` and the
# dashboard, and `fleet reap` then tears down every flagged worktree — refusing
# any with uncommitted changes or an unmerged branch unless --force.

cmd_ready() { # ready [<agent>] [-m "reason"] [--clear]
  local target="" reason="" clear=0
  while [ $# -gt 0 ]; do
    case "$1" in
      -m) reason="$2"; shift 2 ;;
      --clear) clear=1; shift ;;
      -*) die "unknown flag $1" ;;
      *) target="$1"; shift ;;
    esac
  done
  local dir by
  if [ -n "$target" ]; then            # orchestrator flagging another agent
    local line pane
    line=$(agents_tsv | awk -F'\t' -v t="$target" 'index($2,t)||index($5,t){print; exit}')
    [ -n "$line" ] || die "no agent matching '$target' (try: fleet ls)"
    pane=$(echo "$line" | cut -f7)
    dir=$(tmux display -p -t "$pane" '#{pane_current_path}' 2>/dev/null)
    by=orchestrator
  else                                 # a worker flagging its own worktree
    dir="$PWD"; by=worker
  fi
  [ -n "$dir" ] || die "could not resolve a worktree directory"
  local root; root=$(git -C "$dir" rev-parse --show-toplevel 2>/dev/null) || root="$dir"
  local marker="$root/.fleet/ready"
  if [ "$clear" = 1 ]; then
    rm -f "$marker" 2>/dev/null; echo "cleared ready flag: $root"; return 0
  fi
  mkdir -p "$root/.fleet" 2>/dev/null || true
  reason=$(printf '%s' "$reason" | tr '\t\n' '  ')   # keep the marker a clean line
  {
    printf 'ts=%s\n' "$(date -Is 2>/dev/null || date)"
    printf 'by=%s\n' "$by"
    [ -n "$reason" ] && printf 'reason=%s\n' "$reason"
  } 2>/dev/null >"$marker"   # 2>/dev/null FIRST so a failed open of $marker is muted too
  # Don't key success off the brace group's exit: its last statement is the
  # conditional reason line, which is "false" when no -m was given even though
  # the writes succeeded. Check the actual outcome — a non-empty marker file.
  if [ -s "$marker" ]; then
    echo "marked ready for deletion: $root${reason:+ ($reason)}"
  else
    echo "could not write marker at $marker" >&2; return 1
  fi
}

cmd_reap() { # reap [<target>] [--force] — remove worktrees flagged ready
  local force=0 target=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --force|-f) force=1; shift ;;
      -*) die "unknown flag $1" ;;
      *) target="$1"; shift ;;
    esac
  done
  local sess; sess=$(session_name) || die "not inside a fleet session"
  local f; f=$(agents_file "$sess")
  [ -f "$f" ] || { echo "no saved agents for this session"; return 0; }
  local lines; lines=$(cat "$f" 2>/dev/null)   # snapshot: cmd_forget mutates $f
  local any=0 reaped=0 dir repo branch base
  while IFS=$'\t' read -r dir repo branch _bare base _rest; do
    [ -n "$dir" ] || continue
    [ -e "$dir/.fleet/ready" ] || continue       # only flagged worktrees
    local lbl="${repo:-?}/${branch:-?}"
    [ -n "$target" ] && ! printf '%s' "$lbl $dir" | grep -qF -- "$target" && continue
    any=1
    if [ ! -d "$dir" ]; then
      cmd_forget "$dir"; echo "drop   $lbl: dir gone (stale)"; continue
    fi
    local gd; gd=$(git -C "$dir" rev-parse --git-dir 2>/dev/null)
    case "$gd" in *"/worktrees/"*) ;; *) echo "skip   $lbl: not a linked worktree"; continue ;; esac
    if [ "$force" != 1 ]; then
      # ignore fleet's own .fleet/ metadata (the ready marker shows as "?? .fleet/")
      local dirty; dirty=$(git -C "$dir" status --porcelain 2>/dev/null | grep -vE '^...\.fleet/')
      if [ -n "$dirty" ]; then
        echo "skip   $lbl: $(printf '%s\n' "$dirty" | grep -c .) uncommitted file(s) (use --force)"; continue
      fi
      local b="${base:-}"
      [ -n "$b" ] || b=$(git -C "$dir" symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null | sed 's|^origin/||')
      local baseref=""
      if [ -n "$b" ]; then
        if   git -C "$dir" rev-parse --verify -q "$b"        >/dev/null 2>&1; then baseref="$b"
        elif git -C "$dir" rev-parse --verify -q "origin/$b" >/dev/null 2>&1; then baseref="origin/$b"; fi
      fi
      if [ -n "$baseref" ] && ! git -C "$dir" merge-base --is-ancestor HEAD "$baseref" 2>/dev/null; then
        echo "skip   $lbl: branch not merged into $b (use --force)"; continue
      fi
    fi
    local win; win=$(tmux list-panes -a -F '#{pane_current_path}'$'\t''#{window_id}' 2>/dev/null \
                      | awk -F'\t' -v d="$dir" '$1==d{print $2; exit}')
    [ -n "$win" ] && tmux kill-window -t "$win" 2>/dev/null
    cmd_forget "$dir"
    rm -f "$dir/.fleet/ready" 2>/dev/null; rmdir "$dir/.fleet" 2>/dev/null || true  # else it blocks remove
    local main; main=$(git -C "$dir" worktree list --porcelain 2>/dev/null | awk '/^worktree /{print $2; exit}')
    local rmflag=""; [ "$force" = 1 ] && rmflag="--force"
    if git -C "${main:-$dir}" worktree remove $rmflag "$dir" 2>/dev/null; then
      local bnote=""
      if [ -n "$branch" ] && [ -n "$main" ]; then
        # Always -D: the non-force path already verified the branch is merged
        # into its base (the "not merged" guard above), and --force intends to
        # ignore mergedness — so -D is safe in both. Plain -d would check
        # mergedness against $main's HEAD, which for a bare worktree-container
        # is the bare repo's lagging default branch (not the worktree the user
        # merged into), so it wrongly refuses and the branch lingers. The
        # branch is no longer checked out anywhere after worktree remove, so
        # deletion is not blocked by a checkout in either layout.
        local derr
        if ! derr=$(git -C "$main" branch -D "$branch" 2>&1); then
          bnote=" (branch $branch kept: $(printf '%s' "$derr" | head -1))"
        fi
      fi
      echo "reaped $lbl$bnote"; reaped=$((reaped+1))
    else
      echo "skip   $lbl: worktree remove failed (uncommitted? use --force)"
    fi
  done <<EOF
$lines
EOF
  [ "$any" = 1 ] || echo "nothing flagged ready (mark one with 'fleet ready')"
}

# ---- mode ---------------------------------------------------------------------
# Cycle an agent's Claude permission mode by injecting Shift+Tab into its claude.
# claude cycles default → accept-edits → plan → bypass on each press, and prints
# the current mode in its footer (the dash reads that back authoritatively).

cmd_mode() {
  local target="${1:-}"
  [ -n "$target" ] || die "usage: fleet mode <agent>"
  local line
  line=$(agents_tsv | awk -F'\t' -v t="$target" 'index($2,t)||index($5,t){print; exit}')
  [ -n "$line" ] || die "no agent matching '$target' (try: fleet ls)"
  local win pane nsock
  win=$(echo "$line" | cut -f4)
  pane=$(echo "$line" | cut -f7)
  nsock=$(tmux show -w -t "$win" -v @fleet_nvim_sock 2>/dev/null)
  if [ -n "$nsock" ] && [ -S "$nsock" ]; then
    # (Re)source the current fleet.lua first, then call — so this works even for
    # agents whose nvim started before FleetCycleMode existed. Inline lua avoids
    # single quotes (the luaeval string is VimL-single-quoted); _A = the path.
    local res
    # --headless: without it, nvim --remote-expr launched from inside a terminal
    # (e.g. the dashboard pane) starts a TUI and the result comes back wrapped in
    # escape codes — so the "sent" check failed and we double-tapped via fallback.
    res=$(nvim --headless --server "$nsock" --remote-expr \
      "luaeval('(function() dofile(_A) return (_G.FleetCycleMode and _G.FleetCycleMode()) or 0 end)()', '$FLEET_DIR/nvim/fleet.lua')" \
      2>/dev/null)
    case "$res" in
      sent|opening) echo "cycled mode via nvim ($res)"; return 0 ;;
    esac
    echo "nvim RPC failed ($res), falling back to send-keys" >&2
  fi
  # BTab is tmux's name for Shift+Tab (emits \x1b[Z).
  tmux send-keys -t "$pane" BTab \
    && echo "cycled mode via send-keys (focus-dependent for nvim agents)"
}

# ---- main window / command center ---------------------------------------------

main_window_id() { # find existing main window in session
  tmux list-windows -t "$1" -F $'#{window_id}\t#{window_name}' 2>/dev/null \
    | awk -F'\t' '$2=="main"{print $1; exit}'
}

sync_main_tiles() { # ensure exactly one fleet-dash pane next to the orchestrator
  local sess="$1"
  local win; win=$(main_window_id "$sess")
  [ -n "$win" ] || return 1

  # Migrate: kill any legacy per-agent tile panes (old @fleet_tile layout).
  local p
  for p in $(tmux list-panes -t "$win" -F $'#{pane_id}\t#{@fleet_tile}' \
              | awk -F'\t' '$2=="1"{print $1}'); do
    tmux kill-pane -t "$p" 2>/dev/null
  done

  # The dash self-refreshes its whole agent list, so we only ever need one and
  # it should survive across fleet new/main calls — flagged @fleet_dash.
  local dash
  dash=$(tmux list-panes -t "$win" -F $'#{pane_id}\t#{@fleet_dash}' \
          | awk -F'\t' '$2=="1"{print $1; exit}')
  if [ -z "$dash" ]; then
    local orch
    orch=$(tmux list-panes -t "$win" -F '#{pane_id}' | head -1)
    dash=$(tmux split-window -P -F '#{pane_id}' -h -t "$orch" -l '40%' \
      "$FLEET_DIR/bin/fleet-dash" "$sess")
    tmux set -p -t "$dash" @fleet_dash 1
    tmux set -w -t "$win" main-pane-width '60%'
    tmux select-pane -t "$orch" 2>/dev/null
  fi
  # uncoloured pane divider — the active-pane border shouldn't light up between
  # the orchestrator and the dashboard. Match active to inactive (dim grey).
  tmux set -w -t "$win" pane-border-style 'fg=colour238' 2>/dev/null
  tmux set -w -t "$win" pane-active-border-style 'fg=colour238' 2>/dev/null
}

dash_pane_id() { # pane_id of the dashboard in the session's main window, if any
  local win; win=$(main_window_id "$1") || return 1
  [ -n "$win" ] || return 1
  tmux list-panes -t "$win" -F $'#{pane_id}\t#{@fleet_dash}' 2>/dev/null \
    | awk -F'\t' '$2=="1"{print $1; exit}'
}

reload_dash() { # restart the dash process in place — keeps pane size/position;
  local sess="$1"                       # orchestrator + agent windows untouched.
  local dash; dash=$(dash_pane_id "$sess")
  if [ -n "$dash" ]; then
    tmux respawn-pane -k -t "$dash" "$FLEET_DIR/bin/fleet-dash" "$sess"
    echo "dashboard reloaded ($dash)"
  else
    sync_main_tiles "$sess"             # none yet (or legacy tiles) — build fresh
    echo "dashboard built"
  fi
}

# orchestrator helpers: the command-center driver pane can be any harness too.
# load_orch <harness> echoes the binary path AND leaves H_* set in the *caller*
# (so tag_orch_window can read them) — hence it must NOT be run in a $() subshell.
load_orch() { # <harness>; sets ORCH_BIN + H_* in the caller
  harness_load "${1:-claude}"
  ORCH_BIN=$(harness_bin) || die "$H_NAME not found (looked for: $H_BIN)"
  # fold in harness launch flags (e.g. omp --allow-home); tmux runs the string
  # via the shell, so a multi-token command is fine here.
  ORCH_BIN="$ORCH_BIN${H_ARGS:+ $H_ARGS}"
}
tag_orch_window() { # <window_id> — tag with current H_* so hookless orchestrators
  local win="$1"     # still get a status glyph via fleetd's scrape loop
  tmux set -w -t "$win" @fleet_harness "$H_NAME"
  tmux set -w -t "$win" @fleet_state_src "$H_STATE_SRC"
  [ -n "$H_BUSY_RE" ] && tmux set -w -t "$win" @fleet_busy_re "$H_BUSY_RE"
}

cmd_main() {
  local harness=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --reload|reload)
        local sess; sess=$(session_name) || die "not inside tmux"
        reload_dash "$sess"; return ;;
      --harness|-h) harness="$2"; shift 2 ;;
      *) shift ;;
    esac
  done
  local sess; sess=$(session_name) || die "not inside tmux"
  local root; root=$(fleet_root)
  local win; win=$(main_window_id "$sess")
  if [ -z "$win" ]; then
    # orchestrator harness: flag > session memory (@fleet_orch_harness) > claude
    [ -n "$harness" ] || harness=$(tmux show -t "$sess" -v @fleet_orch_harness 2>/dev/null)
    [ -n "$harness" ] || harness=claude
    local ORCH_BIN; load_orch "$harness"
    win=$(tmux new-window -P -F '#{window_id}' -t "$sess" -n main -c "$root" "$ORCH_BIN")
    tag_orch_window "$win"
    tmux set -t "$sess" @fleet_orch_harness "$harness"
    tmux move-window -t "$sess" -s "$win" 2>/dev/null || true
  fi
  sync_main_tiles "$sess"
  tmux select-window -t "$win"
  local oh; oh=$(tmux show -t "$sess" -v @fleet_orch_harness 2>/dev/null)
  echo "command center ready (window 'main', orchestrator: ${oh:-claude})"
}

# Install the fleet orchestrator guide so EVERY harness reads identical
# instructions. claude reads CLAUDE.md; omp (and the cross-tool convention)
# reads AGENTS.md (and CLAUDE.md). Writing BOTH means whatever harness drives
# the orchestrator gets the same fleet instructions. Idempotent + non-destructive:
# creates the file if absent, appends under a marker if present without the guide,
# and leaves a file that already has it untouched.
install_orch_guide() { # <root>
  local root="$1"; local marker="<!-- fleet:orchestrator-guide -->"
  [ -n "$root" ] && [ -f "$FLEET_DIR/FLEET.md" ] || return 0
  local f path
  for f in CLAUDE.md AGENTS.md; do
    path="$root/$f"
    if [ ! -f "$path" ]; then
      { printf '%s\n\n' "$marker"; cat "$FLEET_DIR/FLEET.md"; } > "$path" 2>/dev/null \
        && echo "installed orchestrator guide → $path"
    elif ! grep -qF "$marker" "$path" 2>/dev/null && ! grep -q "fleet new" "$path" 2>/dev/null; then
      { printf '\n%s\n\n' "$marker"; cat "$FLEET_DIR/FLEET.md"; } >> "$path" 2>/dev/null \
        && echo "appended orchestrator guide → $path"
    fi
  done
}

# Switch the orchestrator harness on a running session: respawn just the
# orchestrator pane (left pane of 'main') with the new harness, in place. The
# dashboard pane and every agent window keep running. The previous orchestrator
# agent's conversation/context ends — it's literally a different CLI now.
cmd_orchestrator() {
  local sess; sess=$(session_name) || die "not inside tmux"
  local cur; cur=$(tmux show -t "$sess" -v @fleet_orch_harness 2>/dev/null)
  local h="${1:-}"
  if [ -z "$h" ]; then echo "orchestrator: ${cur:-claude} (switch with: fleet orchestrator <harness>)"; return 0; fi
  local win; win=$(main_window_id "$sess") || true
  [ -n "$win" ] || die "no 'main' window — run: fleet main"
  # orchestrator pane = the main window's pane that ISN'T the dashboard
  # (the dashboard is flagged @fleet_dash=1 by sync_main_tiles).
  local pane
  pane=$(tmux list-panes -t "$win" -F $'#{pane_id}\t#{@fleet_dash}' | awk -F'\t' '$2!="1"{print $1; exit}')
  [ -n "$pane" ] || die "couldn't find the orchestrator pane in 'main'"
  local ORCH_BIN; load_orch "$h"        # validates harness + loads H_* for tagging
  tmux respawn-pane -k -t "$pane" "$ORCH_BIN"
  tag_orch_window "$win"
  tmux set -t "$sess" @fleet_orch_harness "$h"
  # ensure the new harness can read the guide (AGENTS.md if it wasn't there yet)
  local root; root=$(tmux show -t "$sess" -v @fleet_root 2>/dev/null)
  install_orch_guide "$root"
  echo "orchestrator → $h (the previous ${cur:-claude} agent's context ended)"
}

# Jump to the orchestrator: select the current session's 'main' window and focus
# its orchestrator pane (the LEFT pane; the dashboard is the right split, flagged
# @fleet_dash=1 by sync_main_tiles). Session-relative — run via a prefix keybind,
# session_name() resolves to the client that pressed it. Fail-silent everywhere:
# no tmux / no 'main' window / non-fleet session → quietly do nothing.
cmd_orch_jump() {
  local sess; sess=$(session_name 2>/dev/null) || exit 0
  [ -n "$sess" ] || exit 0
  local win; win=$(main_window_id "$sess") || exit 0
  [ -n "$win" ] || exit 0
  tmux select-window -t "$win" 2>/dev/null || exit 0
  # Leftmost pane that ISN'T the dashboard. Sorting by #{pane_left} (not picking
  # the first listed) stays correct if the orchestrator was manually re-split or
  # panes were renumbered by a reload.
  local pane
  pane=$(tmux list-panes -t "$win" -F $'#{pane_left}\t#{pane_id}\t#{@fleet_dash}' 2>/dev/null \
          | awk -F'\t' '$3!="1"{print $1"\t"$2}' | sort -n -k1,1 | head -1 | cut -f2)
  [ -n "$pane" ] && tmux select-pane -t "$pane" 2>/dev/null
  exit 0
}

# Tear down the CURRENT fleet session: kill the command center + every agent
# window in one shot. Session-relative — run via a prefix keybind/menu, so
# session_name() resolves to the client that triggered it. Does NOT stop fleetd
# (it's the shared daemon) and does NOT delete the saved-agents file (kept so
# `fleet up --restore` can rebuild this session later). If a client is attached
# to the session we're about to kill, move it to another tmux session first (or
# detach) so tmux doesn't drop the client abruptly. Fail-silent throughout.
cmd_quit() {
  local sess; sess=$(session_name 2>/dev/null) || exit 0
  [ -n "$sess" ] || exit 0
  # hop the attached client elsewhere before the kill (switch if another session
  # exists, else detach); ignore failures — the kill is what matters.
  local other
  other=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | grep -vxF "$sess" | head -1)
  if [ -n "$other" ]; then
    tmux switch-client -t "$other" 2>/dev/null || true
  else
    tmux detach-client -s "$sess" 2>/dev/null || true
  fi
  tmux kill-session -t "$sess" 2>/dev/null || true
  exit 0
}

# fzf picker over OPEN fleet sessions only (tmux sessions carrying a non-empty
# @fleet_root, set by `fleet up`) -> switch-client to the chosen one. Mirrors
# cmd_pick's fzf styling. Plain tmux sessions (no @fleet_root) are excluded.
# Fallbacks: fzf missing or non-interactive -> print the list plainly (never
# hang); zero or one fleet session -> a friendly message (nothing to switch to).
cmd_sessions() {
  local cur; cur=$(session_name 2>/dev/null)
  local list
  list=$(tmux list-sessions -F $'#{session_name}\t#{@fleet_root}' 2>/dev/null \
          | awk -F'\t' '$2!=""')
  [ -n "$list" ] || { echo "no open fleet sessions"; return 0; }
  local n; n=$(printf '%s\n' "$list" | grep -c .)
  if [ "$n" -le 1 ]; then
    echo "only one open fleet session (${cur:-?}) — nothing to switch to"; return 0
  fi
  # agent counts per session, fetched once (cheap), keyed by session name (col 3).
  local tsv; tsv=$(agents_tsv 2>/dev/null)
  local rows="" name root cnt mark tag
  while IFS=$'\t' read -r name root; do
    [ -n "$name" ] || continue
    cnt=$(printf '%s\n' "$tsv" | awk -F'\t' -v s="$name" '$3==s' | grep -c .)
    if [ "$name" = "$cur" ]; then
      mark=$'\033[32m●\033[0m'; tag=$'  \033[32m(current)\033[0m'
    else
      mark=" "; tag=""
    fi
    rows+=$(printf '%s\t%s %-18s %s  [%s agents]%s' "$name" "$mark" "$name" "$root" "$cnt" "$tag")$'\n'
  done <<< "$list"
  # no fzf / not a tty: print the list plainly and bail (don't hang on fzf).
  if ! command -v fzf >/dev/null || [ ! -t 0 ] || [ ! -t 1 ]; then
    printf '%s' "$rows" | cut -f2-
    return 0
  fi
  local choice
  choice=$(printf '%s' "$rows" | fzf --ansi --delimiter='\t' --with-nth=2 \
            --no-sort --prompt='fleet session> ' --height=100% --border=none) || return 0
  local chosen; chosen=$(printf '%s' "$choice" | cut -f1)
  [ -n "$chosen" ] && tmux switch-client -t "$chosen" 2>/dev/null
}

# ---- up -----------------------------------------------------------------------

ensure_daemon() {
  [ -S "$SOCK" ] && rpc fleet.ping >/dev/null 2>&1 && return 0
  systemctl --user start fleetd 2>/dev/null && sleep 0.3 && [ -S "$SOCK" ] && return 0
  if command -v fleetd >/dev/null; then
    nohup fleetd >/dev/null 2>&1 &
  else
    nohup "$FLEET_DIR/bin/fleetd" >/dev/null 2>&1 &
  fi
  sleep 0.3
}

inject_status_format() { # append agent glyph to window-status formats.
  # window-status-* are window options — tmux has no per-session scope for
  # them, so inject into the runtime GLOBAL value (never the config file).
  # Theme switches that regenerate pills wipe this; fleetd re-injects on its
  # sweep, fleet up on every run.
  local fmt opt
  for opt in window-status-format window-status-current-format; do
    fmt=$(tmux show -g -v "$opt" 2>/dev/null)
    [ -n "$fmt" ] || continue
    case "$fmt" in *@agent_glyph*) ;; *) tmux set -g "$opt" "$fmt#{?@agent_glyph, #{@agent_glyph},}" ;; esac
  done
}

# ---- keybinds -----------------------------------------------------------------
# Keys are bound under the tmux prefix and stored in keybinds.conf as
# `action=key` lines. Bindings are server-global and re-applied on every
# `fleet up`, never written to tmux.conf. The menu (and `fleet rebind`) edit
# this file and re-apply live.

KEYBINDS_CONF="$CONF_DIR/keybinds.conf"

# action|default-key|menu label|description
fleet_actions() {
  cat <<'EOF'
menu|F|Feature menu|Open this menu
pick|a|Pick / jump to agent|fzf popup of all agents, Enter jumps
new|n|New agent|Prompt for "repo branch", spawn agent
save|s|Save project|Save this session as a reusable project alias (fleet up <name>)
orch-jump|m|Orchestrator|Jump to the main window's orchestrator pane
main|M|Rebuild command center|Re-tile the main window
reload|R|Reload dashboard|Restart the dashboard pane in place (picks up new code)
ls|l|List agents|Show agent states in a popup
sessions|o|Fleet sessions|Switch between open fleet sessions
quit|Q|Quit fleet|Kill this fleet session (closes all agents)
EOF
}

keybind_for() { # keybind_for <action> → key (config override or default)
  local action="$1" key=""
  if [ -f "$KEYBINDS_CONF" ]; then
    key=$(awk -F= -v a="$action" '$1==a{print $2; exit}' "$KEYBINDS_CONF")
  fi
  [ -n "$key" ] && { echo "$key"; return; }
  fleet_actions | awk -F'|' -v a="$action" '$1==a{print $2; exit}'
}

action_tmux_command() { # tmux command string run when an action's key is pressed
  local action="$1" self="$FLEET_DIR/bin/fleet"
  case "$action" in
    menu) echo "run-shell '$self menu'" ;;
    pick) echo "display-popup -E -b rounded -w 80% -h 60% '$self pick'" ;;
    new)  echo "command-prompt -p 'fleet new (repo branch):' \"run-shell '$self new %%'\"" ;;
    save) echo "command-prompt -p 'fleet save (name, blank=session):' \"run-shell '$self save %%'\"" ;;
    main)   echo "run-shell '$self main'" ;;
    orch-jump) echo "run-shell '$self orch-jump'" ;;
    reload) echo "display-menu -b rounded -T '#[align=centre]Reload dashboard?' -x C -y C 'Yes, reload' y \"run-shell '$self main --reload'\" 'Cancel' n ''" ;;
    ls)     echo "display-popup -E -b rounded -w 70% -h 60% \"$self ls; echo; read -n1 -r -p 'press any key'\"" ;;
    sessions) echo "display-popup -E -b rounded -w 70% -h 60% '$self sessions'" ;;
    quit)   echo "display-menu -b rounded -T '#[align=centre]Quit fleet session? (closes all agents)' -x C -y C 'Yes, quit' y \"run-shell '$self quit'\" 'Cancel' n ''" ;;
  esac
}

apply_keybinds() {
  local action key cmd
  while IFS='|' read -r action _ _ _; do
    key=$(keybind_for "$action")
    cmd=$(action_tmux_command "$action")
    [ -n "$key" ] && [ -n "$cmd" ] || continue
    eval "tmux bind-key '$key' $cmd"
  done < <(fleet_actions)
}

cmd_menu() {
  local args=() action key label
  while IFS='|' read -r action key_default label _; do
    key=$(keybind_for "$action")
    args+=("$label  (prefix $key)" "$key" "$(action_tmux_command "$action")")
  done < <(fleet_actions)
  tmux display-menu -b rounded -T "#[align=centre]󰭹 Fleet" -x C -y C \
    "${args[@]}" \
    "" \
    "Change a keybind" "c" "run-shell '$FLEET_DIR/bin/fleet rebind'" \
    "Close" "q" ""
}

cmd_rebind() {
  local args=() action key label
  while IFS='|' read -r action key_default label _; do
    key=$(keybind_for "$action")
    args+=("$label  [$key]" "" \
      "command-prompt -1 -p 'new key for $action:' \"run-shell '$FLEET_DIR/bin/fleet rebind-set $action %%'\"")
  done < <(fleet_actions)
  tmux display-menu -b rounded -T "#[align=centre]Rebind which feature?" -x C -y C "${args[@]}"
}

cmd_rebind_set() { # rebind-set <action> <key>
  local action="$1" key="$2"
  [ -n "$action" ] && [ -n "$key" ] || return 0
  mkdir -p "$CONF_DIR"
  touch "$KEYBINDS_CONF"
  # release the action's previous key unless another action still uses it
  local oldkey; oldkey=$(keybind_for "$action")
  if [ -n "$oldkey" ] && [ "$oldkey" != "$key" ]; then
    local still=""
    while IFS='|' read -r a _ _ _; do
      [ "$a" = "$action" ] && continue
      [ "$(keybind_for "$a")" = "$oldkey" ] && still=1
    done < <(fleet_actions)
    [ -z "$still" ] && tmux unbind-key "$oldkey" 2>/dev/null
  fi
  # warn (don't block) if the key already drives another fleet action
  local clash; clash=$(
    while IFS='|' read -r a _ _ _; do
      [ "$a" = "$action" ] && continue
      [ "$(keybind_for "$a")" = "$key" ] && echo "$a"
    done < <(fleet_actions)
  )
  local tmp; tmp=$(mktemp)
  awk -F= -v a="$action" '$1!=a' "$KEYBINDS_CONF" > "$tmp"
  echo "$action=$key" >> "$tmp"
  mv "$tmp" "$KEYBINDS_CONF"
  apply_keybinds
  if [ -n "$clash" ]; then
    tmux display-message "fleet: $action → prefix $key (also bound: $clash)"
  else
    tmux display-message "fleet: $action → prefix $key"
  fi
}

cmd_keys() { # plain text listing
  printf 'ACTION\tKEY\tDESCRIPTION\n'
  local action key label desc
  while IFS='|' read -r action key_default label desc; do
    key=$(keybind_for "$action")
    printf '%s\tprefix %s\t%s\n' "$action" "$key" "$desc"
  done < <(fleet_actions)
  echo
  echo "config: $KEYBINDS_CONF  (edit or use the menu / 'fleet rebind')"
}

cmd_up() {
  local arg="" root name restore=0 harness=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --restore) restore=1; shift ;;
      --harness|-h) harness="$2"; shift 2 ;;
      *) [ -z "$arg" ] && arg="$1"; shift ;;
    esac
  done
  if [ -n "$arg" ] && [ -d "$arg" ]; then
    root=$(readlink -f "$arg")
    name=$(basename "$root" | tr -cd 'a-zA-Z0-9_-')
  elif [ -n "$arg" ]; then
    name="$arg"
    local yml="$CONF_DIR/projects/$arg.yml"
    if [ -f "$yml" ]; then
      root=$(awk -F': *' '$1=="root"{print $2; exit}' "$yml")
      root="${root/#\~/$HOME}"
    fi
    [ -n "${root:-}" ] || root="$PWD"
  else
    root="$PWD"
    name=$(basename "$root" | tr -cd 'a-zA-Z0-9_-')
  fi
  [ -d "$root" ] || die "project root $root does not exist"

  ensure_daemon

  if ! tmux has-session -t "=$name" 2>/dev/null; then
    if command -v tmuxinator >/dev/null && tmuxinator list -n 2>/dev/null | grep -qx "$name"; then
      tmuxinator start "$name" --no-attach 2>/dev/null || true
    fi
    if ! tmux has-session -t "=$name" 2>/dev/null; then
      # fresh session: main IS the first window, orchestrator runs in it —
      # no placeholder shell window. Orchestrator harness: flag > project
      # .fleet/harness > config (harness=) > claude.
      local orch="$harness"
      if [ -z "$orch" ] && [ -f "$root/.fleet/harness" ]; then
        orch=$(head -1 "$root/.fleet/harness" 2>/dev/null | tr -d '[:space:]')
      fi
      if [ -z "$orch" ] && [ -f "$CONF_DIR/config" ]; then
        orch=$(grep -E '^harness=' "$CONF_DIR/config" 2>/dev/null | tail -1 | cut -d= -f2 | tr -d '[:space:]')
      fi
      [ -n "$orch" ] || orch=claude
      local ORCH_BIN; load_orch "$orch"
      tmux new-session -d -s "$name" -c "$root" -n main "$ORCH_BIN"
      tag_orch_window "$(tmux list-windows -t "$name" -F '#{window_id}' | head -1)"
      tmux set -t "$name" @fleet_orch_harness "$orch"
    fi
  fi

  tmux set -t "$name" @fleet_root "$root"
  inject_status_format "$name"
  # runtime keybinds (server-global; re-applied each `up`, never in tmux.conf)
  apply_keybinds

  # install the fleet guide for whatever harness drives the orchestrator
  # (CLAUDE.md for claude, AGENTS.md for omp/others — write both, same content)
  install_orch_guide "$root"

  # build command center, explicitly targeting the project session
  FLEET_SESSION="$name" FLEET_ROOT="$root" cmd_main || true

  # restore previously-open agents (after a tmux/server restart), or hint
  if [ "$restore" = 1 ]; then
    FLEET_SESSION="$name" FLEET_ROOT="$root" cmd_restore || true
  elif [ -s "$(agents_file "$name")" ]; then
    echo "  $(grep -c . "$(agents_file "$name")") saved agent(s) — run 'fleet restore' (or 'fleet up --restore')"
  fi

  if [ -t 0 ]; then
    if [ -n "${TMUX:-}" ]; then tmux switch-client -t "$name"; else tmux attach -t "$name"; fi
  else
    echo "session '$name' ready — attach with: tmux attach -t $name"
  fi
}

cmd_save() { # save [name] — save the current session as a reusable project alias
  local name="${1:-}" sess root
  sess=$(session_name 2>/dev/null)
  [ -n "$sess" ] && root=$(tmux show -t "$sess" -v @fleet_root 2>/dev/null)
  if [ -z "${root:-}" ]; then
    # not inside a fleet session (no @fleet_root) — surface clearly, fall back to PWD.
    root="$PWD"
    echo "fleet save: not inside a fleet session (no @fleet_root) — using \$PWD: $root" >&2
  fi
  [ -n "$root" ] && [ -d "$root" ] || die "could not determine project root"
  # default name: session name, else basename of root. sanitize to a safe filename.
  [ -n "$name" ] || name="${sess:-$(basename "$root")}"
  name=$(printf '%s' "$name" | tr -cd 'a-zA-Z0-9_-')
  [ -n "$name" ] || die "could not derive a valid project name"
  mkdir -p "$CONF_DIR/projects" 2>/dev/null || die "could not create $CONF_DIR/projects"
  local yml="$CONF_DIR/projects/$name.yml" verb="saved"
  [ -f "$yml" ] && verb="updated"
  local rootc="${root/#$HOME/\~}"   # contract $HOME to ~ for portability (cmd_up re-expands)
  # name: is for readability; cmd_up keys off the FILENAME, only reads root:.
  printf 'name: %s\nroot: %s\n' "$name" "$rootc" > "$yml" || die "could not write $yml"
  echo "$verb project '$name' -> $rootc"
  echo "  'fleet up $name' now starts this project from anywhere."
}

# ---- status / doctor ------------------------------------------------------------

cmd_status() {
  # Read-only "what is LIVE" report for the pc-tune config repos. The logic lives
  # in bin/fleet-status (single source — see docs/config-sync-architecture.md §3.1);
  # we just exec it. Fail-silent if it's missing.
  local sx="$FLEET_DIR/bin/fleet-status"
  if [ -x "$sx" ]; then exec "$sx" "$@"; fi
  [ -f "$sx" ] && exec bash "$sx" "$@"
  echo "fleet status: bin/fleet-status not found" >&2; return 0
}

cmd_doctor() {
  local ok=0
  for dep in tmux nvim git python3 fzf; do
    if command -v "$dep" >/dev/null; then echo "ok   $dep"; else echo "MISS $dep"; ok=1; fi
  done
  command -v notify-send >/dev/null && echo "ok   notify-send" || echo "warn notify-send missing (no desktop notifications)"
  command -v tmuxinator >/dev/null && echo "ok   tmuxinator (optional)" || echo "warn tmuxinator missing (fleet up builds sessions itself)"
  command -v claude-profile >/dev/null && echo "ok   claude-profile" \
    || { command -v claude >/dev/null && echo "ok   claude (no profile wrapper)" || { echo "MISS claude"; ok=1; }; }
  # harness adapters + whether each one's binary is on PATH
  local h; for h in $(harness_list); do
    if harness_load "$h" 2>/dev/null && harness_bin >/dev/null 2>&1; then
      echo "ok   harness: $h ($(harness_bin))"
    else echo "warn harness: $h (binary not found: $H_BIN)"; fi
  done
  echo "     default harness: $(harness_select)"
  [ -S "$SOCK" ] && rpc fleet.ping >/dev/null 2>&1 && echo "ok   fleetd socket" || echo "warn fleetd not running (fleet up starts it)"
  # The hook bin must resolve to a real executable: a dangling fleet-hook symlink
  # (e.g. installed from a clone that was later deleted) makes every Claude hook
  # exit non-zero, so no agent ever reports and the dashboard shows 0 agents.
  local hookbin; hookbin=$(command -v fleet-hook 2>/dev/null)
  if [ -n "$hookbin" ] && [ -x "$hookbin" ] && [ -e "$(readlink -f "$hookbin" 2>/dev/null)" ]; then
    echo "ok   fleet-hook -> $(readlink -f "$hookbin")"
  else
    echo "MISS fleet-hook missing or dangling symlink (run install.sh) — agents won't report"; ok=1
  fi
  local prof hooked
  for prof in "$HOME/.claude" "$HOME/.claude_personal"; do
    [ -f "$prof/settings.json" ] || continue
    hooked=$(grep -c fleet-hook "$prof/settings.json" 2>/dev/null || true)
    if [ "${hooked:-0}" -gt 0 ]; then echo "ok   hooks wired in $prof"; else echo "warn hooks NOT wired in $prof (run install.sh)"; fi
  done
  if systemctl --user show-environment >/dev/null 2>&1; then
    systemctl --user is-enabled fleetd >/dev/null 2>&1 && echo "ok   fleetd.service enabled" \
      || echo "warn fleetd.service not enabled (ok if installed --no-systemd; 'fleet up' starts it)"
  else
    echo "ok   no systemd user bus — fleetd runs on demand (nohup via 'fleet up')"
  fi
  doctor_config_sync   # non-fatal advisories: symlinks / chezmoi / stale clones
  return $ok
}

# config-sync guardrails (docs/config-sync-architecture.md §3.4). Read-only,
# non-fatal advisories in doctor's pass/warn style. Guards every git/chezmoi call.
doctor_config_sync() {
  local root rootr
  root="${PC_TUNE_ROOT:-$HOME/proj/pc-tune}"
  rootr="$(readlink -f "$root" 2>/dev/null)"
  [ -n "$rootr" ] || return 0
  echo "--- config-sync (pc-tune) ---"

  # repo -> live deployed path (the symlink the running tool reaches through)
  local specs=(
    "nvim|$HOME/.config/nvim"
    "tmux|$HOME/.tmux.conf"
    "tmuxinator|$HOME/.config/tmuxinator"
    "fleet|$HOME/.local/bin/fleet"
  )

  local spec name link gd mains nmain canon canonr got
  for spec in "${specs[@]}"; do
    IFS='|' read -r name link <<<"$spec"
    gd="$root/$name/.git"

    # canonical main = the worktree whose branch is main, per git itself (NOT
    # a hardcoded path). May be a bare-repo .git or a worktree's .git file.
    mains="$(git --git-dir="$gd" worktree list --porcelain 2>/dev/null | awk '
      /^worktree /{wt=substr($0,10)}
      /^branch /{ if ($2=="refs/heads/main") print wt }')"
    nmain="$(printf '%s\n' "$mains" | grep -c . 2>/dev/null)"
    canon="$(printf '%s\n' "$mains" | head -1)"

    if [ -z "$canon" ]; then
      echo "warn $name: no worktree claims branch main (cannot verify live link)"
      continue
    fi
    [ "${nmain:-0}" -gt 1 ] && echo "warn $name: >1 worktree claims main — ambiguous live target"
    canonr="$(readlink -f "$canon" 2>/dev/null)"

    # canonical main must live under a known container root (~/proj/pc-tune)
    case "$canonr/" in
      "$rootr"/*) ;;
      *) echo "warn $name: main worktree '$canon' is outside container root $root" ;;
    esac

    # the live deployed path must be a symlink resolving inside canonical main
    if [ -L "$link" ]; then
      got="$(readlink -f "$link" 2>/dev/null)"
      if [ -z "$got" ]; then
        echo "warn $name: live link $link is DANGLING"
      elif [ "$got" = "$canonr" ] || case "$got" in "$canonr"/*) true;; *) false;; esac; then
        echo "ok   $name: live $link → $canon (canonical main)"
      else
        echo "warn $name: live $link → $got NOT under canonical main $canon"
      fi
    elif [ -e "$link" ]; then
      echo "warn $name: $link is a COPY, not a symlink — config drifted out of git"
    else
      echo "warn $name: live link $link is missing"
    fi
  done

  # chezmoi must manage NONE of the exact live targets. Anchored exact match —
  # NOT a loose 'tmux' grep (that false-positives on the TPM external + omarchy).
  if command -v chezmoi >/dev/null 2>&1; then
    local hit
    hit="$(chezmoi managed 2>/dev/null | grep -Ex '\.config/nvim|\.tmux\.conf|\.config/tmuxinator|\.local/bin/fleet' || true)"
    if [ -z "$hit" ]; then
      echo "ok   chezmoi: no config-repo path managed (axes decoupled)"
    else
      echo "warn chezmoi MANAGES config-repo path(s) — re-coupling, 'chezmoi forget' them:"
      printf '%s\n' "$hit" | sed 's/^/       /'
    fi
  else
    echo "ok   chezmoi not installed (decoupling N/A)"
  fi

  # stale sibling clones of these repos directly under ~/proj (outside pc-tune)
  local r d stale=
  for r in fleet nvim tmux tmuxinator; do
    d="$HOME/proj/$r"
    if git -C "$d" rev-parse --git-dir >/dev/null 2>&1; then
      echo "warn stale clone at $d (outside pc-tune) — a trap; see doc §3.4"
      stale=1
    fi
  done
  [ -n "$stale" ] || echo "ok   no stale sibling clones in ~/proj"
}

# ---- dispatch -------------------------------------------------------------------

print_usage() {
  local menu_key; menu_key=$(keybind_for menu); cat <<EOF
fleet — agent fleet manager (tmux + nvim + Claude Code)

  fleet                  (bare, interactive) fzf picker of saved projects -> fleet up
  fleet up [name|path]   boot project session + daemon + command center ([--restore])
  fleet save [name]      save the current session as a reusable project alias (fleet up <name>)
  fleet restore          respawn saved agents from a previous session
  fleet new <repo> <br>  spawn agent (worktree + window + claude) [-p prompt] [--bare] [--switch|-s] [--base br] [-h harness]
  fleet new --scratch    spawn a repo-less agent (no repo/branch/worktree) [label] [-p prompt] [-h harness]
  fleet ls               list agents and states
  fleet pick             fzf jump-to-agent
  fleet send <a> "msg"   send message to an agent's claude
  fleet ready [a] [-m r]  flag a worktree done/ready for deletion (no arg = the one you're in) [--clear]
  fleet reap             remove all worktrees flagged ready (skips unmerged/dirty unless --force)
  fleet fan <repo> <nm>  best-of-N: spawn N agents on one prompt [-n N] [-p prompt] [--base br] [--bare]
  fleet cost <a>         show an agent's token spend
  fleet guard on|off     test/CI write-guard (asks before editing tests/CI/lockfiles)
  fleet mode <a>         cycle an agent's Claude permission mode (Shift+Tab)
  fleet main [--reload]  (re)build command center window (--reload restarts just the dashboard)
  fleet sessions         fzf switch between open fleet sessions (prefix+$(keybind_for sessions))
  fleet quit             tear down THIS fleet session — kills all its windows (prefix+$(keybind_for quit))
  fleet menu             feature menu (bound to prefix+$menu_key by fleet up)
  fleet keys             list feature keybinds
  fleet rebind           change a keybind interactively
  fleet status           live config report (what's deployed, per config repo)
  fleet doctor           dependency / wiring check
EOF
}

case "${1:-}" in
  up)      shift; cmd_up "$@" ;;
  save)    shift; cmd_save "$@" ;;
  new)     shift; cmd_new "$@" ;;
  ls)      shift; cmd_ls "$@" ;;
  agents)  shift; agents_tsv "$@" ;;   # raw TSV, consumed by fleet-dash
  repos)    shift; cmd_repos "$@" ;;     # repo names, for the new-agent form
  branches) shift; cmd_branches "$@" ;;  # base branches for a repo
  worktrees) shift; cmd_worktrees "$@" ;; # existing worktrees of a repo
  harnesses) shift; cmd_harnesses "$@" ;; # installed harness adapters (for the form)
  restore)  shift; cmd_restore "$@" ;;   # respawn saved agents
  forget)   shift; cmd_forget "$@" ;;    # drop a saved agent (dashboard teardown)
  guard)    shift; cmd_guard "$@" ;;     # toggle the test/CI write-guard
  fan)      shift; cmd_fan "$@" ;;        # best-of-N fan-out
  cost)     shift; cmd_cost "$@" ;;       # per-agent token/cost
  cost-pane) shift; cost_for_pane "$@" ;; # raw cost for a pane (dashboard)
  pick)    shift; cmd_pick "$@" ;;
  send)    shift; cmd_send "$@" ;;
  watch)     shift; cmd_watch "$@" ;;
  watch-run) shift; cmd_watch_run "$@" ;;  # internal: detached watcher
  ready)   shift; cmd_ready "$@" ;;        # flag a worktree done/ready for reap
  reap)    shift; cmd_reap "$@" ;;         # remove flagged-ready worktrees
  mode)    shift; cmd_mode "$@" ;;
  main)       shift; cmd_main "$@" ;;
  orch-jump)  shift; cmd_orch_jump "$@" ;;            # internal: prefix-key jump to orchestrator pane
  apply-keybinds) shift; apply_keybinds ;;            # internal: re-apply runtime keybinds live
  orchestrator|orch) shift; cmd_orchestrator "$@" ;;  # switch orchestrator harness live
  sessions|switch) shift; cmd_sessions "$@" ;;        # fzf switcher over open fleet sessions
  quit)       shift; cmd_quit "$@" ;;                 # tear down THIS fleet session
  menu)       shift; cmd_menu "$@" ;;
  keys)       shift; cmd_keys "$@" ;;
  rebind)     shift; cmd_rebind "$@" ;;
  rebind-set) shift; cmd_rebind_set "$@" ;;
  status)     shift; cmd_status "$@" ;;
  doctor)     shift; cmd_doctor "$@" ;;
  help|-h|--help) print_usage ;;       # explicit help: always the usage text
  "")
    # bare `fleet`: project picker only when interactive (stdin+stdout tty) AND
    # fzf present AND projects exist (cmd_pick_project handles the latter two).
    # Otherwise usage. NOTE: scripts/dashboard always call WITH a subcommand and
    # non-interactively, so they keep getting usage, never a popup.
    if [ -t 0 ] && [ -t 1 ]; then cmd_pick_project; else print_usage; fi
    ;;
  *) print_usage ;;                     # a real unknown subcommand (typo) -> usage, not picker
esac
